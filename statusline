#!/usr/bin/env bash
set -u

readonly input="$(cat)"
parsed=$(printf '%s' "$input" | jq -ejr '[
  (.model.id // ""),
  (.model.display_name // ""),
  (.effort.level // ""),
  (if .context_window.used_percentage == null then "" else (.context_window.used_percentage | floor | tostring) end),
  (.session_id // ""),
  (.context_window.total_input_tokens // 0 | tostring),
  (.context_window.context_window_size // 0 | tostring),
  (.columns // 0 | tostring)
] | join("\u001f")' 2>/dev/null) || parsed=$'\x1f\x1f\x1f\x1f\x1f\x1f\x1f'

IFS=$'\x1f' read -r model_id display_name effort context_percent session_id total_input_tokens context_window_size input_columns <<< "$parsed"

sanitize_terminal_text() {
  # Strip terminal protocols before ordinary controls so OSC/DCS payloads do
  # not become visible spoofing text. The final pass also removes C0/C1 and
  # Unicode bidi formatting while preserving normal Unicode display text.
  printf '%s' "$1" | jq -Rjr '
    gsub("(?:\u001b\\]|\u009d)[^\u0007\u001b\u009c]*(?:\u0007|\u001b\\\\|\u009c)?"; "") |
    gsub("(?:\u001b\\[|\u009b)[0-?]*[ -/]*[@-~]"; "") |
    gsub("(?:\u001b[P_^X]|[\u0090\u0098\u009e\u009f])[^\u001b\u009c]*(?:\u001b\\\\|\u009c)?"; "") |
    gsub("\u001b."; "") |
    gsub("[\u0000-\u001f\u007f-\u009f\u061c\u200e\u200f\u202a-\u202e\u2066-\u2069]"; "")
  ' 2>/dev/null || printf ''
}

sanitize_terminal_label() {
  # Model and effort fields are semantic labels, not free-form terminal text.
  # Retain only the safe prefix before the first control or bidi formatter so
  # visible text placed after a stripped protocol cannot join, replace, or
  # otherwise spoof the label. Styling is added by this script after this
  # boundary; no input-owned terminal sequence is preserved.
  printf '%s' "$1" | jq -Rjr '
    sub("[\u0000-\u001f\u007f-\u009f\u061c\u200e\u200f\u202a-\u202e\u2066-\u2069].*$"; "")
  ' 2>/dev/null || printf ''
}

statusline_file_mtime() {
  if stat -f '%m' "$1" >/dev/null 2>&1; then stat -f '%m' "$1" 2>/dev/null
  else stat -c '%Y' "$1" 2>/dev/null
  fi
}

prune_statusline_cache() {
  local cache_dir="$1" protected_file="${2:-}" now cutoff file name mtime oldest oldest_mtime count
  local -a files
  [[ -d "$cache_dir" ]] || return 0
  now=$(date +%s)
  cutoff=$(( now - 604800 ))
  files=()
  while IFS= read -r -d '' file; do
    name=${file##*/}
    [[ "$name" =~ ^[A-Za-z0-9._-]+$ && "$name" != .context.tmp.* ]] || continue
    mtime=$(statusline_file_mtime "$file" 2>/dev/null || printf 0)
    if [[ "$mtime" =~ ^[0-9]+$ ]] && (( mtime < cutoff )); then
      rm -f "$file"
    else
      files+=("$file")
    fi
  done < <(find "$cache_dir" -maxdepth 1 -type f -print0 2>/dev/null)

  count=${#files[@]}
  while (( count > 128 )); do
    oldest=""
    oldest_mtime=$now
    for file in "${files[@]}"; do
      [[ -f "$file" && "$file" != "$protected_file" ]] || continue
      mtime=$(statusline_file_mtime "$file" 2>/dev/null || printf 0)
      if [[ "$mtime" =~ ^[0-9]+$ ]] && (( mtime <= oldest_mtime )); then
        oldest="$file"
        oldest_mtime=$mtime
      fi
    done
    [[ -n "$oldest" ]] || break
    rm -f "$oldest"
    count=$(( count - 1 ))
  done
}

stabilize_context_percent() {
  local candidate="$context_percent"
  local config_dir="${CLAUDE_CONFIG_DIR:-$HOME/.config/claudex}"
  local cache_dir cache_file cached tmp_file computed

  # A zero/null payload is transient before the first response and briefly
  # after compaction. When token totals are usable, calculate the real value;
  # otherwise retain only this session's last trustworthy percentage.
  if [[ ! "$candidate" =~ ^[0-9]+$ || "$candidate" == 0 ]]; then
    if [[ "$total_input_tokens" =~ ^[0-9]+$ \
        && "$context_window_size" =~ ^[0-9]+$ \
        && "$total_input_tokens" -gt 0 \
        && "$context_window_size" -gt 0 ]]; then
      computed=$(( total_input_tokens * 100 / context_window_size ))
      if (( computed > 0 )); then
        candidate="$computed"
      else
        candidate="<1"
      fi
    else
      candidate=""
    fi
  fi

  if [[ "${CLAUDEX_NO_SESSION_PERSISTENCE:-0}" != 1 && "$session_id" =~ ^[A-Za-z0-9._-]+$ ]]; then
    cache_dir="$config_dir/statusline-cache"
    cache_file="$cache_dir/$session_id"
    if [[ -n "$candidate" ]]; then
      if mkdir -p "$cache_dir" 2>/dev/null; then
        chmod 700 "$cache_dir" 2>/dev/null || true
        tmp_file=$(mktemp "$cache_dir/.context.tmp.XXXXXX" 2>/dev/null || true)
        if [[ -n "$tmp_file" ]]; then
          umask 077
          if printf '%s\n' "$candidate" > "$tmp_file" && mv -f "$tmp_file" "$cache_file"; then
            chmod 600 "$cache_file" 2>/dev/null || true
            prune_statusline_cache "$cache_dir" "$cache_file"
          else
            rm -f "$tmp_file"
          fi
        fi
      fi
    elif [[ -r "$cache_file" ]]; then
      IFS= read -r cached < "$cache_file" || cached=""
      if [[ "$cached" =~ ^([1-9][0-9]{0,2}|<1)$ ]]; then
        candidate="$cached"
      fi
    fi
  fi

  context_percent="$candidate"
}

stabilize_context_percent

usage_summary=""
load_usage_summary() {
  local display="${CLAUDEX_USAGE_DISPLAY:-on}"
  local config_dir="${CLAUDE_CONFIG_DIR:-$HOME/.config/claudex}"
  local helper="${CLAUDEX_USAGE_LIMIT_BIN:-$config_dir/usage-limit}"
  local cache_dir="$config_dir/usage-cache"
  local summary_file="$cache_dir/summary"
  local last_attempt_file="$cache_dir/last-attempt"
  local last_success_file="$cache_dir/last-success"
  local refresh_seconds="${CLAUDEX_USAGE_REFRESH_SECONDS:-300}"
  local max_stale_seconds="${CLAUDEX_USAGE_MAX_STALE_SECONDS:-86400}"
  local now last_attempt=0 last_success=0

  [[ "$display" != off && -x "$helper" ]] || return 0
  if [[ ! "$refresh_seconds" =~ ^[0-9]+$ ]] || (( refresh_seconds < 60 || refresh_seconds > 3600 )); then
    refresh_seconds=300
  fi
  if [[ ! "$max_stale_seconds" =~ ^[0-9]+$ ]] || (( max_stale_seconds < refresh_seconds || max_stale_seconds > 604800 )); then
    max_stale_seconds=86400
  fi
  now=$(date +%s)
  if [[ -r "$last_attempt_file" ]]; then IFS= read -r last_attempt < "$last_attempt_file" || last_attempt=0; fi
  if [[ ! "$last_attempt" =~ ^[0-9]+$ ]]; then last_attempt=0; fi

  if (( now - last_attempt >= refresh_seconds )); then
    mkdir -p "$cache_dir" 2>/dev/null || true
    chmod 700 "$cache_dir" 2>/dev/null || true
    (umask 077; printf '%s\n' "$now" > "$last_attempt_file") 2>/dev/null || return 0
    chmod 600 "$last_attempt_file" 2>/dev/null || true
    # The helper owns the complete generation-safe refresh lock protocol.
    # Starting an occasional losing helper is cheaper and safer than duplicating
    # lock mutation in the frequently invoked status-line process.
    nohup env \
        -u CLAUDEX_PROXY_TOKEN -u CLAUDEX_PROXY_URL -u CLAUDEX_PROXY_CONFIG -u CLAUDEX_PROXY_BIN \
        -u ANTHROPIC_AUTH_TOKEN -u ANTHROPIC_BASE_URL -u CLAUDE_CODE_USE_BEDROCK \
        -u CLAUDE_CODE_USE_VERTEX -u CLAUDE_CODE_USE_FOUNDRY \
        -u ANTHROPIC_BEDROCK_BASE_URL -u ANTHROPIC_BEDROCK_MANTLE_BASE_URL \
        -u ANTHROPIC_VERTEX_BASE_URL -u ANTHROPIC_VERTEX_PROJECT_ID \
        -u ANTHROPIC_FOUNDRY_BASE_URL -u ANTHROPIC_FOUNDRY_RESOURCE -u ANTHROPIC_FOUNDRY_API_KEY \
        -u ANTHROPIC_API_KEY -u CLAUDE_CODE_OAUTH_TOKEN -u ANTHROPIC_CUSTOM_HEADERS \
        -u ANTHROPIC_MODEL -u ANTHROPIC_SMALL_FAST_MODEL -u ANTHROPIC_SMALL_FAST_MODEL_AWS_REGION \
        -u ANTHROPIC_CUSTOM_MODEL_OPTION -u ANTHROPIC_CUSTOM_MODEL_OPTION_NAME \
        -u ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION \
        "$helper" --refresh-cache >/dev/null 2>&1 </dev/null &
  fi

  if [[ -r "$last_success_file" ]]; then IFS= read -r last_success < "$last_success_file" || last_success=0; fi
  [[ "$last_success" =~ ^[0-9]+$ ]] || last_success=0
  if (( now - last_success <= max_stale_seconds )) && [[ -r "$summary_file" ]]; then
    IFS= read -r usage_summary < "$summary_file" || usage_summary=""
  fi
}

load_usage_summary

model_id=$(sanitize_terminal_label "$model_id")
display_name=$(sanitize_terminal_label "$display_name")
usage_summary=$(sanitize_terminal_text "$usage_summary")

if [[ -z "$effort" ]]; then
  effort="${CLAUDE_CODE_EFFORT_LEVEL:-${CLAUDE_EFFORT:-}}"
fi
if [[ -z "$effort" && -r "${CLAUDE_CONFIG_DIR:-$HOME/.config/claudex}/settings.json" ]]; then
  effort=$(jq -r '.effortLevel // empty' \
    "${CLAUDE_CONFIG_DIR:-$HOME/.config/claudex}/settings.json" 2>/dev/null) || effort=""
fi
if [[ -n "${CLAUDEX_SESSION_MODE:-}" ]]; then
  effort="$CLAUDEX_SESSION_MODE"
fi
effort=$(sanitize_terminal_label "$effort")
readonly effort="${effort:-adaptive}"

case "$model_id" in
  gpt-5.6-sol) model_name="GPT-5.6 Sol" ;;
  gpt-5.6-terra) model_name="GPT-5.6 Terra" ;;
  gpt-5.6-luna) model_name="GPT-5.6 Luna" ;;
  claude-fable-*|claude-opus-*) model_name="GPT-5.6 Sol" ;;
  claude-sonnet-*) model_name="GPT-5.6 Terra" ;;
  claude-haiku-*) model_name="GPT-5.6 Luna" ;;
  *)
    case "$display_name" in
      *Fable*|*Opus*) model_name="GPT-5.6 Sol" ;;
      *Sonnet*) model_name="GPT-5.6 Terra" ;;
      *Haiku*) model_name="GPT-5.6 Luna" ;;
      *) model_name="${model_id:-${display_name:-Unknown model}}" ;;
    esac
    ;;
esac
selected_model_mode="${CLAUDEX_MODEL_MODE:-}"
if [[ -z "$selected_model_mode" && -r "${CLAUDE_CONFIG_DIR:-$HOME/.config/claudex}/settings.json" ]]; then
  selected_model_mode=$(jq -r 'if .model == "opusplan" then "solplan" else "" end' \
    "${CLAUDE_CONFIG_DIR:-$HOME/.config/claudex}/settings.json" 2>/dev/null) || selected_model_mode=""
fi
if [[ "$selected_model_mode" == solplan ]]; then model_name="GPT-5.6 Solplan"; fi
model_name=$(sanitize_terminal_label "$model_name")

statusline_columns="${CLAUDEX_STATUSLINE_COLUMNS:-}"
if [[ ! "$statusline_columns" =~ ^[1-9][0-9]*$ ]] && [[ "$input_columns" =~ ^[1-9][0-9]*$ ]]; then
  statusline_columns="$input_columns"
fi
if [[ ! "$statusline_columns" =~ ^[1-9][0-9]*$ ]] && [[ "${COLUMNS:-}" =~ ^[1-9][0-9]*$ ]]; then
  statusline_columns="$COLUMNS"
fi
if [[ ! "$statusline_columns" =~ ^[1-9][0-9]*$ ]] && [[ -r /dev/tty ]]; then
  # Redirect the compound command rather than only stty. Opening /dev/tty can
  # itself fail in a detached/non-interactive process, and that diagnostic
  # would otherwise corrupt Claude Code's status-line protocol.
  terminal_size=$( { stty size </dev/tty; } 2>/dev/null || true )
  terminal_columns="${terminal_size##* }"
  if [[ "$terminal_columns" =~ ^[1-9][0-9]*$ ]]; then statusline_columns="$terminal_columns"; fi
fi
if [[ ! "$statusline_columns" =~ ^[1-9][0-9]*$ ]]; then statusline_columns=0; fi

readonly brand_plain='Claudex'
readonly brand_ansi=$'\033[38;5;81mClaudex\033[0m'
readonly model_ansi=$'\033[1m'"$model_name"$'\033[0m'
mandatory_plain="$brand_plain · $model_name"
mandatory_ansi="$brand_ansi · $model_ansi"
core_plain="$mandatory_plain · $effort effort"
core_ansi="$mandatory_ansi · $effort effort"
if [[ -n "$context_percent" ]]; then
  core_plain+=" · ${context_percent}% context"
  core_ansi+=" · ${context_percent}% context"
fi
full_plain="$core_plain"
full_ansi="$core_ansi"
if [[ -n "$usage_summary" ]]; then
  full_plain+=" · $usage_summary"
  full_ansi+=" · $usage_summary"
fi

rendered_plain="$full_plain"
rendered_ansi="$full_ansi"
context_plain=""
context_ansi=""
if [[ -n "$context_percent" ]]; then
  context_plain="$mandatory_plain · ${context_percent}% context"
  context_ansi="$mandatory_ansi · ${context_percent}% context"
fi
# Bash counts UTF-8 bytes in a plain C locale but characters in UTF-8 locales.
# Choose the layout with jq's locale-independent Unicode length so Linux and
# macOS render the same status for the same declared terminal width.
layout=$(jq -nr --arg full "$full_plain" --arg core "$core_plain" \
  --arg context "$context_plain" --arg mandatory "$mandatory_plain" \
  --argjson columns "$statusline_columns" '
    if $columns == 0 or ($full | length) <= $columns then "full"
    elif ($core | length) <= $columns then "core"
    elif ($context | length) > 0 and ($context | length) <= $columns then "context"
    elif ($mandatory | length) <= $columns then "mandatory"
    else "short"
    end
  ')
case "$layout" in
  full) ;;
  core) rendered_plain="$core_plain"; rendered_ansi="$core_ansi" ;;
  context) rendered_plain="$context_plain"; rendered_ansi="$context_ansi" ;;
  mandatory) rendered_plain="$mandatory_plain"; rendered_ansi="$mandatory_ansi" ;;
  short)
  prefix_plain="$brand_plain · "
  short_layout=$(jq -nrj --arg brand "$brand_plain" --arg prefix "$prefix_plain" \
    --arg model "$model_name" --argjson columns "$statusline_columns" '
      ($columns - ($prefix | length)) as $available
      | if $available >= 2 then
          "model\u001f" + $model[0:($available - 1)] + "…"
        else
          "brand\u001f" + $brand[0:$columns]
        end
    ')
  IFS=$'\x1f' read -r short_kind shortened_text <<< "$short_layout"
  if [[ "$short_kind" == model ]]; then
    shortened_model="$shortened_text"
    rendered_plain="$prefix_plain$shortened_model"
    rendered_ansi="$brand_ansi · "$'\033[1m'"$shortened_model"$'\033[0m'
  else
    rendered_plain="$shortened_text"
    rendered_ansi=$'\033[38;5;81m'"$rendered_plain"$'\033[0m'
  fi
  ;;
esac

printf '%s\n' "$rendered_ansi"

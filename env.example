# Never commit a real token. The installer generates this localhost-only key
# automatically; users do not need to set it.
CLAUDEX_PROXY_TOKEN=replace-with-your-local-cliproxyapi-key

# Optional overrides:
# CLAUDEX_PROXY_URL=http://127.0.0.1:8318
# CLAUDEX_PROXY_CONFIG=~/.config/claudex/cliproxyapi.yaml
# CLAUDEX_PROXY_BIN=~/.config/claudex/bin/cliproxyapi
# CLAUDEX_CODEX_AUTH_DIR=~/.config/claudex/codex-accounts
# CLAUDEX_NODE_BIN=~/.config/claudex/node/bin
# CLAUDEX_PERMISSION_MODE=auto
# CLAUDEX_AUTO_MODE_MODEL=gpt-5.6-terra
# CLAUDEX_BACKGROUND_MODEL=gpt-5.6-luna
# CLAUDEX_SUBAGENT_MODEL=gpt-5.6-terra
# CLAUDEX_MAX_TOOL_USE_CONCURRENCY=3
# CLAUDEX_MAX_AGENT_CONCURRENCY=3
# CLAUDEX_MAX_RETRIES=15
# CLAUDEX_CONTEXT_WINDOW=400000
# CLAUDEX_AUTO_COMPACT_WINDOW=280000
# CLAUDEX_MOUSE_POINTER_SHAPE=pointer
# CLAUDEX_USAGE_DISPLAY=on
# CLAUDEX_USAGE_REFRESH_SECONDS=300
# CLAUDEX_USAGE_TIMEOUT_SECONDS=8
# CLAUDEX_USAGE_MAX_STALE_SECONDS=86400
# CLAUDEX_USAGE_ALERT_PERCENT=20
# CLAUDEX_USAGE_SOURCE=auto
# CLAUDEX_CLAUDE_AUTO_UPDATE=on
# CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS=86400
# CLAUDEX_AUTO_UPDATE=on
# CLAUDEX_UPDATE_INTERVAL_SECONDS=86400
# CLAUDEX_DISABLE_INTERACTIVE_LOGIN=0
# CLAUDEX_PLAN_MODE_POLICY=conservative
# CLAUDEX_SKILL_BRIDGE=on
# CLAUDEX_SKILL_PLUGINS=on
# CLAUDEX_SKILL_DOLLAR_REFERENCES=on
# CLAUDEX_CLAUDE_CONFIG_DIR=~/.claude
# CLAUDEX_SKILL_EXTRA_DIRS=/absolute/shared/skills
# CLAUDEX_CODEX_AUTH_FILE=/absolute/path/to/a/codex-oauth-file.json
# CLAUDEX_CHROME_CONFIG_DIR=/absolute/path/to/a/direct-claude-profile

node_supports_skill_bridge() {
  command -v node >/dev/null 2>&1 || return 1
  node -e 'const major = Number(process.versions.node.split(".")[0]); process.exit(Number.isInteger(major) && major >= 18 ? 0 : 1)' \
    >/dev/null 2>&1
}

if [[ "${1:-}" == skills ]]; then

proxy_url_is_loopback() {
  local normalized="${1%/}" port=""
  normalized=$(printf '%s' "$normalized" | tr '[:upper:]' '[:lower:]')
  if [[ "$normalized" =~ ^https?://(localhost|127\.0\.0\.1|\[::1\])(:([0-9]{1,5}))?$ ]]; then
    port="${BASH_REMATCH[3]:-}"
    [[ -z "$port" ]] || (( 10#$port >= 1 && 10#$port <= 65535 ))
    return
  fi
  return 1
}

proxy_url_is_secure_remote() {
  local authority="${1#https://}"
  [[ "$1" == https://* ]] || return 1
  authority="${authority%/}"
  [[ -n "$authority" ]] || return 1
  case "$authority" in
    *[/?#@[:space:]]*) return 1 ;;
  esac
}


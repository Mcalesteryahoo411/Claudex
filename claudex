  printf '%s\n' "Auto-mode provider: Codex/OpenAI through the authenticated loopback bridge"
  printf '%s\n' "Subagent model: ${CLAUDEX_SUBAGENT_MODEL} (Sol is reserved for the leader)"
  printf '%s\n' "Tool concurrency: ${CLAUDEX_MAX_TOOL_USE_CONCURRENCY}"
  printf '%s\n' "Agent concurrency: ${CLAUDEX_MAX_AGENT_CONCURRENCY}"
  printf '%s\n' "Task lifecycle: Sol-owned with final-response reconciliation"
  printf '%s\n' "API retries: ${CLAUDEX_MAX_RETRIES}"
  printf '%s\n' "Context window: ${CLAUDEX_CONTEXT_WINDOW} tokens"
  printf '%s\n' "Auto-compact window: ${CLAUDEX_AUTO_COMPACT_WINDOW} tokens (precompute enabled)"
  printf '%s\n' "Context status: session-stabilized (transient zero suppressed)"
  printf '%s\n' "Codex usage: status-line refresh every ${CLAUDEX_USAGE_REFRESH_SECONDS}s; inspect with /usage-limit or claudex --usage-limit"
  printf '%s\n' "Usage source: ${CLAUDEX_USAGE_SOURCE} (documented Codex app-server fallback enabled in auto mode)"
  printf '%s\n' "Low-quota alert: ${CLAUDEX_USAGE_ALERT_PERCENT}% remaining (0 disables)"
  printf '%s\n' 'Effort shortcuts: --max-effort and --ultracode (xhigh plus dynamic workflows)'
  printf '%s\n' 'Claude in Chrome: use --claude-chrome for the direct Anthropic profile required by the extension'
  printf '%s\n' "Claude Code updates: ${CLAUDEX_CLAUDE_AUTO_UPDATE} (checked every ${CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS}s)"
  printf '%s\n' "Plan mode policy: ${CLAUDEX_PLAN_MODE_POLICY} (implementation-first unless planning is genuinely required)"
  printf '%s\n' "Rendering: no-flicker mode with native terminal cursor"
  printf '%s\n' "Terminal UI: fullscreen (launch command hidden while Claudex is open)"
  printf '%s\n' "Header model name: $(model_name "$saved_model")"
  printf '%s\n' "Mouse pointer: ${CLAUDEX_MOUSE_POINTER_SHAPE}"
  printf '%s\n' "Isolation: Claudex config at ${CLAUDE_CONFIG_DIR}; normal Claude config is untouched"

  for model in gpt-5.6-sol gpt-5.6-terra gpt-5.6-luna; do

  local parent_identity
  parent_identity=$(process_identity "$$" 2>/dev/null || true)
  env \
    -u ANTHROPIC_AUTH_TOKEN -u ANTHROPIC_API_KEY -u CLAUDE_CODE_OAUTH_TOKEN \
    -u CLAUDEX_PROXY_TOKEN -u CLAUDEX_CODEX_AUTH_FILE \
    "$codex_session_helper" watch "$$" "$parent_identity" "$parsed_background" \
    </dev/null >/dev/null 2>&1 &
  auth_watcher_pid=$!
  if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_AUTH_WATCH_PID_FILE:-}" ]]; then
    (umask 077; printf '%s\n' "$auth_watcher_pid" > "$CLAUDEX_TEST_AUTH_WATCH_PID_FILE")
  fi
  if (( parsed_background )); then disown "$auth_watcher_pid" 2>/dev/null || true; fi
}

watch_parent_is_current() {
  local parent_pid="$1" expected_identity="$2" current_identity
  kill -0 "$parent_pid" 2>/dev/null || return 1
  [[ -n "$expected_identity" ]] || return 0
  current_identity=$(process_identity "$parent_pid" 2>/dev/null || true)
  [[ -n "$current_identity" && "$current_identity" == "$expected_identity" ]]
}


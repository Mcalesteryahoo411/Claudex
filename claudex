#!/usr/bin/env bash
set -euo pipefail

readonly claudex_config_dir="${CLAUDEX_CONFIG_DIR:-$HOME/.config/claudex}"
readonly config_file="$claudex_config_dir/env"
readonly curl_bin="${CLAUDEX_CURL_BIN:-curl}"

early_runtime_bypass=0
for early_argument in "$@"; do
  case "$early_argument" in
    --claude-chrome) early_runtime_bypass=1; break ;;
    --sol|--terra|--luna|--solplan|--manual|--auto|--accept-edits|--ultracode|--max-effort) ;;
    *) break ;;
  esac
done
case "${1:-}" in
  --help|-h|--version|-v|agents|auth|doctor|gateway|install|mcp|plugin|plugins|project|setup-token|ultrareview|update|upgrade)
    early_runtime_bypass=1
    ;;
esac

if [[ ! -r "$config_file" ]] && (( ! early_runtime_bypass )); then
  printf '%s\n' "claudex: missing $config_file; reinstall or restore the Claudex configuration." >&2
  exit 1
fi

if [[ -r "$config_file" ]]; then source "$config_file"; fi
readonly settings_file="${CLAUDEX_SETTINGS_FILE:-$claudex_config_dir/settings.json}"
readonly codex_session_helper="${CLAUDEX_CODEX_SESSION_HELPER:-$claudex_config_dir/codex-session}"
export CLAUDEX_CODEX_AUTH_DIR CLAUDEX_CODEX_SOURCE_AUTH_FILE CLAUDEX_CODEX_AUTH_FILE

# Authentication recovery must keep working even when the main settings or jq
# installation is damaged. The helper performs its own action-specific checks.
case "${1:-}" in
  --login|--logout|--auth-status)
    [[ -x "$codex_session_helper" ]] || {
      printf '%s\n' 'claudex: authentication helper is missing; reinstall Claudex.' >&2
      exit 1
    }
    case "$1" in
      --login) exec "$codex_session_helper" login ;;
      --logout) exec "$codex_session_helper" logout ;;
      --auth-status) exec "$codex_session_helper" status ;;
    esac
    ;;
esac

if (( ! early_runtime_bypass )) && [[ ! -r "$settings_file" ]]; then
  printf '%s\n' "claudex: missing $settings_file; reinstall or restore the Claudex settings." >&2
  exit 1
fi

if (( ! early_runtime_bypass )) && ! command -v jq >/dev/null 2>&1; then
  printf '%s\n' "claudex: jq is required but was not found in PATH." >&2
  exit 1
fi

: "${CLAUDEX_PROXY_TOKEN:=}"
: "${CLAUDEX_PROXY_URL:=http://127.0.0.1:8318}"
: "${CLAUDEX_MODEL:=gpt-5.6-sol}"
: "${CLAUDEX_PERMISSION_MODE:=auto}"
: "${CLAUDEX_AUTO_MODE_MODEL:=gpt-5.6-terra}"
: "${CLAUDEX_BACKGROUND_MODEL:=gpt-5.6-luna}"
: "${CLAUDEX_SUBAGENT_MODEL:=gpt-5.6-terra}"
: "${CLAUDEX_MAX_TOOL_USE_CONCURRENCY:=3}"
: "${CLAUDEX_MAX_AGENT_CONCURRENCY:=3}"
: "${CLAUDEX_MAX_RETRIES:=4}"
: "${CLAUDEX_CONTEXT_WINDOW:=400000}"
: "${CLAUDEX_AUTO_COMPACT_WINDOW:=280000}"
: "${CLAUDEX_MOUSE_POINTER_SHAPE:=pointer}"
: "${CLAUDEX_USAGE_DISPLAY:=on}"
: "${CLAUDEX_USAGE_REFRESH_SECONDS:=300}"
: "${CLAUDEX_USAGE_TIMEOUT_SECONDS:=8}"
: "${CLAUDEX_USAGE_MAX_STALE_SECONDS:=86400}"
: "${CLAUDEX_USAGE_SOURCE:=auto}"
: "${CLAUDEX_USAGE_ALERT_PERCENT:=20}"
: "${CLAUDEX_CLAUDE_AUTO_UPDATE:=on}"
: "${CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS:=86400}"
: "${CLAUDEX_PLAN_MODE_POLICY:=conservative}"

if (( ! early_runtime_bypass )) && [[ -z "$CLAUDEX_PROXY_TOKEN" ]]; then
  printf '%s\n' 'claudex: CLAUDEX_PROXY_TOKEN is not configured' >&2
  exit 1
fi

if (( ! early_runtime_bypass )); then case "$CLAUDEX_PROXY_TOKEN" in
  *$'\n'*|*$'\r'*)
    printf '%s\n' "claudex: CLAUDEX_PROXY_TOKEN contains an unsupported newline." >&2
    exit 2
    ;;
esac; fi

if (( ! early_runtime_bypass )); then case "$CLAUDEX_MODEL" in
  gpt-5.6-sol|gpt-5.6-terra|gpt-5.6-luna) ;;
  *)
    printf '%s\n' "claudex: CLAUDEX_MODEL must be a managed Codex model (gpt-5.6-sol, gpt-5.6-terra, or gpt-5.6-luna)." >&2
    exit 2
    ;;
esac; fi

if (( ! early_runtime_bypass )); then case "$CLAUDEX_PERMISSION_MODE" in
  manual|auto|acceptEdits|dontAsk|plan) ;;
  *)
    printf '%s\n' "claudex: invalid CLAUDEX_PERMISSION_MODE '$CLAUDEX_PERMISSION_MODE'." >&2
    printf '%s\n' "claudex: expected manual, auto, acceptEdits, dontAsk, or plan." >&2
    exit 2
    ;;
esac; fi

if (( ! early_runtime_bypass )); then for codex_model_setting in CLAUDEX_AUTO_MODE_MODEL CLAUDEX_BACKGROUND_MODEL CLAUDEX_SUBAGENT_MODEL; do
  codex_model_value="${!codex_model_setting}"
  case "$codex_model_value" in
    gpt-5.6-sol|gpt-5.6-terra|gpt-5.6-luna) ;;
    *)
      printf 'claudex: %s must be a managed Codex model (gpt-5.6-sol, gpt-5.6-terra, or gpt-5.6-luna).\n' "$codex_model_setting" >&2
      exit 2
      ;;
  esac
done; fi

if (( ! early_runtime_bypass )); then
if [[ ! "$CLAUDEX_MAX_TOOL_USE_CONCURRENCY" =~ ^[0-9]+$ ]] || (( CLAUDEX_MAX_TOOL_USE_CONCURRENCY < 1 )); then
  printf '%s\n' "claudex: CLAUDEX_MAX_TOOL_USE_CONCURRENCY must be a positive integer." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_MAX_AGENT_CONCURRENCY" =~ ^[0-9]+$ ]] || (( CLAUDEX_MAX_AGENT_CONCURRENCY < 1 )); then
  printf '%s\n' "claudex: CLAUDEX_MAX_AGENT_CONCURRENCY must be a positive integer." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_MAX_RETRIES" =~ ^[0-9]+$ ]] || (( CLAUDEX_MAX_RETRIES > 15 )); then
  printf '%s\n' "claudex: CLAUDEX_MAX_RETRIES must be an integer from 0 to 15." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_CONTEXT_WINDOW" =~ ^[0-9]+$ ]] || (( CLAUDEX_CONTEXT_WINDOW < 100000 || CLAUDEX_CONTEXT_WINDOW > 1000000 )); then
  printf '%s\n' "claudex: CLAUDEX_CONTEXT_WINDOW must be an integer from 100000 to 1000000." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_AUTO_COMPACT_WINDOW" =~ ^[0-9]+$ ]] || (( CLAUDEX_AUTO_COMPACT_WINDOW < 100000 || CLAUDEX_AUTO_COMPACT_WINDOW > CLAUDEX_CONTEXT_WINDOW )); then
  printf '%s\n' "claudex: CLAUDEX_AUTO_COMPACT_WINDOW must be an integer from 100000 through CLAUDEX_CONTEXT_WINDOW." >&2
  exit 2
fi

case "$CLAUDEX_MOUSE_POINTER_SHAPE" in
  pointer|default|off) ;;
  *)
    printf '%s\n' "claudex: CLAUDEX_MOUSE_POINTER_SHAPE must be pointer, default, or off." >&2
    exit 2
    ;;
esac

case "$CLAUDEX_USAGE_DISPLAY" in
  on|off) ;;
  *)
    printf '%s\n' "claudex: CLAUDEX_USAGE_DISPLAY must be on or off." >&2
    exit 2
    ;;
esac

if [[ ! "$CLAUDEX_USAGE_REFRESH_SECONDS" =~ ^[0-9]+$ ]] || (( CLAUDEX_USAGE_REFRESH_SECONDS < 60 || CLAUDEX_USAGE_REFRESH_SECONDS > 3600 )); then
  printf '%s\n' "claudex: CLAUDEX_USAGE_REFRESH_SECONDS must be an integer from 60 to 3600." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_USAGE_TIMEOUT_SECONDS" =~ ^[0-9]+$ ]] || (( CLAUDEX_USAGE_TIMEOUT_SECONDS < 1 || CLAUDEX_USAGE_TIMEOUT_SECONDS > 30 )); then
  printf '%s\n' "claudex: CLAUDEX_USAGE_TIMEOUT_SECONDS must be an integer from 1 to 30." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_USAGE_MAX_STALE_SECONDS" =~ ^[0-9]+$ ]] || (( CLAUDEX_USAGE_MAX_STALE_SECONDS < CLAUDEX_USAGE_REFRESH_SECONDS || CLAUDEX_USAGE_MAX_STALE_SECONDS > 604800 )); then
  printf '%s\n' "claudex: CLAUDEX_USAGE_MAX_STALE_SECONDS must be between the refresh interval and 604800." >&2
  exit 2
fi
case "$CLAUDEX_USAGE_SOURCE" in auto|web|app-server) ;;
  *) printf '%s\n' 'claudex: CLAUDEX_USAGE_SOURCE must be auto, web, or app-server.' >&2; exit 2 ;;
esac
if [[ ! "$CLAUDEX_USAGE_ALERT_PERCENT" =~ ^[0-9]+$ ]] || (( CLAUDEX_USAGE_ALERT_PERCENT < 0 || CLAUDEX_USAGE_ALERT_PERCENT > 100 )); then
  printf '%s\n' 'claudex: CLAUDEX_USAGE_ALERT_PERCENT must be an integer from 0 to 100.' >&2
  exit 2
fi
case "$CLAUDEX_CLAUDE_AUTO_UPDATE" in on|off) ;;
  *) printf '%s\n' 'claudex: CLAUDEX_CLAUDE_AUTO_UPDATE must be on or off.' >&2; exit 2 ;;
esac
if [[ ! "$CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS" =~ ^[0-9]+$ ]] || (( CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS < 3600 || CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS > 2592000 )); then
  printf '%s\n' 'claudex: CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS must be from 3600 to 2592000.' >&2
  exit 2
fi
case "$CLAUDEX_PLAN_MODE_POLICY" in conservative|normal) ;;
  *) printf '%s\n' 'claudex: CLAUDEX_PLAN_MODE_POLICY must be conservative or normal.' >&2; exit 2 ;;
esac
fi

export CLAUDEX_USAGE_DISPLAY CLAUDEX_USAGE_REFRESH_SECONDS CLAUDEX_USAGE_TIMEOUT_SECONDS CLAUDEX_USAGE_MAX_STALE_SECONDS
export CLAUDEX_USAGE_SOURCE CLAUDEX_USAGE_ALERT_PERCENT

# Keep Claudex model choices, sessions, and preferences isolated from normal Claude Code.
export CLAUDE_CONFIG_DIR="$claudex_config_dir"

acquire_state_lock() {
  local lock_dir="$1" attempt mtime=0 now
  mkdir -p "$(dirname "$lock_dir")"
  for attempt in {1..100}; do
    if mkdir "$lock_dir" 2>/dev/null; then return 0; fi
    if stat -f '%m' "$lock_dir" >/dev/null 2>&1; then
      mtime=$(stat -f '%m' "$lock_dir")
    else
      mtime=$(stat -c '%Y' "$lock_dir" 2>/dev/null || printf 0)
    fi
    now=$(date +%s)
    if [[ "$mtime" =~ ^[0-9]+$ && "$now" =~ ^[0-9]+$ ]] && (( now - mtime >= 60 )); then
      rmdir "$lock_dir" 2>/dev/null || true
    fi
    sleep 0.02
  done
  return 1
}

release_state_lock() {
  rmdir "$1" 2>/dev/null || true
}

# Claude Code's welcome banner does not use ANTHROPIC_CUSTOM_MODEL_OPTION_NAME.
# Seed its isolated model-option cache so custom GPT IDs have friendly names in
# both the banner and model picker. Preserve unrelated cached options.
ensure_model_display_names() {
  local state_file="$CLAUDE_CONFIG_DIR/.claude.json"
  local tmp_file lock_dir="$CLAUDE_CONFIG_DIR/run/model-display.lock"
  local managed_options='[
    {"value":"opusplan","label":"GPT-5.6 Solplan","description":"GPT-5.6 Sol in plan mode, GPT-5.6 Terra for implementation"},
    {"value":"gpt-5.6-sol","label":"GPT-5.6 Sol","description":"Frontier capability for planning and the hardest engineering work"},
    {"value":"gpt-5.6-terra","label":"GPT-5.6 Terra","description":"Balanced intelligence, speed, and cost for everyday coding"},
    {"value":"gpt-5.6-luna","label":"GPT-5.6 Luna","description":"Fast, efficient model for search, triage, and mechanical tasks"}
  ]'

  acquire_state_lock "$lock_dir" || return 0
  if [[ -s "$state_file" ]] && jq -e --argjson managed "$managed_options" '
    . as $root
    | all($managed[] as $expected;
        [$root.additionalModelOptionsCache[]? | select(.value == $expected.value)] as $matches
        | ($matches | length) == 1
        and $matches[0].label == $expected.label
        and $matches[0].description == $expected.description)
  ' "$state_file" >/dev/null 2>&1; then
    release_state_lock "$lock_dir"
    return 0
  fi

  mkdir -p "$CLAUDE_CONFIG_DIR"
  tmp_file=$(mktemp "$CLAUDE_CONFIG_DIR/.claude.json.tmp.XXXXXX")
  if [[ -s "$state_file" ]] && jq -e 'type == "object"' "$state_file" >/dev/null 2>&1; then
    if ! jq --argjson managed "$managed_options" '
      ($managed | map(.value)) as $managed_ids
      | .additionalModelOptionsCache = (
          ((.additionalModelOptionsCache // [])
            | map(.value as $value | select(($managed_ids | index($value)) == null)))
          + $managed
        )
    ' "$state_file" > "$tmp_file"; then
      rm -f "$tmp_file"
      release_state_lock "$lock_dir"
      return 0
    fi
  else
    if ! jq -n --argjson managed "$managed_options" \
      '{additionalModelOptionsCache: $managed}' > "$tmp_file"; then
      rm -f "$tmp_file"
      release_state_lock "$lock_dir"
      return 0
    fi
  fi
  mv -f "$tmp_file" "$state_file"
  release_state_lock "$lock_dir"
}

if (( ! early_runtime_bypass )) || { [[ -r "$settings_file" ]] && command -v jq >/dev/null 2>&1; }; then
  ensure_model_display_names
fi

fetch_models() {
  local timeout_seconds="${1:-1}" response_file status_file request_pid timer_pid request_status=0
  local http_status status_output
  local run_dir="$claudex_config_dir/run"
  mkdir -p "$run_dir"
  response_file=$(mktemp "$run_dir/.proxy-health.XXXXXX")
  status_file=$(mktemp "$run_dir/.proxy-health-status.XXXXXX")
  chmod 600 "$response_file" 2>/dev/null || true
  chmod 600 "$status_file" 2>/dev/null || true

  "$curl_bin" --silent --show-error \
    --connect-timeout 0.5 --max-time "$timeout_seconds" \
    --header @<(printf 'Authorization: Bearer %s\n' "$CLAUDEX_PROXY_TOKEN") \
    --output "$response_file" --write-out '%{http_code}' \
    "${CLAUDEX_PROXY_URL}/v1/models" > "$status_file" &
  request_pid=$!
  (
    sleep "$timeout_seconds"
    kill -TERM "$request_pid" 2>/dev/null || exit 0
    sleep 0.1
    kill -KILL "$request_pid" 2>/dev/null || true
  ) &
  timer_pid=$!
  wait "$request_pid" || request_status=$?
  kill "$timer_pid" 2>/dev/null || true
  wait "$timer_pid" 2>/dev/null || true

  if (( request_status != 0 )); then
    rm -f "$response_file" "$status_file"
    return "$request_status"
  fi
  status_output=$(<"$status_file")
  # Test doubles and curl-compatible wrappers may ignore --output/--write-out
  # and emit the body on stdout. Accept that shape without weakening real HTTP
  # status validation.
  if [[ ! -s "$response_file" && "$status_output" == \{* ]]; then
    printf '%s\n' "$status_output" > "$response_file"
    http_status=200
  else
    http_status="${status_output##*$'\n'}"
  fi
  rm -f "$status_file"
  case "$http_status" in
    2??) cat "$response_file"; rm -f "$response_file"; return 0 ;;
    401|403) rm -f "$response_file"; return 41 ;;
    *) rm -f "$response_file"; return 42 ;;
  esac
}

models_are_valid() {
  jq -e '[.data[]?.id | select(type == "string" and length > 0)] | length > 0' >/dev/null 2>&1
}

proxy_ready() {
  local models fetch_status=0
  models=$(fetch_models 1 2>/dev/null) || fetch_status=$?
  (( fetch_status == 0 )) || return "$fetch_status"
  printf '%s\n' "$models" | models_are_valid || return 43
}

selected_model_is_available() {
  local selected_model="$1" models required_models
  case "$selected_model" in
    opusplan) required_models='["gpt-5.6-sol", "gpt-5.6-terra"]' ;;
    *) required_models=$(printf '["%s"]' "$selected_model") ;;
  esac
  models=$(fetch_models 2) || return 1
  printf '%s\n' "$models" | jq -e --argjson required "$required_models" '
    [.data[]?.id] as $ids
    | [$required[] as $model | select(($ids | index($model)) == null)]
    | length == 0
  ' >/dev/null 2>&1
}

proxy_reachable() {
  if [[ -n "${CLAUDEX_TEST_PROXY_REACHABLE_FILE:-}" ]]; then
    [[ -e "$CLAUDEX_TEST_PROXY_REACHABLE_FILE" ]]
    return
  fi
  proxy_ready
}

proxy_executable() {
  if [[ -n "${CLAUDEX_PROXY_BIN:-}" && -x "$CLAUDEX_PROXY_BIN" ]]; then
    printf '%s\n' "$CLAUDEX_PROXY_BIN"
  elif [[ -x "$CLAUDE_CONFIG_DIR/bin/cliproxyapi" ]]; then
    printf '%s\n' "$CLAUDE_CONFIG_DIR/bin/cliproxyapi"
  elif command -v cliproxyapi >/dev/null 2>&1; then
    command -v cliproxyapi
  elif command -v cli-proxy-api >/dev/null 2>&1; then
    command -v cli-proxy-api
  else
    return 1
  fi
}

start_auth_watcher() {
  [[ "${CLAUDEX_SKIP_AUTH_WATCHER:-0}" != 1 ]] || return 0
  "$codex_session_helper" watch "$$" >/dev/null 2>&1 &
  auth_watcher_pid=$!
}

start_proxy_watcher() {
  [[ "${CLAUDEX_SKIP_PROXY_WATCHER:-0}" != 1 ]] || return 0
  local parent_pid=$$
  (
    while kill -0 "$parent_pid" 2>/dev/null; do
      sleep 1
      kill -0 "$parent_pid" 2>/dev/null || break
      if ! proxy_reachable; then ensure_proxy >/dev/null 2>&1 || true; fi
    done
  ) &
  proxy_watcher_pid=$!
}

current_shell_pid() {
  local destination="$1"
  # Bash 3.2 does not expose BASHPID. A short-lived child reports the real PID
  # of whichever launcher or watcher process directly spawned it. Write to a
  # file so command substitution cannot insert another short-lived subshell.
  sh -c 'printf "%s\n" "$PPID" > "$1"' claudex-pid "$destination"
}

process_identity() {
  local pid="$1"
  ps -p "$pid" -o lstart= 2>/dev/null | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]][[:space:]]*/ /g'
}

lock_age_seconds() {
  local path="$1" mtime=0 now
  if stat -f '%m' "$path" >/dev/null 2>&1; then
    mtime=$(stat -f '%m' "$path")
  else
    mtime=$(stat -c '%Y' "$path" 2>/dev/null || printf 0)
  fi
  now=$(date +%s)
  if [[ "$mtime" =~ ^[0-9]+$ && "$now" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$(( now - mtime ))"
  else
    printf '%s\n' 0
  fi
}

record_proxy_recovery() {
  local message="$1" run_dir="$CLAUDE_CONFIG_DIR/run" log_file temporary size
  mkdir -p "$run_dir"
  log_file="$run_dir/proxy-recovery.log"
  (umask 077; printf '%s %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$message" >> "$log_file")
  chmod 600 "$log_file" 2>/dev/null || true
  size=$(wc -c < "$log_file" 2>/dev/null | tr -d ' ' || printf 0)
  if [[ "$size" =~ ^[0-9]+$ ]] && (( size > 65536 )); then
    temporary=$(mktemp "$run_dir/.proxy-recovery.XXXXXX")
    tail -c 32768 "$log_file" > "$temporary" 2>/dev/null || true
    chmod 600 "$temporary" 2>/dev/null || true
    mv -f "$temporary" "$log_file"
  fi
}

read_lock_field() {
  local owner_file="$1" field="$2"
  awk -F= -v field="$field" '$1 == field { sub(/^[^=]*=/, ""); print; exit }' "$owner_file" 2>/dev/null
}

lock_owner_is_current() {
  local owner_file="$1" pid identity current
  pid=$(read_lock_field "$owner_file" pid)
  identity=$(read_lock_field "$owner_file" identity)
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  [[ -n "$identity" ]] || return 0
  current=$(process_identity "$pid")
  [[ -n "$current" && "$current" == "$identity" ]]
}

release_proxy_lock() {
  local lock_dir="$1" nonce="$2" owner_file="$lock_dir/owner"
  [[ "$(read_lock_field "$owner_file" nonce)" == "$nonce" ]] || return 0
  rm -f "$owner_file" 2>/dev/null || true
  rmdir "$lock_dir" 2>/dev/null || true
}

reclaim_proxy_lock() {
  local lock_dir="$1" observed_nonce="$2" owner_file="$lock_dir/owner"
  local quarantine="$lock_dir.stale.$observed_nonce"
  [[ -n "$observed_nonce" ]] || return 1
  [[ "$(read_lock_field "$owner_file" nonce)" == "$observed_nonce" ]] || return 1
  [[ ! -e "$quarantine" ]] || return 1
  mv "$lock_dir" "$quarantine" 2>/dev/null || return 1
  if [[ "$(read_lock_field "$quarantine/owner" nonce)" != "$observed_nonce" ]]; then
    record_proxy_recovery "startup lock quarantine changed ownership unexpectedly"
    return 1
  fi
  rm -f "$quarantine/owner" 2>/dev/null || true
  rmdir "$quarantine" 2>/dev/null || true
  record_proxy_recovery "reclaimed stale startup lock nonce=$observed_nonce"
}

write_managed_proxy_pid() {
  local pid="$1" run_dir="$CLAUDE_CONFIG_DIR/run" pid_file temporary identity
  pid_file="$run_dir/managed-proxy"
  identity=$(process_identity "$pid")
  temporary=$(mktemp "$run_dir/.managed-proxy.XXXXXX")
  {
    printf 'pid=%s\n' "$pid"
    printf 'identity=%s\n' "$identity"
  } > "$temporary"
  chmod 600 "$temporary" 2>/dev/null || true
  mv -f "$temporary" "$pid_file"
}

stop_unhealthy_managed_proxy() {
  local pid_file="$CLAUDE_CONFIG_DIR/run/managed-proxy" pid identity current attempt
  [[ -r "$pid_file" ]] || return 0
  pid=$(read_lock_field "$pid_file" pid)
  identity=$(read_lock_field "$pid_file" identity)
  if [[ ! "$pid" =~ ^[0-9]+$ ]] || ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$pid_file"
    return 0
  fi
  current=$(process_identity "$pid")
  [[ -n "$identity" && "$current" == "$identity" ]] || {
    record_proxy_recovery "ignored stale managed proxy pid metadata pid=$pid"
    rm -f "$pid_file"
    return 0
  }
  kill -TERM "$pid" 2>/dev/null || true
  for attempt in {1..20}; do
    kill -0 "$pid" 2>/dev/null || break
    sleep 0.1
  done
  if kill -0 "$pid" 2>/dev/null && [[ "$(process_identity "$pid")" == "$identity" ]]; then
    kill -KILL "$pid" 2>/dev/null || true
  fi
  rm -f "$pid_file"
  record_proxy_recovery "stopped unresponsive managed proxy pid=$pid"
}

ensure_proxy() {
  local health_status=0
  if [[ ! -x "$codex_session_helper" ]]; then
    record_proxy_recovery "authentication helper is missing"
    printf '%s\n' "claudex: authentication helper is missing: $codex_session_helper" >&2
    printf '%s\n' 'claudex: reinstall Claudex to repair the installation.' >&2
    return 1
  fi
  local sync_status=0
  "$codex_session_helper" sync || sync_status=$?
  if (( sync_status != 0 )); then
    record_proxy_recovery "authentication synchronization failed status=$sync_status"
    return "$sync_status"
  fi

  if proxy_ready; then
    return 0
  else
    health_status=$?
    if (( health_status == 41 )); then
      record_proxy_recovery "proxy rejected the configured authentication token"
      printf '%s\n' 'claudex: the local proxy rejected its configured authentication token; rerun the installer to repair matching credentials.' >&2
      return 1
    fi
  fi

  # Concurrent Claudex tabs can notice a stopped bridge at the same time.
  # Serialize startup so only one process can bind the loopback port.
  local run_dir="$CLAUDE_CONFIG_DIR/run" lock_dir owner_file attempt owner_tmp orphan_nonce orphan_tmp owner_pid_file
  local lock_acquired=0 owner_pid owner_identity owner_nonce observed_nonce lock_age
  local lock_deadline startup_deadline proxy_pid
  lock_dir="$run_dir/proxy-start.lock"
  owner_file="$lock_dir/owner"
  mkdir -p "$run_dir"
  lock_deadline=$(( SECONDS + 30 ))
  while (( SECONDS < lock_deadline )); do
    if mkdir "$lock_dir" 2>/dev/null; then
      owner_pid_file=$(mktemp "$run_dir/.proxy-owner-pid.XXXXXX")
      current_shell_pid "$owner_pid_file"
      read -r owner_pid < "$owner_pid_file"
      rm -f "$owner_pid_file"
      owner_identity=$(process_identity "$owner_pid")
      owner_nonce="${owner_pid}.$(date +%s).${RANDOM}.${RANDOM}"
      owner_tmp=$(mktemp "$run_dir/.proxy-start-owner.XXXXXX")
      {
        printf 'pid=%s\n' "$owner_pid"
        printf 'identity=%s\n' "$owner_identity"
        printf 'nonce=%s\n' "$owner_nonce"
      } > "$owner_tmp"
      chmod 600 "$owner_tmp" 2>/dev/null || true
      if ! mv -f "$owner_tmp" "$owner_file"; then
        rm -f "$owner_tmp" 2>/dev/null || true
        rmdir "$lock_dir" 2>/dev/null || true
        return 1
      fi
      lock_acquired=1
      break
    fi
    if proxy_ready; then return 0
    elif (( $? == 41 )); then
      record_proxy_recovery "proxy authentication failed while waiting for startup lock"
      return 1
    fi
    lock_age=$(lock_age_seconds "$lock_dir")
    observed_nonce=$(read_lock_field "$owner_file" nonce)
    if { [[ -n "$observed_nonce" ]] && ! lock_owner_is_current "$owner_file" && (( lock_age >= 2 )); } \
        || { [[ -n "$observed_nonce" ]] && (( lock_age >= 20 )); }; then
      reclaim_proxy_lock "$lock_dir" "$observed_nonce" || true
    elif [[ -z "$observed_nonce" ]] && (( lock_age >= 2 )); then
      # A crash between mkdir and the atomic owner-file rename leaves no nonce.
      orphan_nonce="orphan.$(date +%s).${RANDOM}"
      orphan_tmp=$(mktemp "$run_dir/.proxy-start-owner.XXXXXX")
      printf 'nonce=%s\n' "$orphan_nonce" > "$orphan_tmp"
      chmod 600 "$orphan_tmp" 2>/dev/null || true
      if ln "$orphan_tmp" "$owner_file" 2>/dev/null; then :; fi
      rm -f "$orphan_tmp"
      reclaim_proxy_lock "$lock_dir" "$orphan_nonce" || true
    fi
    sleep 0.1
  done
  if (( ! lock_acquired )); then
    record_proxy_recovery "timed out after 30s waiting for startup lock"
    printf '%s\n' "claudex: timed out waiting for another session to start the local proxy." >&2
    return 1
  fi
  trap 'release_proxy_lock "$lock_dir" "$owner_nonce"' EXIT

  if proxy_ready; then
    release_proxy_lock "$lock_dir" "$owner_nonce"
    trap - EXIT
    return 0
  elif (( $? == 41 )); then
    record_proxy_recovery "proxy authentication failed after startup lock acquisition"
    release_proxy_lock "$lock_dir" "$owner_nonce"
    trap - EXIT
    return 1
  fi

  printf '%s\n' "claudex: starting the local CLIProxyAPI service..." >&2
  record_proxy_recovery "starting authenticated proxy recovery"
  stop_unhealthy_managed_proxy
  proxy_config="${CLAUDEX_PROXY_CONFIG:-$CLAUDE_CONFIG_DIR/cliproxyapi.yaml}"
  homebrew_proxy_config=""
  if command -v brew >/dev/null 2>&1; then
    homebrew_proxy_config="$(brew --prefix)/etc/cliproxyapi.conf"
  fi
  if command -v brew >/dev/null 2>&1 \
      && brew list --formula cliproxyapi >/dev/null 2>&1 \
      && { [[ ! -r "$proxy_config" ]] || [[ "$proxy_config" == "$homebrew_proxy_config" ]]; }; then
    if ! brew services start cliproxyapi >/dev/null; then
      record_proxy_recovery "Homebrew proxy service failed to start"
      release_proxy_lock "$lock_dir" "$owner_nonce"
      trap - EXIT
      return 1
    fi
  else
    proxy_bin=$(proxy_executable) || {
      record_proxy_recovery "proxy executable is missing"
      printf '%s\n' "claudex: CLIProxyAPI is not reachable and no proxy executable was found." >&2
      release_proxy_lock "$lock_dir" "$owner_nonce"
      trap - EXIT
      return 1
    }
    log_dir="$CLAUDE_CONFIG_DIR/logs"
    mkdir -p "$log_dir"
    if [[ -r "$proxy_config" ]]; then
      nohup "$proxy_bin" -config "$proxy_config" >"$log_dir/cliproxyapi.log" 2>&1 </dev/null &
    else
      nohup "$proxy_bin" >"$log_dir/cliproxyapi.log" 2>&1 </dev/null &
    fi
    proxy_pid=$!
    write_managed_proxy_pid "$proxy_pid"
  fi

  startup_deadline=$(( SECONDS + 10 ))
  while (( SECONDS < startup_deadline )); do
    if proxy_ready; then
      release_proxy_lock "$lock_dir" "$owner_nonce"
      trap - EXIT
      return 0
    elif (( $? == 41 )); then
      record_proxy_recovery "new proxy rejected the configured authentication token"
      release_proxy_lock "$lock_dir" "$owner_nonce"
      trap - EXIT
      return 1
    fi
    sleep 0.1
  done
  record_proxy_recovery "proxy did not become semantically healthy within 10s"
  release_proxy_lock "$lock_dir" "$owner_nonce"
  trap - EXIT

  printf '%s\n' "claudex: local proxy did not become healthy. Run: claudex --doctor" >&2
  return 1
}

maybe_update_claude() {
  [[ "$CLAUDEX_CLAUDE_AUTO_UPDATE" == on ]] || return 0
  [[ "${CLAUDEX_SKIP_AUTO_UPDATE:-0}" != 1 ]] || return 0
  command -v claude >/dev/null 2>&1 || return 0

  # Direct Chrome intentionally unsets CLAUDE_CONFIG_DIR. Update bookkeeping
  # always belongs to Claudex's stable private config root.
  local update_dir="$claudex_config_dir/update" stamp="$claudex_config_dir/update/last-success" now last=0
  now=$(date +%s)
  if [[ -r "$stamp" ]]; then
    read -r last < "$stamp" || last=0
  fi
  [[ "$last" =~ ^[0-9]+$ ]] || last=0
  (( now - last >= CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS )) || return 0
  mkdir -p "$update_dir"
  local lock_dir="$update_dir/lock" lock_mtime=0
  if [[ -d "$lock_dir" ]]; then
    if stat -f '%m' "$lock_dir" >/dev/null 2>&1; then
      lock_mtime=$(stat -f '%m' "$lock_dir")
    else
      lock_mtime=$(stat -c '%Y' "$lock_dir" 2>/dev/null || printf 0)
    fi
    if [[ "$lock_mtime" =~ ^[0-9]+$ ]] && (( now - lock_mtime >= 3600 )); then
      rmdir "$lock_dir" 2>/dev/null || true
    fi
  fi
  if mkdir "$lock_dir" 2>/dev/null; then
    (
      if claude update >"$update_dir/claude-update.log" 2>&1; then
        local completed temporary
        completed=$(date +%s)
        temporary="$update_dir/.last-success.$$"
        printf '%s\n' "$completed" > "$temporary"
        mv -f "$temporary" "$stamp"
      fi
      rmdir "$lock_dir" 2>/dev/null || true
    ) &
  fi
}

claude_supports() {
  local option="$1"
  [[ "${claude_help_cache:-}" == *"$option"* ]]
}

load_claude_capabilities() {
  command -v claude >/dev/null 2>&1 || {
    printf '%s\n' 'claudex: Claude Code was not found. Install Claude Code and retry.' >&2
    return 1
  }
  claude_help_cache=$(claude --help 2>/dev/null || true)
  [[ -n "$claude_help_cache" ]] || {
    printf '%s\n' 'claudex: Claude Code did not return its capability list.' >&2
    return 1
  }
  if ! claude_supports '--model'; then
    printf '%s\n' 'claudex: this Claude Code build does not support custom models; run `claude update`.' >&2
    return 1
  fi
}

ensure_auto_mode_rules() {
  # Claude Code replaces an autoMode array when settings provide that key.
  # Recompose from the current binary's defaults so Claudex's scoped additions
  # never discard new or existing upstream safety rules after an update.
  [[ "$settings_file" == "$claudex_config_dir/settings.json" ]] || return 0
  local defaults_json previous_defaults='{}' tmp_file snapshot_file snapshot_tmp defaults_are_fresh=0
  local lock_dir="$claudex_config_dir/run/auto-mode.lock"
  acquire_state_lock "$lock_dir" || return 0
  snapshot_file="$claudex_config_dir/auto-mode-defaults.json"
  if [[ -s "$snapshot_file" ]] && jq -e '
    (.allow | type == "array") and
    (.environment | type == "array") and
    (.soft_deny | type == "array") and
    (.hard_deny | type == "array")
  ' "$snapshot_file" >/dev/null 2>&1; then
    previous_defaults=$(<"$snapshot_file")
  fi
  if defaults_json=$(claude auto-mode defaults 2>/dev/null) && printf '%s\n' "$defaults_json" | jq -e '
      (.allow | type == "array") and
      (.environment | type == "array") and
      (.soft_deny | type == "array") and
      (.hard_deny | type == "array")
    ' >/dev/null 2>&1; then
    defaults_are_fresh=1
  elif [[ "$previous_defaults" != '{}' ]]; then
    defaults_json="$previous_defaults"
  else
    release_state_lock "$lock_dir"
    return 0
  fi

  tmp_file=$(mktemp "$claudex_config_dir/settings.json.tmp.XXXXXX")
  if jq --argjson defaults "$defaults_json" \
      --argjson previous "$previous_defaults" \
      --arg approval 'Explicit Action Approval: A user message that explicitly approves a specific action and target, including reissuing it after a denial or unambiguously referring to the immediately preceding blocked action with language such as approve that, go ahead, or proceed, satisfies named-and-specific consent for matching SOFT BLOCK rules. Do not force the user to restate the command, ask for duplicate confirmation, or treat the prior denial as permanent. This does not override HARD BLOCK rules or authorize a broader action.' \
      --arg requested_config 'Requested Agent Configuration: Editing agent configuration is routine when the user explicitly asks for that specific configuration or permission change. Treat that edit as user-requested rather than Self-Modification; unrelated permission widening remains blocked.' \
      --arg task_boundary 'User-designated task boundary: A repository, cloud project, host, bucket, service, or destination that the user explicitly identifies in their own message as owned or controlled infrastructure and as the intended target is trusted for the specifically requested operation and data flow only. Merely naming a target does not establish trust; do not infer trust for agent-selected destinations, unrelated resources, or broader scopes.' \
      --arg approved_transfer 'Explicitly approved development transfer: When the user explicitly approves an exact source transfer between a named repository and a named build, deployment, or cloud host, treat that named source and destination as inside the task trust boundary for that transfer. Approval may unambiguously refer to the immediately preceding blocked command without repeating it. This never covers a public destination, credentials or secrets, unrelated files, a broader source tree, or a different host.' '
        def stable_unique:
          reduce .[] as $item ([]; if index($item) == null then . + [$item] else . end);
        .autoMode = (.autoMode // {})
        | ($previous.allow // []) as $previous_allow
        | ($previous.environment // []) as $previous_environment
        | ((.autoMode.allow // []) | map(. as $rule | select(
            ((startswith("Explicit Action Approval:") or startswith("Requested Agent Configuration:")) | not)
            and (($previous_allow | index($rule)) == null)
          ))) as $custom_allow
        | ((.autoMode.environment // []) | map(. as $rule | select(
            ((startswith("User-designated task boundary:") or startswith("Explicitly approved development transfer:")) | not)
            and (($previous_environment | index($rule)) == null)
          ))) as $custom_environment
        | .autoMode.allow = (($defaults.allow + $custom_allow + [$approval, $requested_config]) | stable_unique)
        | .autoMode.environment = (($defaults.environment + $custom_environment + [$task_boundary, $approved_transfer]) | stable_unique)
      ' "$settings_file" > "$tmp_file"; then
    if cmp -s "$tmp_file" "$settings_file"; then
      rm -f "$tmp_file"
    else
      chmod 600 "$tmp_file" 2>/dev/null || true
      mv -f "$tmp_file" "$settings_file"
    fi
  else
    rm -f "$tmp_file"
    release_state_lock "$lock_dir"
    return 0
  fi

  if (( defaults_are_fresh )); then
    snapshot_tmp=$(mktemp "$claudex_config_dir/.auto-mode-defaults.XXXXXX")
    printf '%s\n' "$defaults_json" | jq '.' > "$snapshot_tmp"
    chmod 600 "$snapshot_tmp" 2>/dev/null || true
    mv -f "$snapshot_tmp" "$snapshot_file"
  fi
  release_state_lock "$lock_dir"
}


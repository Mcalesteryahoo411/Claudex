start_model="$CLAUDEX_MODEL"
start_model_explicit=0
effort_mode=""
permission_mode="$CLAUDEX_PERMISSION_MODE"
direct_chrome=0
forwarded_args=()
while (( $# > 0 )); do
  case "$1" in
    --sol) start_model="gpt-5.6-sol"; start_model_explicit=1 ;;
    --terra) start_model="gpt-5.6-terra"; start_model_explicit=1 ;;
    --luna) start_model="gpt-5.6-luna"; start_model_explicit=1 ;;
    --solplan) start_model="opusplan"; start_model_explicit=1 ;;
    --manual) permission_mode="manual" ;;
    --auto) permission_mode="auto" ;;
    --accept-edits) permission_mode="acceptEdits" ;;
    --ultracode)
      [[ -z "$effort_mode" || "$effort_mode" == ultracode ]] || {
        printf '%s\n' 'claudex: --ultracode and --max-effort cannot be combined.' >&2
        exit 2
      }
      effort_mode=ultracode
      ;;
    --max-effort)
      [[ -z "$effort_mode" || "$effort_mode" == max ]] || {
        printf '%s\n' 'claudex: --ultracode and --max-effort cannot be combined.' >&2
        exit 2
      }
      effort_mode=max
      ;;
    --claude-chrome) direct_chrome=1 ;;
    --)
      forwarded_args+=(--)
      shift
      forwarded_args+=("$@")
      break
      ;;
    *)
      # Claudex-only options form a leading prefix. Once Claude's own
      # arguments begin, preserve every remaining token byte-for-byte so a
      # prompt or option value such as "--terra" is never consumed by us.
      forwarded_args+=("$@")
      break
      ;;
  esac
  shift
done
use_proxy=1
inject_session_customizations=1
inject_permission=1

case "${forwarded_args[0]:-}" in
  --help|-h|--version|-v|agents|auth|auto-mode|doctor|gateway|install|mcp|plugin|plugins|project|setup-token|ultrareview|update|upgrade)
    use_proxy=0
    inject_session_customizations=0
    inject_permission=0
    ;;
esac

for argument in ${forwarded_args[@]+"${forwarded_args[@]}"}; do
  case "$argument" in
    --safe-mode|--bare)
      inject_session_customizations=0
      inject_permission=0
      ;;
    --agents) inject_session_customizations=0 ;;
    --permission-mode|--dangerously-skip-permissions|--allow-dangerously-skip-permissions)
      inject_permission=0
      ;;
    --effort|--effort=*|--settings|--settings=*)
      if [[ -n "$effort_mode" ]]; then
        printf '%s\n' "claudex: $argument conflicts with the selected Claudex effort shortcut." >&2
        exit 2
      fi
      ;;
  esac
done

if (( direct_chrome )); then
  (( ! start_model_explicit )) || {
    printf '%s\n' 'claudex: --sol, --terra, --luna, and --solplan cannot be combined with --claude-chrome because Chrome requires a first-party Anthropic model.' >&2
    exit 2
  }
  use_proxy=0
  inject_session_customizations=0
  inject_permission=0

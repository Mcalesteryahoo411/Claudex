  node_supports_skill_bridge || { printf '%s\n' 'claudex: Node.js 18 or newer is required for skill compatibility.' >&2; exit 1; }
  [[ -r "$skill_bridge_helper" ]] || { printf '%s\n' 'claudex: skill bridge helper is missing; reinstall Claudex.' >&2; exit 1; }
  shift
  [[ $# -eq 0 ]] || { printf '%s\n' 'Usage: claudex skills' >&2; exit 2; }
  exec node "$skill_bridge_helper" list --project "$PWD"

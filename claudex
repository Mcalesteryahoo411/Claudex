    # Refresh once on startup so a repaired login/account tier is reflected
    # immediately instead of falling back indefinitely.
    if [[ -x "$usage_helper" ]]; then
      "$usage_helper" --refresh-cache >/dev/null 2>&1 || true
      plan_label=$(chatgpt_plan_label_from_cache 2>/dev/null || true)

  export ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"
  export ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"

# Claude Code otherwise chooses Sonnet 5 for an external-provider auto-mode classifier,
# which Claudex maps to Terra. Pinning the classifier prevents misleading Terra outages.
  export CLAUDE_CODE_AUTO_MODE_MODEL="$CLAUDEX_AUTO_MODE_MODEL"
  export CLAUDE_CODE_BG_CLASSIFIER_MODEL="$CLAUDEX_BACKGROUND_MODEL"
  export CLAUDE_CODE_SUBAGENT_MODEL="$CLAUDEX_SUBAGENT_MODEL"
  export CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1
  export CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY="$CLAUDEX_MAX_TOOL_USE_CONCURRENCY"
  export CLAUDE_CODE_MAX_RETRIES="$CLAUDEX_MAX_RETRIES"

# Claude Code assumes unknown custom models have a 200k context window. Claudex's
# GPT-5.6 backend supports a larger window, so make the meter accurate and force
# client-side summarization before the session grows without bound.
  export CLAUDE_CODE_MAX_CONTEXT_TOKENS="$CLAUDEX_CONTEXT_WINDOW"
  export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$CLAUDEX_AUTO_COMPACT_WINDOW"
else
  unset ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN
fi

export CLAUDEX_USAGE_DISPLAY CLAUDEX_USAGE_REFRESH_SECONDS CLAUDEX_USAGE_TIMEOUT_SECONDS CLAUDEX_USAGE_MAX_STALE_SECONDS
export CLAUDEX_USAGE_SOURCE CLAUDEX_USAGE_ALERT_PERCENT
export CLAUDE_CODE_NO_FLICKER=1
export CLAUDE_CODE_ACCESSIBILITY=1

# One proxy credential backs all three aliases. Custom agents must not recursively
# spawn more agents, or a small parallel batch becomes a retry/429 storm.
readonly no_nested_agents="Do not create a team, spawn or delegate to additional agents, or send intermediate progress messages to the parent. Do not create, claim, or update entries in the shared task list; the Sol leader owns task lifecycle. Complete the assigned task yourself and return one final result through the normal agent result channel. If the provider reports a 429 or model cooldown, do not launch a replacement agent or start a retry loop."
readonly claudex_agents="{\"Terra\":{\"description\":\"Terra for delegated architecture, debugging, implementation, testing, security review, and other substantial engineering work.\",\"prompt\":\"You are GPT-5.6 Terra. Investigate thoroughly, make robust focused progress, verify the result, and return concise evidence-backed findings. ${no_nested_agents}\",\"model\":\"gpt-5.6-terra\",\"effort\":\"high\"},\"Luna\":{\"description\":\"Luna for delegated search, triage, inventory, and bounded mechanical tasks.\",\"prompt\":\"You are GPT-5.6 Luna. Complete the scoped task efficiently and report only relevant verified findings. ${no_nested_agents}\",\"model\":\"gpt-5.6-luna\",\"effort\":\"medium\"}}"
readonly claudex_capacity_guard="Claudex capacity rule: keep at most ${CLAUDEX_MAX_AGENT_CONCURRENCY} Agent tasks active at once. Launch no more than ${CLAUDEX_MAX_AGENT_CONCURRENCY} agents in a wave, wait for one to finish before starting another, and never create an agent team. Sol capacity is reserved for the leader; use the named Terra or Luna agents for delegated work. For every Agent call, make its description '- <concise task>' so the activity list renders labels such as 'Terra - Audit JSON parser bugs'. If a model reports a 429 or cooldown, do not launch replacement agents or create a retry storm; continue useful local work and retry at most once after active agents settle."
readonly claudex_task_guard="Claudex task lifecycle rule: the Sol leader is the sole owner of the shared task list. Keep it compact and create only tasks that represent real remaining deliverables, not duplicate discovery lanes or speculative work. Mark a task in_progress only while the leader or a currently active agent is working on it; queued or blocked work stays pending. After every agent result, immediately reconcile its parent task and mark it completed once its outcome is integrated and verified. Before every final answer, call TaskList and reconcile every entry: completed work must be completed, inactive work must not remain in_progress, and genuinely unfinished pending work must be explicitly reported instead of being hidden behind a completion claim. Never leave stale in_progress tasks after their work is done."
readonly claudex_codex_guard="Claudex Codex-model rule: operate as a Codex coding agent inside Claude Code's interface. Treat the available Claude Code tools and their schemas as the authoritative execution protocol. Prefer direct implementation and verification for concrete change requests. Ask as few questions as possible: inspect available context first, make safe reasonable assumptions, and continue without confirmation for routine, reversible, in-scope work. Never repeat a question the user already answered. Ask only when the missing answer cannot be discovered and would materially change the result, authorize a meaningful scope expansion, or precede an irreversible action. Treat the user's explicit approval as decisive for the specifically named action and target: after a soft auto-mode denial, ask for precise consent only when it is missing, then retry once when the user grants it instead of claiming the denial is permanent. Hard-deny security boundaries still apply. Do not invent unsupported provider behavior, do not expose raw internal tool protocol, and keep progress updates concise and evidence-based."
if [[ "$CLAUDEX_PLAN_MODE_POLICY" == conservative ]]; then
  readonly claudex_plan_guard="Claudex plan-mode rule: remain in the current execution mode by default. Do not call EnterPlanMode or switch into plan permission mode merely because work is large, multi-step, unfamiliar, or benefits from private reasoning. Enter plan mode only when the user explicitly asks for a plan/design-only response, when a required user decision would materially change the implementation, or when the requested action is irreversible and needs approval before execution. For ordinary bug fixes and implementation requests, inspect, implement, test, and report directly."
else
  readonly claudex_plan_guard=""
fi
readonly claudex_leader_guard="${claudex_capacity_guard}

${claudex_task_guard}

${claudex_codex_guard}

${claudex_plan_guard}"

claude_args=()
if (( inject_session_customizations )); then
  if claude_supports '--agents'; then
    claude_args+=(--agents "$claudex_agents")
  fi
  if claude_supports '--append-system-prompt'; then
    claude_args+=(--append-system-prompt "$claudex_leader_guard")
  fi
fi
if (( inject_permission )) && claude_supports '--permission-mode'; then
  claude_args+=(--permission-mode "$permission_mode")
fi
if (( ! direct_chrome )) && [[ "$settings_file" != "$CLAUDE_CONFIG_DIR/settings.json" && "$effort_mode" != ultracode ]]; then
  claude_args+=(--settings "$settings_file")
fi
if (( use_proxy )) && [[ -n "$start_model" ]]; then
  claude_args+=(--model "$start_model")
  if [[ "$start_model" == opusplan ]]; then export CLAUDEX_MODEL_MODE=solplan; fi
fi
case "$effort_mode" in
  ultracode)
    claude_supports '--effort' || {
      printf '%s\n' 'claudex: this Claude Code build lacks --effort; run `claude update`.' >&2
      exit 1
    }
    if (( direct_chrome )); then
      ultracode_settings='{"ultracode":true,"workflows":true}'
    else
      ultracode_settings=$(jq -c '. + {ultracode: true, workflows: true}' "$settings_file")
    fi
    claude_args+=(--settings "$ultracode_settings" --effort xhigh)
    export CLAUDEX_SESSION_MODE=ultracode CLAUDE_CODE_EFFORT_LEVEL=xhigh
    ;;
  max)
    claude_supports '--effort' || {
      printf '%s\n' 'claudex: this Claude Code build lacks --effort; run `claude update`.' >&2
      exit 1
    }
    claude_args+=(--effort max)
    export CLAUDEX_SESSION_MODE=max CLAUDE_CODE_EFFORT_LEVEL=max
    ;;
esac

emit_mouse_pointer_shape() {
  local shape="$1"
  [[ "$CLAUDEX_MOUSE_POINTER_SHAPE" != "off" && -t 1 ]] || return 0

  # Ghostty implements OSC 22 application-controlled mouse pointer shapes.
  printf '\033]22;%s\033\\' "$shape"
}

resume_marker=""
emit_mouse_pointer_shape "$CLAUDEX_MOUSE_POINTER_SHAPE"
cleanup_session() {
  emit_mouse_pointer_shape default
  [[ -z "${resume_marker:-}" ]] || rm -f "$resume_marker"
  if [[ -n "${auth_watcher_pid:-}" ]]; then
    kill "$auth_watcher_pid" 2>/dev/null || true
    wait "$auth_watcher_pid" 2>/dev/null || true
  fi
  if [[ -n "${proxy_watcher_pid:-}" ]]; then
    kill "$proxy_watcher_pid" 2>/dev/null || true
    wait "$proxy_watcher_pid" 2>/dev/null || true
  fi
}
trap cleanup_session EXIT

rewrite_resume_footer=0
if { [[ -t 0 && -t 1 ]] || [[ "${CLAUDEX_TEST_TTY_OUTPUT:-0}" == 1 ]]; }; then
  rewrite_resume_footer=1
  for argument in ${forwarded_args[@]+"${forwarded_args[@]}"}; do
    case "$argument" in
      --print|-p|--help|-h|--version|-v|doctor) rewrite_resume_footer=0 ;;
    esac
  done
fi
if (( rewrite_resume_footer )); then
  resume_marker=$(mktemp "$claudex_config_dir/.resume-start.XXXXXX")
fi

run_claude() {
  if (( ${#claude_args[@]} > 0 )); then
    if (( ${#forwarded_args[@]} > 0 )); then
      claude "${claude_args[@]}" "${forwarded_args[@]}"
    else
      claude "${claude_args[@]}"
    fi
  elif (( ${#forwarded_args[@]} > 0 )); then
    claude "${forwarded_args[@]}"
  else
    claude
  fi
}

set +e
run_claude
claude_exit=$?
set -e

if (( rewrite_resume_footer )); then
  project_key=$(printf '%s' "$PWD" | sed 's/[^A-Za-z0-9]/-/g')
  project_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects/$project_key"
  latest_session_file=""
  matching_session_count=0
  if [[ -d "$project_dir" ]]; then
    while IFS= read -r candidate; do
      candidate_session_id="${candidate##*/}"
      candidate_session_id="${candidate_session_id%.jsonl}"
      [[ "$candidate_session_id" =~ ^[0-9a-fA-F-]{36}$ ]] || continue
      # Agent and concurrent-session logs can change while the root session is
      # closing. Select only a root record for this working directory, then use
      # its actual session ID for the launcher-owned footer replacement.
      tail -n 200 "$candidate" 2>/dev/null | jq -s -e \
        --arg cwd "$PWD" --arg session_id "$candidate_session_id" '
          any(.[];
            (.sessionId // "") == $session_id
            and (.cwd // "") == $cwd
            and ((.isSidechain // false) == false))
        ' >/dev/null 2>&1 || continue
      matching_session_count=$(( matching_session_count + 1 ))
      if [[ -z "$latest_session_file" || "$candidate" -nt "$latest_session_file" ]]; then latest_session_file="$candidate"; fi
    done < <(find "$project_dir" -maxdepth 1 -type f -name '*.jsonl' -newer "$resume_marker" -print 2>/dev/null)
  fi
  if (( matching_session_count == 1 )) && [[ -n "$latest_session_file" ]]; then
    session_id="${latest_session_file##*/}"
    session_id="${session_id%.jsonl}"
    if [[ "$session_id" =~ ^[0-9a-fA-F-]{36}$ ]]; then
      # Claude Code prints its hardcoded binary name after the JavaScript
      # runtime has already shut down. Append the authenticated Claudex path;
      # cursor-up erasure can corrupt wrapped or resized terminal output.
      if (( direct_chrome )); then
        printf '\nResume this session with Claudex:\nclaudex --claude-chrome --resume %s\n' "$session_id"
      else
        printf '\nResume this session with Claudex:\nclaudex --resume %s\n' "$session_id"
      fi
    fi
  fi
fi
[[ -z "$resume_marker" ]] || rm -f "$resume_marker"
exit "$claude_exit"

  start_model=""
  # Bash 3.2 (the system Bash on macOS) treats an empty array expansion as an
  # unbound variable under `set -u`; use its compatible conditional expansion.
  forwarded_args=(--chrome ${forwarded_args[@]+"${forwarded_args[@]}"})
fi


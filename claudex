#!/usr/bin/env bash
set -euo pipefail

readonly claudex_config_dir="${CLAUDEX_CONFIG_DIR:-$HOME/.config/claudex}"
readonly config_file="$claudex_config_dir/env"
readonly settings_file="${CLAUDEX_SETTINGS_FILE:-$claudex_config_dir/settings.json}"
readonly curl_bin="${CLAUDEX_CURL_BIN:-curl}"
readonly codex_session_helper="${CLAUDEX_CODEX_SESSION_HELPER:-$claudex_config_dir/codex-session}"

if [[ ! -r "$config_file" ]]; then
  printf '%s\n' "claudex: missing $config_file; reinstall or restore the Claudex configuration." >&2
  exit 1
fi

if [[ ! -r "$settings_file" ]]; then
  printf '%s\n' "claudex: missing $settings_file; reinstall or restore the Claudex settings." >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  printf '%s\n' "claudex: jq is required but was not found in PATH." >&2
  exit 1
fi

source "$config_file"

: "${CLAUDEX_PROXY_TOKEN:?CLAUDEX_PROXY_TOKEN is not configured}"
: "${CLAUDEX_PROXY_URL:=http://127.0.0.1:8317}"
: "${CLAUDEX_MODEL:=gpt-5.6-sol}"
: "${CLAUDEX_PERMISSION_MODE:=auto}"
: "${CLAUDEX_AUTO_MODE_MODEL:=gpt-5.6-luna}"
: "${CLAUDEX_BACKGROUND_MODEL:=gpt-5.6-luna}"
: "${CLAUDEX_SUBAGENT_MODEL:=gpt-5.6-terra}"
: "${CLAUDEX_MAX_TOOL_USE_CONCURRENCY:=3}"
: "${CLAUDEX_MAX_AGENT_CONCURRENCY:=3}"
: "${CLAUDEX_MAX_RETRIES:=2}"
: "${CLAUDEX_CONTEXT_WINDOW:=400000}"
: "${CLAUDEX_AUTO_COMPACT_WINDOW:=280000}"
: "${CLAUDEX_MOUSE_POINTER_SHAPE:=pointer}"
: "${CLAUDEX_USAGE_DISPLAY:=on}"
: "${CLAUDEX_USAGE_REFRESH_SECONDS:=300}"
: "${CLAUDEX_USAGE_TIMEOUT_SECONDS:=8}"
: "${CLAUDEX_USAGE_MAX_STALE_SECONDS:=86400}"
: "${CLAUDEX_USAGE_SOURCE:=auto}"
: "${CLAUDEX_USAGE_ALERT_PERCENT:=20}"
: "${CLAUDEX_CLAUDE_AUTO_UPDATE:=on}"
: "${CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS:=86400}"
: "${CLAUDEX_PLAN_MODE_POLICY:=conservative}"

case "$CLAUDEX_PROXY_TOKEN" in
  *$'\n'*|*$'\r'*)
    printf '%s\n' "claudex: CLAUDEX_PROXY_TOKEN contains an unsupported newline." >&2
    exit 2
    ;;
esac

case "$CLAUDEX_PERMISSION_MODE" in
  manual|auto|acceptEdits|dontAsk|plan) ;;
  *)
    printf '%s\n' "claudex: invalid CLAUDEX_PERMISSION_MODE '$CLAUDEX_PERMISSION_MODE'." >&2
    printf '%s\n' "claudex: expected manual, auto, acceptEdits, dontAsk, or plan." >&2
    exit 2
    ;;
esac

if [[ ! "$CLAUDEX_MAX_TOOL_USE_CONCURRENCY" =~ ^[0-9]+$ ]] || (( CLAUDEX_MAX_TOOL_USE_CONCURRENCY < 1 )); then
  printf '%s\n' "claudex: CLAUDEX_MAX_TOOL_USE_CONCURRENCY must be a positive integer." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_MAX_AGENT_CONCURRENCY" =~ ^[0-9]+$ ]] || (( CLAUDEX_MAX_AGENT_CONCURRENCY < 1 )); then
  printf '%s\n' "claudex: CLAUDEX_MAX_AGENT_CONCURRENCY must be a positive integer." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_MAX_RETRIES" =~ ^[0-9]+$ ]] || (( CLAUDEX_MAX_RETRIES > 15 )); then
  printf '%s\n' "claudex: CLAUDEX_MAX_RETRIES must be an integer from 0 to 15." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_CONTEXT_WINDOW" =~ ^[0-9]+$ ]] || (( CLAUDEX_CONTEXT_WINDOW < 100000 || CLAUDEX_CONTEXT_WINDOW > 1000000 )); then
  printf '%s\n' "claudex: CLAUDEX_CONTEXT_WINDOW must be an integer from 100000 to 1000000." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_AUTO_COMPACT_WINDOW" =~ ^[0-9]+$ ]] || (( CLAUDEX_AUTO_COMPACT_WINDOW < 100000 || CLAUDEX_AUTO_COMPACT_WINDOW > CLAUDEX_CONTEXT_WINDOW )); then
  printf '%s\n' "claudex: CLAUDEX_AUTO_COMPACT_WINDOW must be an integer from 100000 through CLAUDEX_CONTEXT_WINDOW." >&2
  exit 2
fi

case "$CLAUDEX_MOUSE_POINTER_SHAPE" in
  pointer|default|off) ;;
  *)
    printf '%s\n' "claudex: CLAUDEX_MOUSE_POINTER_SHAPE must be pointer, default, or off." >&2
    exit 2
    ;;
esac

case "$CLAUDEX_USAGE_DISPLAY" in
  on|off) ;;
  *)
    printf '%s\n' "claudex: CLAUDEX_USAGE_DISPLAY must be on or off." >&2
    exit 2
    ;;
esac

if [[ ! "$CLAUDEX_USAGE_REFRESH_SECONDS" =~ ^[0-9]+$ ]] || (( CLAUDEX_USAGE_REFRESH_SECONDS < 60 || CLAUDEX_USAGE_REFRESH_SECONDS > 3600 )); then
  printf '%s\n' "claudex: CLAUDEX_USAGE_REFRESH_SECONDS must be an integer from 60 to 3600." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_USAGE_TIMEOUT_SECONDS" =~ ^[0-9]+$ ]] || (( CLAUDEX_USAGE_TIMEOUT_SECONDS < 1 || CLAUDEX_USAGE_TIMEOUT_SECONDS > 30 )); then
  printf '%s\n' "claudex: CLAUDEX_USAGE_TIMEOUT_SECONDS must be an integer from 1 to 30." >&2
  exit 2
fi

if [[ ! "$CLAUDEX_USAGE_MAX_STALE_SECONDS" =~ ^[0-9]+$ ]] || (( CLAUDEX_USAGE_MAX_STALE_SECONDS < CLAUDEX_USAGE_REFRESH_SECONDS || CLAUDEX_USAGE_MAX_STALE_SECONDS > 604800 )); then
  printf '%s\n' "claudex: CLAUDEX_USAGE_MAX_STALE_SECONDS must be between the refresh interval and 604800." >&2
  exit 2
fi
case "$CLAUDEX_USAGE_SOURCE" in auto|web|app-server) ;;
  *) printf '%s\n' 'claudex: CLAUDEX_USAGE_SOURCE must be auto, web, or app-server.' >&2; exit 2 ;;
esac
if [[ ! "$CLAUDEX_USAGE_ALERT_PERCENT" =~ ^[0-9]+$ ]] || (( CLAUDEX_USAGE_ALERT_PERCENT < 0 || CLAUDEX_USAGE_ALERT_PERCENT > 100 )); then
  printf '%s\n' 'claudex: CLAUDEX_USAGE_ALERT_PERCENT must be an integer from 0 to 100.' >&2
  exit 2
fi
case "$CLAUDEX_CLAUDE_AUTO_UPDATE" in on|off) ;;
  *) printf '%s\n' 'claudex: CLAUDEX_CLAUDE_AUTO_UPDATE must be on or off.' >&2; exit 2 ;;
esac
if [[ ! "$CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS" =~ ^[0-9]+$ ]] || (( CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS < 3600 || CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS > 2592000 )); then
  printf '%s\n' 'claudex: CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS must be from 3600 to 2592000.' >&2
  exit 2
fi
case "$CLAUDEX_PLAN_MODE_POLICY" in conservative|normal) ;;
  *) printf '%s\n' 'claudex: CLAUDEX_PLAN_MODE_POLICY must be conservative or normal.' >&2; exit 2 ;;
esac

export CLAUDEX_USAGE_DISPLAY CLAUDEX_USAGE_REFRESH_SECONDS CLAUDEX_USAGE_TIMEOUT_SECONDS CLAUDEX_USAGE_MAX_STALE_SECONDS
export CLAUDEX_USAGE_SOURCE CLAUDEX_USAGE_ALERT_PERCENT

# Keep Claudex model choices, sessions, and preferences isolated from normal Claude Code.
export CLAUDE_CONFIG_DIR="$claudex_config_dir"

# Claude Code's welcome banner does not use ANTHROPIC_CUSTOM_MODEL_OPTION_NAME.
# Seed its isolated model-option cache so custom GPT IDs have friendly names in
# both the banner and model picker. Preserve unrelated cached options.
ensure_model_display_names() {
  local state_file="$CLAUDE_CONFIG_DIR/.claude.json"
  local tmp_file
  local managed_options='[
    {"value":"opusplan","label":"GPT-5.6 Solplan","description":"GPT-5.6 Sol in plan mode, GPT-5.6 Terra for implementation"},
    {"value":"gpt-5.6-sol","label":"GPT-5.6 Sol","description":"Frontier capability for planning and the hardest engineering work"},
    {"value":"gpt-5.6-terra","label":"GPT-5.6 Terra","description":"Balanced intelligence, speed, and cost for everyday coding"},
    {"value":"gpt-5.6-luna","label":"GPT-5.6 Luna","description":"Fast, efficient model for search, triage, and mechanical tasks"}
  ]'

  if [[ -s "$state_file" ]] && jq -e --argjson managed "$managed_options" '
    . as $root
    | ($managed | map({key: .value, value: .label}) | from_entries) as $labels
    | all(.additionalModelOptionsCache[]?; ($labels[.value] // .label) == .label)
    and all($managed[]; .value as $value | any($root.additionalModelOptionsCache[]?; .value == $value))
  ' "$state_file" >/dev/null 2>&1; then
    return 0
  fi

  mkdir -p "$CLAUDE_CONFIG_DIR"
  tmp_file=$(mktemp "$CLAUDE_CONFIG_DIR/.claude.json.tmp.XXXXXX")
  if [[ -s "$state_file" ]] && jq -e 'type == "object"' "$state_file" >/dev/null 2>&1; then
    jq --argjson managed "$managed_options" '
      ($managed | map(.value)) as $managed_ids
      | .additionalModelOptionsCache = (
          ((.additionalModelOptionsCache // [])
            | map(.value as $value | select(($managed_ids | index($value)) == null)))
          + $managed
        )
    ' "$state_file" > "$tmp_file"
  else
    jq -n --argjson managed "$managed_options" \
      '{additionalModelOptionsCache: $managed}' > "$tmp_file"
  fi
  mv -f "$tmp_file" "$state_file"
}

ensure_model_display_names

readonly claudex_preload="$CLAUDE_CONFIG_DIR/preload.cjs"
if [[ -r "$claudex_preload" ]]; then
  readonly escaped_claudex_preload="${claudex_preload// /\\ }"
  export BUN_OPTIONS="--preload $escaped_claudex_preload ${BUN_OPTIONS:-}"
fi

fetch_models() {
  printf 'Authorization: Bearer %s\n' "$CLAUDEX_PROXY_TOKEN" | \
    "$curl_bin" --silent --show-error --fail --max-time 5 --header @- \
    "${CLAUDEX_PROXY_URL}/v1/models"
}

models_are_valid() {
  jq -e --arg model "$CLAUDEX_MODEL" '
    [.data[]?.id] as $ids
    | ($ids | length) > 0 and ($ids | index($model) != null)
  ' >/dev/null 2>&1
}

proxy_ready() {
  fetch_models 2>/dev/null | models_are_valid
}

proxy_executable() {
  if [[ -n "${CLAUDEX_PROXY_BIN:-}" && -x "$CLAUDEX_PROXY_BIN" ]]; then
    printf '%s\n' "$CLAUDEX_PROXY_BIN"
  elif [[ -x "$CLAUDE_CONFIG_DIR/bin/cliproxyapi" ]]; then
    printf '%s\n' "$CLAUDE_CONFIG_DIR/bin/cliproxyapi"
  elif command -v cliproxyapi >/dev/null 2>&1; then
    command -v cliproxyapi
  elif command -v cli-proxy-api >/dev/null 2>&1; then
    command -v cli-proxy-api
  else
    return 1
  fi
}

ensure_proxy() {
  if [[ ! -x "$codex_session_helper" ]]; then
    printf '%s\n' "claudex: authentication helper is missing: $codex_session_helper" >&2
    printf '%s\n' 'claudex: reinstall Claudex to repair the installation.' >&2
    return 1
  fi
  "$codex_session_helper" sync || return $?

  if proxy_ready; then
    return 0
  fi

  printf '%s\n' "claudex: starting the local CLIProxyAPI service..." >&2
  local proxy_config homebrew_proxy_config=""
  proxy_config="${CLAUDEX_PROXY_CONFIG:-$CLAUDE_CONFIG_DIR/cliproxyapi.yaml}"
  if command -v brew >/dev/null 2>&1; then
    homebrew_proxy_config="$(brew --prefix)/etc/cliproxyapi.conf"
  fi
  if command -v brew >/dev/null 2>&1 \
      && brew list --formula cliproxyapi >/dev/null 2>&1 \
      && { [[ ! -r "$proxy_config" ]] || [[ "$proxy_config" == "$homebrew_proxy_config" ]]; }; then
    brew services start cliproxyapi >/dev/null
  else
    local proxy_bin log_dir
    proxy_bin=$(proxy_executable) || {
      printf '%s\n' "claudex: CLIProxyAPI is not reachable and no proxy executable was found." >&2
      return 1
    }
    log_dir="$CLAUDE_CONFIG_DIR/logs"
    mkdir -p "$log_dir"
    if [[ -r "$proxy_config" ]]; then
      nohup "$proxy_bin" -config "$proxy_config" >"$log_dir/cliproxyapi.log" 2>&1 </dev/null &
    else
      nohup "$proxy_bin" >"$log_dir/cliproxyapi.log" 2>&1 </dev/null &
    fi
  fi

  local attempt
  for attempt in {1..50}; do
    if proxy_ready; then
      return 0
    fi
    sleep 0.1
  done

  printf '%s\n' "claudex: local proxy did not become healthy. Run: claudex --doctor" >&2
  return 1
}

maybe_update_claude() {
  [[ "$CLAUDEX_CLAUDE_AUTO_UPDATE" == on ]] || return 0
  [[ "${CLAUDEX_SKIP_AUTO_UPDATE:-0}" != 1 ]] || return 0
  command -v claude >/dev/null 2>&1 || return 0

  local update_dir="$CLAUDE_CONFIG_DIR/update" stamp="$CLAUDE_CONFIG_DIR/update/last-success" now last=0
  now=$(date +%s)
  if [[ -r "$stamp" ]]; then
    read -r last < "$stamp" || last=0
  fi
  [[ "$last" =~ ^[0-9]+$ ]] || last=0
  (( now - last >= CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS )) || return 0
  mkdir -p "$update_dir"
  if mkdir "$update_dir/lock" 2>/dev/null; then
    (
      if claude update >"$update_dir/claude-update.log" 2>&1; then
        local completed temporary
        completed=$(date +%s)
        temporary="$update_dir/.last-success.$$"
        printf '%s\n' "$completed" > "$temporary"
        mv -f "$temporary" "$stamp"
      fi
      rmdir "$update_dir/lock" 2>/dev/null || true
    ) &
  fi
}

claude_supports() {
  local option="$1"
  [[ "${claude_help_cache:-}" == *"$option"* ]]
}

load_claude_capabilities() {
  command -v claude >/dev/null 2>&1 || {
    printf '%s\n' 'claudex: Claude Code was not found. Install Claude Code and retry.' >&2
    return 1
  }
  claude_help_cache=$(claude --help 2>/dev/null || true)
  [[ -n "$claude_help_cache" ]] || {
    printf '%s\n' 'claudex: Claude Code did not return its capability list.' >&2
    return 1
  }
  if ! claude_supports '--model'; then
    printf '%s\n' 'claudex: this Claude Code build does not support custom models; run `claude update`.' >&2
    return 1
  fi
}

model_name() {
  case "$1" in
    opusplan|solplan) printf '%s\n' "GPT-5.6 Solplan" ;;
    gpt-5.6-terra|sonnet) printf '%s\n' "GPT-5.6 Terra" ;;
    gpt-5.6-luna|haiku) printf '%s\n' "GPT-5.6 Luna" ;;
    *) printf '%s\n' "GPT-5.6 Sol" ;;
  esac
}

doctor() {
  ensure_proxy

  local saved_model models proxy_version missing=0 model
  saved_model=$(jq -r '.model // "gpt-5.6-sol"' "$settings_file")
  models=$(fetch_models)
  local proxy_bin
  proxy_bin=$(proxy_executable) || proxy_bin=""
  if [[ -n "$proxy_bin" ]]; then
    proxy_version=$("$proxy_bin" -version 2>&1) || true
  else
    proxy_version=""
  fi
  proxy_version="${proxy_version%%$'\n'*}"
  [[ -n "$proxy_version" ]] || proxy_version="unavailable"

  printf '%s\n' "Claude Code: $(claude --version 2>/dev/null || printf unavailable)"
  printf '%s\n' "CLIProxyAPI: ${proxy_version}"
  "$codex_session_helper" status
  printf '%s\n' "Proxy: healthy at ${CLAUDEX_PROXY_URL}"
  printf '%s\n' "Saved model: $(model_name "$saved_model") (${saved_model})"
  printf '%s\n' "Default permission mode: ${CLAUDEX_PERMISSION_MODE}"
  printf '%s\n' "Auto-mode classifier: ${CLAUDEX_AUTO_MODE_MODEL} (only used when auto mode is selected)"
  printf '%s\n' "Subagent model: ${CLAUDEX_SUBAGENT_MODEL} (Sol is reserved for the leader)"
  printf '%s\n' "Tool concurrency: ${CLAUDEX_MAX_TOOL_USE_CONCURRENCY}"
  printf '%s\n' "Agent concurrency: ${CLAUDEX_MAX_AGENT_CONCURRENCY}"
  printf '%s\n' "Task lifecycle: Sol-owned with final-response reconciliation"
  printf '%s\n' "API retries: ${CLAUDEX_MAX_RETRIES}"
  printf '%s\n' "Context window: ${CLAUDEX_CONTEXT_WINDOW} tokens"
  printf '%s\n' "Auto-compact window: ${CLAUDEX_AUTO_COMPACT_WINDOW} tokens (precompute enabled)"
  printf '%s\n' "Context status: session-stabilized (transient zero suppressed)"
  printf '%s\n' "Codex usage: status-line refresh every ${CLAUDEX_USAGE_REFRESH_SECONDS}s; inspect with /usage-limit or claudex --usage-limit"
  printf '%s\n' "Usage source: ${CLAUDEX_USAGE_SOURCE} (documented Codex app-server fallback enabled in auto mode)"
  printf '%s\n' "Low-quota alert: ${CLAUDEX_USAGE_ALERT_PERCENT}% remaining (0 disables)"
  printf '%s\n' 'Effort shortcuts: --max-effort and --ultracode (xhigh plus dynamic workflows)'
  printf '%s\n' 'Claude in Chrome: use --claude-chrome for the direct Anthropic profile required by the extension'
  printf '%s\n' "Claude Code updates: ${CLAUDEX_CLAUDE_AUTO_UPDATE} (checked every ${CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS}s)"
  printf '%s\n' "Plan mode policy: ${CLAUDEX_PLAN_MODE_POLICY} (implementation-first unless planning is genuinely required)"
  printf '%s\n' "Rendering: no-flicker mode with native terminal cursor"
  printf '%s\n' "Terminal UI: fullscreen (launch command hidden while Claudex is open)"
  printf '%s\n' "Header model name: GPT-5.6 Sol"
  printf '%s\n' "Mouse pointer: ${CLAUDEX_MOUSE_POINTER_SHAPE}"
  printf '%s\n' "Isolation: Claudex config at ${CLAUDE_CONFIG_DIR}; normal Claude config is untouched"

  for model in gpt-5.6-sol gpt-5.6-terra gpt-5.6-luna; do
    if printf '%s\n' "$models" | jq -e --arg model "$model" \
      'any(.data[]?; .id == $model)' >/dev/null 2>&1; then
      printf '%s\n' "${model}: advertised"
    else
      printf '%s\n' "${model}: not advertised by the authenticated Codex account" >&2
      missing=1
    fi
  done

  return "$missing"
}

if [[ "${1:-}" == "--login" ]]; then
  [[ -x "$codex_session_helper" ]] || {
    printf '%s\n' 'claudex: authentication helper is missing; reinstall Claudex.' >&2
    exit 1
  }
  exec "$codex_session_helper" login
fi

if [[ "${1:-}" == "--logout" ]]; then
  [[ -x "$codex_session_helper" ]] || {
    printf '%s\n' 'claudex: authentication helper is missing; reinstall Claudex.' >&2
    exit 1
  }
  exec "$codex_session_helper" logout
fi

if [[ "${1:-}" == "--auth-status" ]]; then
  [[ -x "$codex_session_helper" ]] || {
    printf '%s\n' 'claudex: authentication helper is missing; reinstall Claudex.' >&2
    exit 1
  }
  exec "$codex_session_helper" status
fi

if [[ "${1:-}" == "--doctor" ]]; then
  doctor
  exit
fi

if [[ "${1:-}" == "--usage-limit" ]]; then
  shift
  usage_helper="$CLAUDE_CONFIG_DIR/usage-limit"
  [[ -x "$usage_helper" ]] || {
    printf '%s\n' "claudex: usage-limit helper is missing; reinstall Claudex." >&2
    exit 1
  }
  exec "$usage_helper" "$@"
fi

if [[ "${1:-}" == "--accounts" ]]; then
  usage_helper="$CLAUDE_CONFIG_DIR/usage-limit"
  [[ -x "$usage_helper" ]] || {
    printf '%s\n' "claudex: usage-limit helper is missing; reinstall Claudex." >&2
    exit 1
  }
  exec "$usage_helper" --accounts
fi

if [[ "${1:-}" == "--account" ]]; then
  shift
  [[ $# -eq 1 ]] || {
    printf '%s\n' "Usage: claudex --account <number|email|filename|auto>" >&2
    exit 2
  }
  usage_helper="$CLAUDE_CONFIG_DIR/usage-limit"
  [[ -x "$usage_helper" ]] || {
    printf '%s\n' "claudex: usage-limit helper is missing; reinstall Claudex." >&2
    exit 1
  }
  exec "$usage_helper" --account "$1"
fi

start_model=""
effort_mode=""
permission_mode="$CLAUDEX_PERMISSION_MODE"
direct_chrome=0
forwarded_args=()
while (( $# > 0 )); do
  case "$1" in
    --sol) start_model="gpt-5.6-sol" ;;
    --terra) start_model="gpt-5.6-terra" ;;
    --luna) start_model="gpt-5.6-luna" ;;
    --solplan) start_model="opusplan" ;;
    --manual) permission_mode="manual" ;;
    --auto) permission_mode="auto" ;;
    --accept-edits) permission_mode="acceptEdits" ;;
    --ultracode)
      [[ -z "$effort_mode" || "$effort_mode" == ultracode ]] || {
        printf '%s\n' 'claudex: --ultracode and --max-effort cannot be combined.' >&2
        exit 2
      }
      effort_mode=ultracode
      ;;
    --max-effort)
      [[ -z "$effort_mode" || "$effort_mode" == max ]] || {
        printf '%s\n' 'claudex: --ultracode and --max-effort cannot be combined.' >&2
        exit 2
      }
      effort_mode=max
      ;;
    --claude-chrome) direct_chrome=1 ;;
    --)
      forwarded_args+=(--)
      shift
      forwarded_args+=("$@")
      break
      ;;
    *) forwarded_args+=("$1") ;;
  esac
  shift
done
use_proxy=1
inject_session_customizations=1
inject_permission=1

case "${forwarded_args[0]:-}" in
  --help|-h|--version|-v|agents|auth|auto-mode|doctor|gateway|install|mcp|plugin|plugins|project|setup-token|ultrareview|update|upgrade)
    use_proxy=0
    inject_session_customizations=0
    inject_permission=0
    ;;
esac

for argument in ${forwarded_args[@]+"${forwarded_args[@]}"}; do
  case "$argument" in
    --safe-mode|--bare)
      inject_session_customizations=0
      inject_permission=0
      ;;
    --agents) inject_session_customizations=0 ;;
    --permission-mode|--dangerously-skip-permissions|--allow-dangerously-skip-permissions)
      inject_permission=0
      ;;
    --effort|--effort=*|--settings|--settings=*)
      if [[ -n "$effort_mode" ]]; then
        printf '%s\n' "claudex: $argument conflicts with the selected Claudex effort shortcut." >&2
        exit 2
      fi
      ;;
  esac
done

if (( direct_chrome )); then
  [[ -z "$start_model" ]] || {
    printf '%s\n' 'claudex: --sol, --terra, --luna, and --solplan cannot be combined with --claude-chrome because Chrome requires a first-party Anthropic model.' >&2
    exit 2
  }
  use_proxy=0
  inject_session_customizations=0
  inject_permission=0
  if [[ -n "${CLAUDEX_CHROME_CONFIG_DIR:-}" ]]; then
    export CLAUDE_CONFIG_DIR="$CLAUDEX_CHROME_CONFIG_DIR"
  else
    unset CLAUDE_CONFIG_DIR
  fi
  unset ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN
  forwarded_args=(--chrome "${forwarded_args[@]}")
fi

load_claude_capabilities
maybe_update_claude

if (( use_proxy )); then
  ensure_proxy

  export ANTHROPIC_BASE_URL="$CLAUDEX_PROXY_URL"
  export ANTHROPIC_AUTH_TOKEN="$CLAUDEX_PROXY_TOKEN"

# Map one Claude Code selector alias onto each GPT-5.6 model. Registering the
# same model through Fable, Opus, and the custom slot creates duplicate rows.
  export ANTHROPIC_DEFAULT_OPUS_MODEL="gpt-5.6-sol"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="gpt-5.6-terra"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="gpt-5.6-luna"
  export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="GPT-5.6 Sol"
  export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="GPT-5.6 Terra"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="GPT-5.6 Luna"
  export ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION="Frontier capability for planning and the hardest engineering work"
  export ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION="Balanced intelligence, speed, and cost for everyday coding"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL_DESCRIPTION="Fast, efficient model for search, triage, and mechanical tasks"

  readonly gpt56_capabilities="effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking"
  export ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"
  export ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"

# Claude Code otherwise chooses Sonnet 5 for an external-provider auto-mode classifier,
# which Claudex maps to Terra. Pinning the classifier prevents misleading Terra outages.
  export CLAUDE_CODE_AUTO_MODE_MODEL="$CLAUDEX_AUTO_MODE_MODEL"
  export CLAUDE_CODE_BG_CLASSIFIER_MODEL="$CLAUDEX_BACKGROUND_MODEL"
  export CLAUDE_CODE_SUBAGENT_MODEL="$CLAUDEX_SUBAGENT_MODEL"
  export CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1
  export CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY="$CLAUDEX_MAX_TOOL_USE_CONCURRENCY"
  export CLAUDE_CODE_MAX_RETRIES="$CLAUDEX_MAX_RETRIES"

# Claude Code assumes unknown custom models have a 200k context window. Claudex's
# GPT-5.6 backend supports a larger window, so make the meter accurate and force
# client-side summarization before the session grows without bound.
  export CLAUDE_CODE_MAX_CONTEXT_TOKENS="$CLAUDEX_CONTEXT_WINDOW"
  export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$CLAUDEX_AUTO_COMPACT_WINDOW"
else
  unset ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN
fi

export CLAUDEX_USAGE_DISPLAY CLAUDEX_USAGE_REFRESH_SECONDS CLAUDEX_USAGE_TIMEOUT_SECONDS CLAUDEX_USAGE_MAX_STALE_SECONDS
export CLAUDEX_USAGE_SOURCE CLAUDEX_USAGE_ALERT_PERCENT
export CLAUDE_CODE_NO_FLICKER=1
export CLAUDE_CODE_ACCESSIBILITY=1

# One proxy credential backs all three aliases. Custom agents must not recursively
# spawn more agents, or a small parallel batch becomes a retry/429 storm.
readonly no_nested_agents="Do not create a team, spawn or delegate to additional agents, or send intermediate progress messages to the parent. Do not create, claim, or update entries in the shared task list; the Sol leader owns task lifecycle. Complete the assigned task yourself and return one final result through the normal agent result channel. If the provider reports a 429 or model cooldown, do not launch a replacement agent or start a retry loop."
readonly claudex_agents="{\"gpt-5-6-terra\":{\"description\":\"GPT-5.6 Terra for delegated architecture, debugging, implementation, testing, security review, and other substantial engineering work.\",\"prompt\":\"You are GPT-5.6 Terra. Investigate thoroughly, make robust focused progress, verify the result, and return concise evidence-backed findings. ${no_nested_agents}\",\"model\":\"gpt-5.6-terra\",\"effort\":\"high\"},\"gpt-5-6-luna\":{\"description\":\"GPT-5.6 Luna for delegated search, triage, inventory, and bounded mechanical tasks.\",\"prompt\":\"You are GPT-5.6 Luna. Complete the scoped task efficiently and report only relevant verified findings. ${no_nested_agents}\",\"model\":\"gpt-5.6-luna\",\"effort\":\"medium\"}}"
readonly claudex_capacity_guard="Claudex capacity rule: keep at most ${CLAUDEX_MAX_AGENT_CONCURRENCY} Agent tasks active at once. Launch no more than ${CLAUDEX_MAX_AGENT_CONCURRENCY} agents in a wave, wait for one to finish before starting another, and never create an agent team. Sol capacity is reserved for the leader; use the configured Terra or Luna agents for delegated work. If a model reports a 429 or cooldown, do not launch replacement agents or create a retry storm; continue useful local work and retry at most once after active agents settle."
readonly claudex_task_guard="Claudex task lifecycle rule: the Sol leader is the sole owner of the shared task list. Keep it compact and create only tasks that represent real remaining deliverables, not duplicate discovery lanes or speculative work. Mark a task in_progress only while the leader or a currently active agent is working on it; queued or blocked work stays pending. After every agent result, immediately reconcile its parent task and mark it completed once its outcome is integrated and verified. Before every final answer, call TaskList and reconcile every entry: completed work must be completed, inactive work must not remain in_progress, and genuinely unfinished pending work must be explicitly reported instead of being hidden behind a completion claim. Never leave stale in_progress tasks after their work is done."
readonly claudex_codex_guard="Claudex Codex-model rule: operate as a Codex coding agent inside Claude Code's interface. Treat the available Claude Code tools and their schemas as the authoritative execution protocol. Prefer direct implementation and verification for concrete change requests. Do not invent unsupported provider behavior, do not expose raw internal tool protocol, and keep progress updates concise and evidence-based."
if [[ "$CLAUDEX_PLAN_MODE_POLICY" == conservative ]]; then
  readonly claudex_plan_guard="Claudex plan-mode rule: remain in the current execution mode by default. Do not call EnterPlanMode or switch into plan permission mode merely because work is large, multi-step, unfamiliar, or benefits from private reasoning. Enter plan mode only when the user explicitly asks for a plan/design-only response, when a required user decision would materially change the implementation, or when the requested action is irreversible and needs approval before execution. For ordinary bug fixes and implementation requests, inspect, implement, test, and report directly."
else
  readonly claudex_plan_guard=""
fi
readonly claudex_leader_guard="${claudex_capacity_guard}

${claudex_task_guard}

${claudex_codex_guard}

${claudex_plan_guard}"

claude_args=()
if (( inject_session_customizations )); then
  if claude_supports '--agents'; then
    claude_args+=(--agents "$claudex_agents")
  fi
  if claude_supports '--append-system-prompt'; then
    claude_args+=(--append-system-prompt "$claudex_leader_guard")
  fi
fi
if (( inject_permission )) && claude_supports '--permission-mode'; then
  claude_args+=(--permission-mode "$permission_mode")
fi
if (( ! direct_chrome )) && [[ "$settings_file" != "$CLAUDE_CONFIG_DIR/settings.json" && "$effort_mode" != ultracode ]]; then
  claude_args+=(--settings "$settings_file")
fi
if [[ -n "$start_model" ]]; then
  claude_args+=(--model "$start_model")
  if [[ "$start_model" == opusplan ]]; then export CLAUDEX_MODEL_MODE=solplan; fi
fi
case "$effort_mode" in
  ultracode)
    claude_supports '--effort' || {
      printf '%s\n' 'claudex: this Claude Code build lacks --effort; run `claude update`.' >&2
      exit 1
    }
    if (( direct_chrome )); then
      ultracode_settings='{"ultracode":true,"workflows":true}'
    else
      ultracode_settings=$(jq -c '. + {ultracode: true, workflows: true}' "$settings_file")
    fi
    claude_args+=(--settings "$ultracode_settings" --effort xhigh)
    export CLAUDEX_SESSION_MODE=ultracode CLAUDE_CODE_EFFORT_LEVEL=xhigh
    ;;
  max)
    claude_supports '--effort' || {
      printf '%s\n' 'claudex: this Claude Code build lacks --effort; run `claude update`.' >&2
      exit 1
    }
    claude_args+=(--effort max)
    export CLAUDEX_SESSION_MODE=max CLAUDE_CODE_EFFORT_LEVEL=max
    ;;
esac

emit_mouse_pointer_shape() {
  local shape="$1"
  [[ "$CLAUDEX_MOUSE_POINTER_SHAPE" != "off" && -t 1 ]] || return 0

  # Ghostty implements OSC 22 application-controlled mouse pointer shapes.
  printf '\033]22;%s\033\\' "$shape"
}

resume_marker=""
emit_mouse_pointer_shape "$CLAUDEX_MOUSE_POINTER_SHAPE"
trap 'emit_mouse_pointer_shape default; [[ -z "${resume_marker:-}" ]] || rm -f "$resume_marker"' EXIT

rewrite_resume_footer=0
if { [[ -t 0 && -t 1 ]] || [[ "${CLAUDEX_TEST_TTY_OUTPUT:-0}" == 1 ]]; }; then
  rewrite_resume_footer=1
  for argument in ${forwarded_args[@]+"${forwarded_args[@]}"}; do
    case "$argument" in
      --print|-p|--help|-h|--version|-v|doctor) rewrite_resume_footer=0 ;;
    esac
  done
fi
if (( rewrite_resume_footer )); then
  resume_marker=$(mktemp "$claudex_config_dir/.resume-start.XXXXXX")
fi

run_claude() {
  if (( ${#claude_args[@]} > 0 )); then
    if (( ${#forwarded_args[@]} > 0 )); then
      claude "${claude_args[@]}" "${forwarded_args[@]}"
    else
      claude "${claude_args[@]}"
    fi
  elif (( ${#forwarded_args[@]} > 0 )); then
    claude "${forwarded_args[@]}"
  else
    claude
  fi
}

set +e
run_claude
claude_exit=$?
set -e

if (( rewrite_resume_footer && claude_exit == 0 )); then
  project_key=$(printf '%s' "$PWD" | sed 's/[^A-Za-z0-9]/-/g')
  project_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects/$project_key"
  latest_session_file=""
  if [[ -d "$project_dir" ]]; then
    while IFS= read -r candidate; do
      if [[ -z "$latest_session_file" || "$candidate" -nt "$latest_session_file" ]]; then
        latest_session_file="$candidate"
      fi
    done < <(find "$project_dir" -maxdepth 1 -type f -name '*.jsonl' -newer "$resume_marker" -print 2>/dev/null)
  fi
  if [[ -n "$latest_session_file" ]]; then
    session_id="${latest_session_file##*/}"
    session_id="${session_id%.jsonl}"
    if [[ "$session_id" =~ ^[0-9a-fA-F-]{36}$ ]]; then
      # Claude Code prints its hardcoded binary name after the JavaScript
      # runtime has already shut down. Replace those final two terminal rows
      # from the launcher, which still owns the authenticated resume path.
      printf '\033[2A\033[JResume this session with:\nclaudex --resume %s\n' "$session_id"
    fi
  fi
fi
[[ -z "$resume_marker" ]] || rm -f "$resume_marker"
exit "$claude_exit"

  printf '%s\n' "Claude Code: $(claude --version 2>/dev/null || printf unavailable)"
  printf '%s\n' "CLIProxyAPI: ${proxy_version}"
  "$codex_session_helper" status
  printf '%s\n' "Proxy: healthy at ${CLAUDEX_PROXY_URL}"
  printf '%s\n' "Saved model: $(model_name "$saved_model") (${saved_model})"
  printf '%s\n' "Default permission mode: ${CLAUDEX_PERMISSION_MODE}"

}

start_proxy_watcher() {
  [[ "${CLAUDEX_SKIP_PROXY_WATCHER:-0}" != 1 ]] || return 0
  local parent_pid=$$ parent_identity consecutive_failures=0
  parent_identity=$(process_identity "$parent_pid" 2>/dev/null || true)
  (
    trap '' HUP
    local registry_status=0 empty_polls=0
    while :; do
      if watch_parent_is_current "$parent_pid" "$parent_identity"; then
        empty_polls=0
      elif (( parsed_background )); then
        registry_status=0
        managed_background_registry_state || registry_status=$?
        case "$registry_status" in
          0) empty_polls=0 ;;
          1)
            empty_polls=$(( empty_polls + 1 ))
            (( empty_polls < 3 )) || break
            ;;
          *) empty_polls=0 ;;
        esac
      else
        break
      fi
      sleep 1
      if proxy_reachable; then
        consecutive_failures=0
      else
        consecutive_failures=$((consecutive_failures + 1))
        if (( consecutive_failures >= 2 )); then
          ensure_proxy >/dev/null 2>&1 || true
          consecutive_failures=0
        fi
      fi
    done
    if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_PROXY_WATCH_EXIT_FILE:-}" ]]; then
      (umask 077; printf '%s\n' exited > "$CLAUDEX_TEST_PROXY_WATCH_EXIT_FILE")
    fi
  ) </dev/null >/dev/null 2>&1 &
  proxy_watcher_pid=$!
  if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_PROXY_WATCH_PID_FILE:-}" ]]; then
    (umask 077; printf '%s\n' "$proxy_watcher_pid" > "$CLAUDEX_TEST_PROXY_WATCH_PID_FILE")
  fi
  if (( parsed_background )); then disown "$proxy_watcher_pid" 2>/dev/null || true; fi
}

record_proxy_recovery() {
  local message="$1" run_dir="$CLAUDE_CONFIG_DIR/run" log_file temporary size
  mkdir -p "$run_dir"
  log_file="$run_dir/proxy-recovery.log"
  (umask 077; printf '%s %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$message" >> "$log_file")
  chmod 600 "$log_file" 2>/dev/null || true
  size=$(wc -c < "$log_file" 2>/dev/null | tr -d ' ' || printf 0)
  if [[ "$size" =~ ^[0-9]+$ ]] && (( size > 65536 )); then
    temporary=$(mktemp "$run_dir/.proxy-recovery.XXXXXX")
    tail -c 32768 "$log_file" > "$temporary" 2>/dev/null || true
    chmod 600 "$temporary" 2>/dev/null || true
    mv -f "$temporary" "$log_file"
  fi
}

release_proxy_lock() {
  release_owned_lock "$1" "$2"
}

write_managed_proxy_pid() {
  local pid="$1" run_dir="$CLAUDE_CONFIG_DIR/run" pid_file temporary identity attempt
  pid_file="$run_dir/managed-proxy"
  identity=""
  for attempt in {1..10}; do
    identity=$(process_identity "$pid" || true)
    [[ -z "$identity" ]] || break
    kill -0 "$pid" 2>/dev/null || return 1
    sleep 0.02
  done
  [[ -n "$identity" ]] || return 1
  temporary=$(mktemp "$run_dir/.managed-proxy.XXXXXX")
  {
    printf 'pid=%s\n' "$pid"
    printf 'identity=%s\n' "$identity"
  } > "$temporary"
  chmod 600 "$temporary" 2>/dev/null || true
  mv -f "$temporary" "$pid_file"
}

managed_proxy_is_current() {
  local pid_file="$CLAUDE_CONFIG_DIR/run/managed-proxy" pid identity current
  [[ -r "$pid_file" ]] || return 1
  pid=$(read_lock_field "$pid_file" pid)
  identity=$(read_lock_field "$pid_file" identity)
  [[ "$pid" =~ ^[0-9]+$ && -n "$identity" ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  current=$(process_identity "$pid" || true)
  [[ -n "$current" && "$current" == "$identity" ]]
}

stop_unhealthy_managed_proxy() {
  local pid_file="$CLAUDE_CONFIG_DIR/run/managed-proxy" pid identity current attempt
  [[ -r "$pid_file" ]] || return 0
  pid=$(read_lock_field "$pid_file" pid)
  identity=$(read_lock_field "$pid_file" identity)
  if [[ ! "$pid" =~ ^[0-9]+$ ]] || ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$pid_file"
    return 0
  fi
  current=$(process_identity "$pid" || true)
  [[ -n "$identity" && "$current" == "$identity" ]] || {
    record_proxy_recovery "ignored stale managed proxy pid metadata pid=$pid"
    rm -f "$pid_file"
    return 0
  }
  kill -TERM "$pid" 2>/dev/null || true
  for attempt in {1..20}; do
    kill -0 "$pid" 2>/dev/null || break
    sleep 0.1
  done
  if kill -0 "$pid" 2>/dev/null && [[ "$(process_identity "$pid" || true)" == "$identity" ]]; then
    kill -KILL "$pid" 2>/dev/null || true
  fi
  rm -f "$pid_file"
  record_proxy_recovery "stopped unresponsive managed proxy pid=$pid"
}

claudex_auth_sync_failed=0
claudex_auth_sync_status=0
claudex_interactive_login_attempted=0

ensure_proxy() {
  local health_status=0
  claudex_auth_sync_failed=0
  claudex_auth_sync_status=0
  if [[ ! -x "$codex_session_helper" ]]; then
    record_proxy_recovery "authentication helper is missing"
    printf '%s\n' "claudex: authentication helper is missing: $codex_session_helper" >&2
    printf '%s\n' 'claudex: reinstall Claudex to repair the installation.' >&2
    return 1
  fi
  local sync_status=0
  if [[ "${CLAUDEX_TEST_MODE:-0}" != 1 || "${CLAUDEX_TEST_SKIP_AUTH_SYNC:-0}" != 1 ]]; then
    "$codex_session_helper" sync || sync_status=$?
  fi
  if (( sync_status != 0 )); then
    claudex_auth_sync_failed=1
    claudex_auth_sync_status=$sync_status
    record_proxy_recovery "authentication synchronization failed status=$sync_status"
    return "$sync_status"
  fi

  if proxy_ready; then
    return 0
  else
    health_status=$?
    if (( health_status == 41 )); then
      if (( claudex_remote_proxy )) || ! managed_proxy_is_current; then
        record_proxy_recovery "unmanaged proxy rejected the configured authentication token"
        printf '%s\n' 'claudex: the proxy rejected its configured authentication token; refusing to restart a listener that is not proven Claudex-managed.' >&2
        return 1
      fi
      record_proxy_recovery "tracked managed proxy rejected its configured authentication token; restarting it"
    fi
  fi

  if (( claudex_remote_proxy )); then
    record_proxy_recovery "remote proxy is unavailable; local recovery is disabled"
    printf '%s\n' 'claudex: the configured remote proxy is unavailable; local proxy recovery is disabled for remote endpoints.' >&2
    return 1
  fi

  # Concurrent Claudex tabs can notice a stopped bridge at the same time.
  # Serialize startup so only one process can bind the loopback port.
  local run_dir="$CLAUDE_CONFIG_DIR/run" lock_dir attempt
  local lock_acquired=0 owner_nonce
  local lock_deadline startup_deadline proxy_pid startup_auth_failures=0
  lock_dir="$run_dir/proxy-start.lock"
  mkdir -p "$run_dir"
  lock_deadline=$(( SECONDS + 30 ))
  while (( SECONDS < lock_deadline )); do
    if acquire_owned_lock "$lock_dir" 1 0 120; then
      owner_nonce="$owned_lock_nonce"
      lock_acquired=1
      if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_PROXY_LOCK_ATTEMPT_FILE:-}" ]]; then
        printf 'acquired %s\n' "$$" >> "$CLAUDEX_TEST_PROXY_LOCK_ATTEMPT_FILE"
      fi
      break
    fi
    if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_PROXY_LOCK_ATTEMPT_FILE:-}" ]]; then
      printf 'blocked %s\n' "$$" >> "$CLAUDEX_TEST_PROXY_LOCK_ATTEMPT_FILE"
    fi
    if proxy_ready; then return 0
    elif (( $? == 41 )) && ! managed_proxy_is_current; then
      record_proxy_recovery "unmanaged proxy authentication failed while waiting for startup lock"
      return 1
    fi
    sleep 0.1
  done
  if (( ! lock_acquired )); then
    record_proxy_recovery "timed out after 30s waiting for startup lock"
    printf '%s\n' "claudex: timed out waiting for another session to start the local proxy." >&2
    return 1
  fi
  record_proxy_recovery "proxy startup lock acquired"
  trap 'release_proxy_lock "$lock_dir" "$owner_nonce"' EXIT

  if proxy_ready; then
    release_proxy_lock "$lock_dir" "$owner_nonce"
    trap - EXIT
    return 0
  elif (( $? == 41 )) && ! managed_proxy_is_current; then
    record_proxy_recovery "unmanaged proxy authentication failed after startup lock acquisition"
    release_proxy_lock "$lock_dir" "$owner_nonce"
    trap - EXIT
    return 1
  fi

  printf '%s\n' "claudex: starting the local CLIProxyAPI service..." >&2
  record_proxy_recovery "starting authenticated proxy recovery"
  stop_unhealthy_managed_proxy
  proxy_config="${CLAUDEX_PROXY_CONFIG:-$CLAUDE_CONFIG_DIR/cliproxyapi.yaml}"
  homebrew_proxy_config=""
  if command -v brew >/dev/null 2>&1; then
    homebrew_proxy_config="$(brew --prefix)/etc/cliproxyapi.conf"
  fi
  if command -v brew >/dev/null 2>&1 \
      && brew list --formula cliproxyapi >/dev/null 2>&1 \
      && { [[ ! -r "$proxy_config" ]] || [[ "$proxy_config" == "$homebrew_proxy_config" ]]; }; then
    if ! brew services start cliproxyapi >/dev/null; then
      record_proxy_recovery "Homebrew proxy service failed to start"
      release_proxy_lock "$lock_dir" "$owner_nonce"
      trap - EXIT
      return 1
    fi
  else
    proxy_bin=$(proxy_executable) || {
      record_proxy_recovery "proxy executable is missing"
      printf '%s\n' "claudex: CLIProxyAPI is not reachable and no proxy executable was found." >&2
      release_proxy_lock "$lock_dir" "$owner_nonce"
      trap - EXIT
      return 1
    }
    log_dir="$CLAUDE_CONFIG_DIR/logs"
    mkdir -p "$log_dir"
    (
      # CLIProxyAPI is a long-lived infrastructure process, not a managed
      # Claude session. Match the PowerShell launch boundary and keep caller
      # credentials, model routing, and runtime preloads out of its environment.
      scrub_managed_session_environment
      scrub_competing_provider_routing
      unset BUN_OPTIONS CLAUDE_CODE_SUBAGENT_MODEL CLAUDEX_PROXY_TOKEN
      unset CLAUDEX_CONFIG_DIR CLAUDEX_CLAUDE_CONFIG_DIR CLAUDEX_INSTRUCTION_BRIDGE
      if [[ -r "$proxy_config" ]]; then
        exec nohup "$proxy_bin" -config "$proxy_config"
      else
        exec nohup "$proxy_bin"
      fi
    ) >"$log_dir/cliproxyapi.log" 2>&1 </dev/null &
    proxy_pid=$!
    if ! write_managed_proxy_pid "$proxy_pid"; then
      kill -TERM "$proxy_pid" 2>/dev/null || true
      sleep 0.1
      kill -KILL "$proxy_pid" 2>/dev/null || true
      wait "$proxy_pid" 2>/dev/null || true
      record_proxy_recovery "new proxy exited before managed PID metadata was established"
      release_proxy_lock "$lock_dir" "$owner_nonce"
      trap - EXIT
      return 1
    fi
  fi

  startup_deadline=$(( SECONDS + 10 ))
  while (( SECONDS < startup_deadline )); do
    if proxy_ready; then
      release_proxy_lock "$lock_dir" "$owner_nonce"
      trap - EXIT
      return 0
    elif (( $? == 41 )); then
      startup_auth_failures=$(( startup_auth_failures + 1 ))
      if (( startup_auth_failures >= 5 )); then
        record_proxy_recovery "new proxy repeatedly rejected the configured authentication token"
        [[ -z "${proxy_pid:-}" ]] || stop_unhealthy_managed_proxy
        release_proxy_lock "$lock_dir" "$owner_nonce"
        trap - EXIT
        return 1
      fi
    else
      startup_auth_failures=0
    fi
    sleep 0.1
  done
  record_proxy_recovery "proxy did not become semantically healthy within 10s"
  [[ -z "${proxy_pid:-}" ]] || stop_unhealthy_managed_proxy
  release_proxy_lock "$lock_dir" "$owner_nonce"
  trap - EXIT

  printf '%s\n' "claudex: local proxy did not become healthy. Run: claudex --doctor" >&2
  return 1
}

interactive_codex_login_allowed() {
  [[ "${CLAUDEX_DISABLE_INTERACTIVE_LOGIN:-0}" != 1 ]] || return 1
  case "${CI:-}" in
    ''|0|false|FALSE|no|NO) ;;
    *) return 1 ;;
  esac
  { [[ -t 0 && -t 1 ]] \
      || { [[ "${CLAUDEX_TEST_TTY_INPUT:-0}" == 1 ]] && [[ "${CLAUDEX_TEST_TTY_OUTPUT:-0}" == 1 ]]; }; }
}

# Only the foreground launcher may open Codex's browser sign-in. The proxy and
# auth watchers call ensure_proxy directly, so background recovery always stays
# prompt-free even when it inherits a terminal from the parent session.
ensure_proxy_for_launch() {
  local required_model="${1:-}" ensure_status=0 login_status=0
  if ensure_proxy; then return 0; else ensure_status=$?; fi
  if (( claudex_auth_sync_failed != 1 )); then return "$ensure_status"; fi
  case "$claudex_auth_sync_status" in
    11|13|14) ;;
    *) return "$ensure_status" ;;
  esac

  if (( claudex_interactive_login_attempted )); then
    printf '%s\n' 'claudex: Codex authentication is still unavailable after the sign-in attempt. Run `claudex --login` to retry.' >&2
    return "$ensure_status"
  fi
  if ! interactive_codex_login_allowed; then
    printf '%s\n' 'claudex: Codex sign-in is required. Run `claudex --login` in an interactive terminal, then retry.' >&2
    return "$ensure_status"
  fi

  claudex_interactive_login_attempted=1
  printf '%s\n' 'claudex: Codex sign-in is required. Opening the official Codex browser login...' >&2
  record_proxy_recovery 'foreground startup requested official Codex browser login'
  "$codex_session_helper" login || login_status=$?
  if (( login_status != 0 )); then
    record_proxy_recovery "foreground Codex browser login failed status=$login_status"
    printf '%s\n' 'claudex: Codex sign-in did not complete. Run `claudex --login` to retry.' >&2
    return "$login_status"
  fi

  ensure_status=0
  if [[ -n "$required_model" ]]; then
    ensure_proxy "$required_model" || ensure_status=$?
  else
    ensure_proxy || ensure_status=$?
  fi
  if (( ensure_status != 0 )); then
    printf '%s\n' 'claudex: Codex authentication is still unavailable after sign-in. Run `claudex --login` to retry.' >&2
    return "$ensure_status"
  fi
  record_proxy_recovery 'foreground Codex browser login synchronized successfully'
  return 0
}

run_claude_update_worker() {
  local claude_path="$1" update_dir="$2" stamp="$3" interval="$4"
  local now last=0 lock_dir="$update_dir/lock" lock_nonce completed temporary
  mkdir -p "$update_dir"
  now=$(date +%s)
  if [[ -r "$stamp" ]]; then read -r last < "$stamp" || last=0; fi
  [[ "$last" =~ ^[0-9]+$ ]] || last=0
  (( now - last >= interval )) || return 0

  # The worker publishes its own PID and process-start identity. A launcher
  # exiting between spawn and ownership publication can therefore leave only a
  # short ownerless generation, never a misleading parent-owned lock.
  if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_UPDATE_WORKER_ATTEMPT_FILE:-}" ]]; then
    printf 'start %s\n' "$$" >> "$CLAUDEX_TEST_UPDATE_WORKER_ATTEMPT_FILE"
  fi
  if ! acquire_owned_lock "$lock_dir" 5 0.02 3600; then
    if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_UPDATE_WORKER_ATTEMPT_FILE:-}" ]]; then
      printf 'blocked %s\n' "$$" >> "$CLAUDEX_TEST_UPDATE_WORKER_ATTEMPT_FILE"
    fi
    return 0
  fi
  lock_nonce="$owned_lock_nonce"
  trap 'release_owned_lock "$lock_dir" "$lock_nonce"' EXIT
  trap 'release_owned_lock "$lock_dir" "$lock_nonce"; exit 130' INT
  trap 'release_owned_lock "$lock_dir" "$lock_nonce"; exit 143' TERM

  # Another worker may have completed between the parent's cadence check and
  # lock acquisition. Recheck while serialized before invoking Claude.
  now=$(date +%s)
  last=0
  if [[ -r "$stamp" ]]; then read -r last < "$stamp" || last=0; fi
  [[ "$last" =~ ^[0-9]+$ ]] || last=0
  if (( now - last < interval )); then
    release_owned_lock "$lock_dir" "$lock_nonce"
    trap - EXIT INT TERM
    return 0
  fi

  # Claude's updater is a first-party maintenance route. Never project proxy,
  # provider, session, or credential state into the detached process.
  unset CLAUDEX_PROXY_TOKEN
  scrub_managed_session_environment
  scrub_competing_provider_routing
  unset CLAUDE_CODE_SUBAGENT_MODEL
  if "$claude_path" update; then
    completed=$(date +%s)
    temporary=$(mktemp "$update_dir/.last-success.XXXXXX")
    printf '%s\n' "$completed" > "$temporary"
    chmod 600 "$temporary" 2>/dev/null || true
    mv -f "$temporary" "$stamp"
  fi
  release_owned_lock "$lock_dir" "$lock_nonce"
  trap - EXIT INT TERM
}

maybe_update_claude() {
  [[ "$CLAUDEX_CLAUDE_AUTO_UPDATE" == on ]] || return 0
  [[ "${CLAUDEX_SKIP_AUTO_UPDATE:-0}" != 1 ]] || return 0
  command -v claude >/dev/null 2>&1 || return 0

  # Direct Chrome intentionally unsets CLAUDE_CONFIG_DIR. Update bookkeeping
  # always belongs to Claudex's stable private config root.
  local update_dir="$claudex_config_dir/update" stamp="$claudex_config_dir/update/last-success" now last=0
  now=$(date +%s)
  if [[ -r "$stamp" ]]; then
    read -r last < "$stamp" || last=0
  fi
  [[ "$last" =~ ^[0-9]+$ ]] || last=0
  (( now - last >= CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS )) || return 0
  mkdir -p "$update_dir"
  local claude_path
  claude_path=$(command -v claude)
  # Keep the updater alive when the invoking terminal closes and prevent it
  # from reading the interactive session. The worker owns all log redirection.
  (
    trap '' HUP
    run_claude_update_worker "$claude_path" "$update_dir" "$stamp" \
      "$CLAUDEX_CLAUDE_UPDATE_INTERVAL_SECONDS"
  ) </dev/null >"$update_dir/claude-update.log" 2>&1 &
}

maybe_self_update() {
  [[ "$CLAUDEX_AUTO_UPDATE" != off && -x "$self_update_helper" ]] || return 0
  [[ "${CLAUDEX_SKIP_AUTO_UPDATE:-0}" != 1 ]] || return 0
  local action=--check log_dir="$claudex_config_dir/update/claudex"
  [[ "$CLAUDEX_AUTO_UPDATE" == on ]] && action=--apply
  mkdir -p "$log_dir"
  CLAUDEX_UPDATE_BACKGROUND=1 CLAUDEX_UPDATE_INTERVAL_SECONDS="$CLAUDEX_UPDATE_INTERVAL_SECONDS" \
    nohup "$self_update_helper" "$action" --background </dev/null >"$log_dir/background.log" 2>&1 &
}

claude_supports() {
  local option="$1"
  printf '%s\n' "${claude_help_cache:-}" | awk -v wanted="$option" '
    {
      line = $0
      sub(/^[[:space:]]+/, "", line)
      count = split(line, fields, /[[:space:]]+/)
      for (i = 1; i <= count; i++) {
        candidate = fields[i]
        sub(/,$/, "", candidate)
        sub(/[= ].*$/, "", candidate)
        if (candidate !~ /^-/) break
        if (candidate == wanted) found = 1
      }
    }
    END { exit(found ? 0 : 1) }
  '
}

load_claude_capabilities() {
  command -v claude >/dev/null 2>&1 || {
    printf '%s\n' 'claudex: Claude Code was not found. Install Claude Code and retry.' >&2
    return 1
  }
  claude_help_cache=$(claude --help 2>/dev/null || true)
  [[ -n "$claude_help_cache" ]] || {
    printf '%s\n' 'claudex: Claude Code did not return its capability list.' >&2
    return 1
  }
  if ! claude_supports '--model'; then
    printf '%s\n' 'claudex: this Claude Code build does not support custom models; run `claude update`.' >&2
    return 1
  fi
}

ensure_auto_mode_rules() {
  # Claude Code replaces an autoMode array when settings provide that key.
  # Recompose from the current binary's defaults so Claudex's scoped additions
  # never discard new or existing upstream safety rules after an update.
  [[ "$settings_file" == "$claudex_config_dir/settings.json" ]] || return 0
  local defaults_json previous_defaults='{}' tmp_file snapshot_file snapshot_tmp defaults_are_fresh=0
  local lock_dir="$claudex_config_dir/run/auto-mode.lock"
  acquire_state_lock "$lock_dir" || return 0
  snapshot_file="$claudex_config_dir/auto-mode-defaults.json"
  if [[ -s "$snapshot_file" ]] && jq -e '
    (.allow | type == "array") and
    (.environment | type == "array") and
    (.soft_deny | type == "array") and
    (.hard_deny | type == "array")
  ' "$snapshot_file" >/dev/null 2>&1; then
    previous_defaults=$(<"$snapshot_file")
  fi
  if defaults_json=$(claude auto-mode defaults 2>/dev/null) && printf '%s\n' "$defaults_json" | jq -e '
      (.allow | type == "array") and
      (.environment | type == "array") and
      (.soft_deny | type == "array") and
      (.hard_deny | type == "array")
    ' >/dev/null 2>&1; then
    defaults_are_fresh=1
  elif [[ "$previous_defaults" != '{}' ]]; then
    defaults_json="$previous_defaults"
  else
    # Older Claudex releases shipped only the managed allow/environment
    # additions. Because Claude Code replaces a configured array wholesale,
    # leaving those partial arrays active after an upstream-defaults failure
    # would discard every upstream exception and make auto mode fail closed in
    # surprising ways. Remove only that recognizable legacy seed; never erase
    # user-authored rules when their provenance cannot be established.
    tmp_file=$(mktemp "$claudex_config_dir/settings.json.tmp.XXXXXX")
    if jq '
      def managed_allow:
        startswith("Explicit Action Approval:") or startswith("Requested Agent Configuration:");
      def managed_environment:
        startswith("User designated task boundary:") or startswith("Explicitly approved development transfer:");
      (.autoMode // {}) as $auto
      | if all($auto.allow[]?; managed_allow)
          and all($auto.environment[]?; managed_environment)
          and (($auto.soft_deny // []) | length) == 0
          and (($auto.hard_deny // []) | length) == 0
        then del(.autoMode.allow, .autoMode.environment)
          | if ((.autoMode // {}) | length) == 0 then del(.autoMode) else . end
        else error("auto mode defaults unavailable with non-managed custom rules")
        end
    ' "$settings_file" > "$tmp_file" 2>/dev/null; then
      chmod 600 "$tmp_file" 2>/dev/null || true
      mv -f "$tmp_file" "$settings_file"
      release_state_lock "$lock_dir"
      return 0
    fi
    rm -f "$tmp_file"
    printf '%s\n' 'claudex: Claude Code auto mode defaults are unavailable; preserving custom rules and refusing an unsafe partial composition.' >&2
    printf '%s\n' 'claudex: update Claude Code or restore the auto mode defaults snapshot, then retry.' >&2
    release_state_lock "$lock_dir"
    return 1
  fi

  tmp_file=$(mktemp "$claudex_config_dir/settings.json.tmp.XXXXXX")
  if jq --argjson defaults "$defaults_json" \
      --argjson previous "$previous_defaults" \
      --arg approval 'Explicit Action Approval: A user message that explicitly approves a specific action and target, including reissuing it after a denial or unambiguously referring to the immediately preceding blocked action with language such as approve that, go ahead, or proceed, satisfies named and specific consent for matching SOFT BLOCK rules. Do not force the user to restate the command, ask for duplicate confirmation, or treat the prior denial as permanent. This does not override HARD BLOCK rules or authorize a broader action.' \
      --arg requested_config 'Requested Agent Configuration: Editing agent configuration is routine when the user explicitly asks for that specific configuration or permission change. Treat that edit as requested by the user rather than Self Modification; unrelated permission widening remains blocked.' \
      --arg task_boundary 'User designated task boundary: A repository, cloud project, host, bucket, service, or destination that the user explicitly identifies in their own message as owned or controlled infrastructure and as the intended target is trusted for the specifically requested operation and data flow only. Merely naming a target does not establish trust; do not infer trust for agent selected destinations, unrelated resources, or broader scopes.' \
      --arg approved_transfer 'Explicitly approved development transfer: When the user explicitly approves an exact transfer of only the source required for the task from the current trusted repository to an explicitly named private build or deployment host controlled by the user, treat that source and destination as inside the task trust boundary for that transfer only. Approval may unambiguously refer to the immediately preceding blocked command without repeating it. This never covers a public destination, credentials or secrets, unrelated files, a broader source tree, an agent selected target, or a different host.' \
      --arg transfer_soft 'Approved Private Development Transfer [named+specifics: must name the current source repository, the private build or deployment host controlled by the user, and the requested transfer]: Transferring only the source required for the task from the current trusted repository to that exact named private host requires the user to request or explicitly approve that transfer. Approval may unambiguously refer to the immediately preceding denied transfer. This consent never clears credentials or secrets, a public destination, unrelated files, a broader source tree, an agent selected target, or a different host.' \
      --arg hard_exception $'\n  - Claudex scoped private development transfer exception: Notwithstanding the bulk scale treatment above, an exact transfer of only the source required for the task from the current trusted repository to an explicitly named private build or deployment host controlled by the user is not HARD Data Exfiltration when the user requested or explicitly approved that exact source, destination, and transfer. Evaluate it under Approved Private Development Transfer as named and specific SOFT consent. The exception never covers credentials or secrets, a public destination, unrelated files, a broader source tree, an agent selected target, or a different host; if any condition is missing, the HARD rule remains in force.' '
        def stable_unique:
          reduce .[] as $item ([]; if index($item) == null then . + [$item] else . end);
        .autoMode = (.autoMode // {})
        | ($previous.allow // []) as $previous_allow
        | ($previous.environment // []) as $previous_environment
        | ($previous.soft_deny // []) as $previous_soft_deny
        | ($previous.hard_deny // []) as $previous_hard_deny
        | ((.autoMode.allow // []) | map(. as $rule | select(
            ((startswith("Explicit Action Approval:") or startswith("Requested Agent Configuration:")) | not)
            and (($previous_allow | index($rule)) == null)
          ))) as $custom_allow
        | ((.autoMode.environment // []) | map(. as $rule | select(
            ((startswith("User designated task boundary:") or startswith("Explicitly approved development transfer:")) | not)
            and (($previous_environment | index($rule)) == null)
          ))) as $custom_environment
        | ((.autoMode.soft_deny // []) | map(. as $rule | select(
            (startswith("Approved Private Development Transfer") | not)
            and (($previous_soft_deny | index($rule)) == null)
          ))) as $custom_soft_deny
        | ((.autoMode.hard_deny // []) | map(. as $rule | select(
            (contains("Claudex scoped private development transfer exception:") | not)
            and (($previous_hard_deny | index($rule)) == null)
          ))) as $custom_hard_deny
        | ($defaults.hard_deny | map(
            if startswith("Data Exfiltration:") then . + $hard_exception else . end
          )) as $managed_hard_deny
        | .autoMode.allow = (($defaults.allow + $custom_allow + [$approval, $requested_config]) | stable_unique)
        | .autoMode.environment = (($defaults.environment + $custom_environment + [$task_boundary, $approved_transfer]) | stable_unique)
        | .autoMode.soft_deny = (($defaults.soft_deny + $custom_soft_deny + [$transfer_soft]) | stable_unique)
        | .autoMode.hard_deny = (($managed_hard_deny + $custom_hard_deny) | stable_unique)
      ' "$settings_file" > "$tmp_file"; then
    if cmp -s "$tmp_file" "$settings_file"; then
      rm -f "$tmp_file"
    else
      chmod 600 "$tmp_file" 2>/dev/null || true
      mv -f "$tmp_file" "$settings_file"
    fi
  else
    rm -f "$tmp_file"
    release_state_lock "$lock_dir"
    return 0
  fi

  if (( defaults_are_fresh )); then
    snapshot_tmp=$(mktemp "$claudex_config_dir/.auto-mode-defaults.XXXXXX")
    printf '%s\n' "$defaults_json" | jq '.' > "$snapshot_tmp"
    chmod 600 "$snapshot_tmp" 2>/dev/null || true
    mv -f "$snapshot_tmp" "$snapshot_file"
  fi
  release_state_lock "$lock_dir"
}


current_shell_pid() {
  local destination="$1"
  # Bash 3.2 does not expose BASHPID. A short-lived child reports the real PID
  # of whichever launcher or detached worker directly spawned it.
  sh -c 'printf "%s\n" "$PPID" > "$1"' claudex-pid "$destination"
}

process_identity() {
  local pid="$1" identity="" stat_line=""
  if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_PROCESS_IDENTITY:-}" ]]; then
    printf '%s\n' "$CLAUDEX_TEST_PROCESS_IDENTITY"
    return 0
  fi
  # Linux exposes a boot-relative process start tick even when ps is missing or
  # denied by a sandbox. Strip the parenthesized command from /proc/PID/stat;
  # starttime is field 20 of the remaining sequence (field 22 overall).
  if [[ -r "/proc/$pid/stat" ]]; then
    IFS= read -r stat_line < "/proc/$pid/stat" || stat_line=""
    stat_line="${stat_line##*) }"
    if [[ -n "$stat_line" ]]; then
      set -- $stat_line
      if (( $# >= 20 )) && [[ "${20}" =~ ^[0-9]+$ ]]; then
        printf 'proc:%s\n' "${20}"
        return 0
      fi
    fi
  fi
  identity=$(ps -p "$pid" -o lstart= 2>/dev/null | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]][[:space:]]*/ /g' || true)
  if [[ -n "$identity" ]]; then
    printf '%s\n' "$identity"
    return 0
  fi
  return 1
}

lock_age_seconds() {
  local path="$1" mtime=0 now
  if stat -f '%m' "$path" >/dev/null 2>&1; then
    mtime=$(stat -f '%m' "$path")
  else
    mtime=$(stat -c '%Y' "$path" 2>/dev/null || printf 0)
  fi
  now=$(date +%s)
  if [[ "$mtime" =~ ^[0-9]+$ && "$now" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$(( now - mtime ))"
  else
    printf '%s\n' 0
  fi
}

read_lock_field() {
  local owner_file="$1" field="$2"
  awk -F= -v field="$field" '$1 == field { sub(/^[^=]*=/, ""); print; exit }' "$owner_file" 2>/dev/null
}

lock_owner_is_current() {
  local owner_file="$1" pid identity current
  pid=$(read_lock_field "$owner_file" pid)
  identity=$(read_lock_field "$owner_file" identity)
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  # Identity lookup can be transiently denied. A live PID is fail-safe in that
  # case; reclaim only when a start identity is available and mismatched.
  [[ -n "$identity" ]] || return 0
  current=$(process_identity "$pid" || true)
  [[ -z "$current" || "$current" == "$identity" ]]
}

lock_barrier_exists() {
  local barrier
  for barrier in "$1".quarantine.*; do [[ -e "$barrier" ]] && return 0; done
  return 1
}

lock_test_pause() {
  local stage="$1" lock_dir="$2" ready_variable continue_variable ready_file continue_file
  [[ "${CLAUDEX_TEST_MODE:-0}" == 1 ]] || return 0
  [[ -z "${CLAUDEX_TEST_LOCK_MATCH:-}" || "$lock_dir" == *"$CLAUDEX_TEST_LOCK_MATCH"* ]] || return 0
  ready_variable="CLAUDEX_TEST_LOCK_${stage}_READY"
  continue_variable="CLAUDEX_TEST_LOCK_${stage}_CONTINUE"
  ready_file="${!ready_variable:-}"
  continue_file="${!continue_variable:-}"
  [[ -n "$ready_file" && -n "$continue_file" ]] || return 0
  : > "$ready_file"
  while [[ ! -e "$continue_file" ]]; do sleep 0.02; done
}

read_generation_nonce() {
  local generation_file="$1/generation" nonce=""
  [[ -r "$generation_file" ]] || return 0
  IFS= read -r nonce < "$generation_file" || nonce=""
  printf '%s\n' "$nonce"
}

remove_lock_directory_files() {
  local directory="$1"
  rm -f "$directory/owner" "$directory/generation" 2>/dev/null || true
  rmdir "$directory" 2>/dev/null || true
}

read_legacy_lock_pid() {
  local directory="$1" file line pid
  for file in "$directory/owner" "$directory/owner-pid"; do
    [[ -r "$file" ]] || continue
    IFS= read -r line < "$file" || line=""
    pid="${line%%[[:space:]]*}"
    [[ "$pid" =~ ^[0-9]+$ ]] && { printf '%s\n' "$pid"; return 0; }
  done
  return 1
}

lock_directory_has_legacy_owner() {
  local directory="$1"
  [[ -e "$directory/owner-pid" ]] && return 0
  [[ -s "$directory/owner" && -z "$(read_lock_field "$directory/owner" nonce)" ]]
}

lock_directory_has_unknown_entries() {
  local directory="$1" entry base
  for entry in "$directory"/* "$directory"/.[!.]* "$directory"/..?*; do
    [[ -e "$entry" ]] || continue
    base="${entry##*/}"
    [[ "$base" == owner || "$base" == owner-pid || "$base" == generation ]] || return 0
  done
  return 1
}

lock_directory_identity() {
  local directory="$1" identity=""
  [[ -d "$directory" ]] || return 1
  identity=$(stat -c '%d:%i' -- "$directory" 2>/dev/null || true)
  if [[ ! "$identity" =~ ^[0-9]+:[0-9]+$ ]]; then
    identity=$(stat -f '%d:%i' "$directory" 2>/dev/null || true)
  fi
  [[ "$identity" =~ ^[0-9]+:[0-9]+$ ]] || return 1
  printf '%s\n' "$identity"
}

remove_legacy_lock_directory_files() {
  local directory="$1"
  rm -f "$directory/owner" "$directory/owner-pid" "$directory/generation" 2>/dev/null || true
  rmdir "$directory" 2>/dev/null || true
}

publish_lock_file() {
  local source="$1" destination="$2"
  if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && "${CLAUDEX_TEST_FORCE_PUBLICATION_FAILURE:-0}" == 1 ]]; then
    if [[ -z "${CLAUDEX_TEST_FORCE_PUBLICATION_FAILURE_MATCH:-}" \
        || "$destination" == *"$CLAUDEX_TEST_FORCE_PUBLICATION_FAILURE_MATCH"* ]]; then
      return 1
    fi
  fi
  if [[ "${CLAUDEX_TEST_MODE:-0}" != 1 || "${CLAUDEX_TEST_FORCE_HARDLINK_FAILURE:-0}" != 1 ]]; then
    ln "$source" "$destination" 2>/dev/null && return 0
  fi
  # FileMode CreateNew/O_EXCL is the portable fallback for filesystems that do
  # not implement hard links. Keep the descriptor open while copying so a
  # concurrent directory rename cannot redirect the write into a new owner.
  (
    set -C
    umask 077
    exec 9> "$destination" || exit 1
    cat "$source" >&9
  ) 2>/dev/null
}

remove_incomplete_lock_directory() {
  local lock_dir="$1" expected_nonce="${2:-}" preserve_directory="${3:-0}"
  local quarantine moved_nonce owner_nonce legacy_pid legacy_owner_text=""
  [[ -d "$lock_dir" ]] || return 0
  quarantine="$lock_dir.quarantine.incomplete.$$.$RANDOM"
  mv "$lock_dir" "$quarantine" 2>/dev/null || return 1
  moved_nonce=$(read_generation_nonce "$quarantine")
  owner_nonce=$(read_lock_field "$quarantine/owner" nonce)
  [[ -n "$moved_nonce" ]] || moved_nonce="$owner_nonce"
  legacy_pid=$(read_legacy_lock_pid "$quarantine" || true)
  [[ ! -s "$quarantine/owner" ]] || legacy_owner_text=1
  [[ ! -s "$quarantine/owner-pid" ]] || legacy_owner_text=1
  if [[ "$preserve_directory" == 1 ]]; then
    if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_LOCK_PRESERVE_FILE:-}" ]]; then
      : > "$CLAUDEX_TEST_LOCK_PRESERVE_FILE"
    fi
    if [[ -n "$expected_nonce" && "$moved_nonce" == "$expected_nonce" ]]; then
      rm -f "$quarantine/generation" 2>/dev/null || true
    fi
    if [[ -n "$expected_nonce" && "$owner_nonce" == "$expected_nonce" ]]; then
      rm -f "$quarantine/owner" 2>/dev/null || true
    fi
    restore_lock_barrier "$lock_dir" "$quarantine" || true
    return 1
  fi
  if lock_directory_has_legacy_owner "$quarantine" \
      || lock_directory_has_unknown_entries "$quarantine"; then
    if [[ -n "$expected_nonce" && "$moved_nonce" == "$expected_nonce" ]]; then
      rm -f "$quarantine/generation" 2>/dev/null || true
    fi
    if [[ -n "$expected_nonce" && "$owner_nonce" == "$expected_nonce" ]]; then
      rm -f "$quarantine/owner" 2>/dev/null || true
    fi
    restore_lock_barrier "$lock_dir" "$quarantine" || true
    return 1
  fi
  if [[ -n "$owner_nonce" && -n "$expected_nonce" && "$owner_nonce" == "$expected_nonce" \
      && "$moved_nonce" == "$expected_nonce" ]]; then
    remove_lock_directory_files "$quarantine"
    return 0
  fi
  if [[ -n "$moved_nonce" && "$moved_nonce" != "$expected_nonce" ]]; then
    restore_lock_barrier "$lock_dir" "$quarantine" || true
    return 1
  fi
  remove_lock_directory_files "$quarantine"
  [[ ! -e "$quarantine" ]]
}

restore_lock_barrier() {
  local lock_dir="$1" barrier="$2" attempt
  for attempt in {1..250}; do
    if [[ ! -e "$lock_dir" ]] && mv "$barrier" "$lock_dir" 2>/dev/null; then return 0; fi
    sleep 0.02
  done
  return 1
}

recover_lock_barriers() {
  local lock_dir="$1" legacy_ownerless_seconds="$2" barrier age nonce legacy_pid legacy_owner_present
  for barrier in "$lock_dir".quarantine.*; do
    [[ -d "$barrier" ]] || continue
    nonce=$(read_lock_field "$barrier/owner" nonce)
    legacy_pid=$(read_legacy_lock_pid "$barrier" || true)
    legacy_owner_present=0
    lock_directory_has_legacy_owner "$barrier" && legacy_owner_present=1
    age=$(lock_age_seconds "$barrier")
    if (( legacy_owner_present )); then
      # owner-pid is the prior-format source of truth. A structured owner and
      # generation beside it can only be an interrupted new creator, so remove
      # that injection before using the legacy PID's liveness and grace rules.
      rm -f "$barrier/generation" 2>/dev/null || true
      [[ -z "$nonce" ]] || rm -f "$barrier/owner" 2>/dev/null || true
      legacy_pid=$(read_legacy_lock_pid "$barrier" || true)
      if [[ -n "$legacy_pid" ]] && kill -0 "$legacy_pid" 2>/dev/null; then
        if [[ ! -e "$lock_dir" ]]; then mv "$barrier" "$lock_dir" 2>/dev/null || true; fi
      elif [[ -n "$legacy_pid" ]] && (( age >= legacy_ownerless_seconds )); then
        remove_legacy_lock_directory_files "$barrier"
      else
        if [[ ! -e "$lock_dir" ]]; then mv "$barrier" "$lock_dir" 2>/dev/null || true; fi
      fi
    elif [[ -n "$nonce" ]] && lock_owner_is_current "$barrier/owner"; then
      if [[ ! -e "$lock_dir" ]]; then mv "$barrier" "$lock_dir" 2>/dev/null || true; fi
    elif [[ -n "$nonce" && "$age" -ge 2 ]]; then
      remove_lock_directory_files "$barrier"
    elif [[ -n "$legacy_pid" && "$age" -ge "$legacy_ownerless_seconds" ]]; then
      remove_legacy_lock_directory_files "$barrier"
    elif [[ -n "$(read_generation_nonce "$barrier")" && "$age" -ge 2 ]]; then
      remove_lock_directory_files "$barrier"
    elif [[ -z "$(read_generation_nonce "$barrier")" && "$age" -ge "$legacy_ownerless_seconds" ]]; then
      remove_lock_directory_files "$barrier"
    fi
  done
}

remove_owned_lock_generation() {
  local lock_dir="$1" expected_nonce="$2"
  local quarantine moved_nonce attempt current_nonce
  current_nonce=$(read_generation_nonce "$lock_dir")
  [[ -n "$current_nonce" ]] || current_nonce=$(read_lock_field "$lock_dir/owner" nonce)
  [[ -n "$expected_nonce" && "$current_nonce" == "$expected_nonce" ]] || return 1
  quarantine="$lock_dir.quarantine.$$.$RANDOM"
  lock_test_pause BEFORE_RENAME "$lock_dir"
  mv "$lock_dir" "$quarantine" 2>/dev/null || return 1
  lock_test_pause AFTER_RENAME "$lock_dir"
  [[ -d "$quarantine" ]] || return 1
  moved_nonce=$(read_generation_nonce "$quarantine")
  [[ -n "$moved_nonce" ]] || moved_nonce=$(read_lock_field "$quarantine/owner" nonce)
  if lock_directory_has_legacy_owner "$quarantine" || lock_directory_has_unknown_entries "$quarantine"; then
    [[ "$moved_nonce" != "$expected_nonce" ]] || rm -f "$quarantine/generation" 2>/dev/null || true
    if [[ "$(read_lock_field "$quarantine/owner" nonce)" == "$expected_nonce" ]]; then
      rm -f "$quarantine/owner" 2>/dev/null || true
    fi
    restore_lock_barrier "$lock_dir" "$quarantine" || true
    return 1
  fi
  if [[ "$moved_nonce" == "$expected_nonce" ]]; then
    remove_lock_directory_files "$quarantine"
    return 0
  fi
  # The quarantine sibling is a global acquisition barrier. A contender that
  # appeared during the rename gap must abort before entering its critical
  # section; wait for it to withdraw, then restore the moved generation before
  # the barrier path disappears.
  restore_lock_barrier "$lock_dir" "$quarantine" || true
  # Fail safe: leaving the barrier blocks new acquisitions and lets a later
  # recovery pass restore or retire the proven generation.
  return 1
}

recover_owned_lock_generation() {
  local lock_dir="$1" expected_nonce="$2" barrier moved_nonce current_nonce
  for barrier in "$lock_dir".quarantine.*; do
    [[ -d "$barrier" ]] || continue
    moved_nonce=$(read_generation_nonce "$barrier")
    [[ -n "$moved_nonce" ]] || moved_nonce=$(read_lock_field "$barrier/owner" nonce)
    [[ "$moved_nonce" == "$expected_nonce" ]] || continue
    if lock_directory_has_legacy_owner "$barrier" || lock_directory_has_unknown_entries "$barrier"; then
      rm -f "$barrier/generation" 2>/dev/null || true
      if [[ "$(read_lock_field "$barrier/owner" nonce)" == "$expected_nonce" ]]; then
        rm -f "$barrier/owner" 2>/dev/null || true
      fi
      if [[ ! -e "$lock_dir" ]]; then mv "$barrier" "$lock_dir" 2>/dev/null || true; fi
      continue
    fi
    if [[ ! -e "$lock_dir" ]]; then mv "$barrier" "$lock_dir" 2>/dev/null || true; fi
  done
  current_nonce=$(read_generation_nonce "$lock_dir")
  [[ -n "$current_nonce" ]] || current_nonce=$(read_lock_field "$lock_dir/owner" nonce)
  if [[ "$current_nonce" == "$expected_nonce" ]] && ! lock_barrier_exists "$lock_dir"; then
    if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_LOCK_SELF_RECOVERED_FILE:-}" ]]; then
      : > "$CLAUDEX_TEST_LOCK_SELF_RECOVERED_FILE"
    fi
    return 0
  fi
  # This contender can safely retire only its own proven generation. Doing so
  # prevents a live orphan barrier when another barrier or canonical owner won.
  if [[ "$current_nonce" == "$expected_nonce" ]]; then
    remove_owned_lock_generation "$lock_dir" "$expected_nonce" || true
  fi
  for barrier in "$lock_dir".quarantine.*; do
    [[ -d "$barrier" ]] || continue
    moved_nonce=$(read_generation_nonce "$barrier")
    [[ -n "$moved_nonce" ]] || moved_nonce=$(read_lock_field "$barrier/owner" nonce)
    if [[ "$moved_nonce" == "$expected_nonce" ]] \
        && ! lock_directory_has_legacy_owner "$barrier" \
        && ! lock_directory_has_unknown_entries "$barrier"; then
      remove_lock_directory_files "$barrier"
    fi
  done
  return 1
}

owned_lock_directory=""
owned_lock_nonce=""
acquire_owned_lock() {
  local lock_dir="$1" attempts="${2:-100}" delay="${3:-0.02}" legacy_ownerless_seconds="${4:-60}"
  local attempt owner_file observed_nonce age pid_file owner_pid owner_identity owner_tmp generation_tmp generation_nonce quarantine
  local publication_ok generation_published owner_published legacy_pid legacy_owner_present
  local directory_identity current_directory_identity directory_replaced
  owned_lock_directory=""
  owned_lock_nonce=""
  owner_file="$lock_dir/owner"
  mkdir -p "$(dirname "$lock_dir")"
  for (( attempt=0; attempt<attempts; attempt++ )); do
    recover_lock_barriers "$lock_dir" "$legacy_ownerless_seconds"
    if lock_barrier_exists "$lock_dir"; then sleep "$delay"; continue; fi

    pid_file=$(mktemp "$(dirname "$lock_dir")/.lock-owner-pid.XXXXXX")
    current_shell_pid "$pid_file"
    read -r owner_pid < "$pid_file"
    rm -f "$pid_file"
    owner_identity=$(process_identity "$owner_pid" || true)
    generation_nonce="${owner_pid}.$(date +%s).${RANDOM}.${RANDOM}"
    generation_tmp=$(mktemp "$(dirname "$lock_dir")/.lock-generation.XXXXXX")
    owner_tmp=$(mktemp "$(dirname "$lock_dir")/.lock-owner.XXXXXX")
    printf '%s\n' "$generation_nonce" > "$generation_tmp"
    {
      printf 'pid=%s\n' "$owner_pid"
      printf 'identity=%s\n' "$owner_identity"
      printf 'nonce=%s\n' "$generation_nonce"
    } > "$owner_tmp"
    chmod 600 "$generation_tmp" "$owner_tmp" 2>/dev/null || true
    if mkdir "$lock_dir" 2>/dev/null; then
      directory_identity=$(lock_directory_identity "$lock_dir" || true)
      lock_test_pause AFTER_MKDIR "$lock_dir"
      publication_ok=0
      generation_published=0
      owner_published=0
      directory_replaced=0
      current_directory_identity=$(lock_directory_identity "$lock_dir" || true)
      [[ -n "$directory_identity" && "$current_directory_identity" == "$directory_identity" ]] \
        || directory_replaced=1
      if (( ! directory_replaced )); then
        if publish_lock_file "$generation_tmp" "$lock_dir/generation"; then
          generation_published=1
          if [[ "$(lock_directory_identity "$lock_dir" || true)" == "$directory_identity" ]] \
              && [[ "$(read_generation_nonce "$lock_dir")" == "$generation_nonce" ]]; then
            if publish_lock_file "$owner_tmp" "$owner_file"; then
              owner_published=1
              if [[ "$(lock_directory_identity "$lock_dir" || true)" == "$directory_identity" ]] \
                  && [[ "$(read_lock_field "$owner_file" nonce)" == "$generation_nonce" ]] \
                  && ! lock_barrier_exists "$lock_dir" \
                  && ! lock_directory_has_legacy_owner "$lock_dir" \
                  && ! lock_directory_has_unknown_entries "$lock_dir"; then
                publication_ok=1
              fi
            fi
          fi
        fi
      fi
      if (( publication_ok )); then
        rm -f "$generation_tmp" "$owner_tmp"
        owned_lock_nonce="$generation_nonce"
        owned_lock_directory="$lock_dir"
        lock_test_pause AFTER_PUBLISH "$lock_dir"
        if [[ "$(lock_directory_identity "$lock_dir" || true)" != "$directory_identity" ]] \
            || [[ "$(read_generation_nonce "$lock_dir")" != "$generation_nonce" ]] \
            || lock_barrier_exists "$lock_dir" || lock_directory_has_legacy_owner "$lock_dir" \
            || lock_directory_has_unknown_entries "$lock_dir"; then
          if [[ "$(lock_directory_identity "$lock_dir" || true)" != "$directory_identity" ]]; then
            if recover_owned_lock_generation "$lock_dir" "$generation_nonce" \
                && [[ "$(lock_directory_identity "$lock_dir" || true)" == "$directory_identity" ]]; then
              return 0
            fi
            if [[ "$(read_generation_nonce "$lock_dir")" == "$generation_nonce" ]] \
                || [[ "$(read_lock_field "$lock_dir/owner" nonce)" == "$generation_nonce" ]]; then
              remove_incomplete_lock_directory "$lock_dir" "$generation_nonce" 1 || true
            fi
            owned_lock_nonce=""
            owned_lock_directory=""
            sleep "$delay"
            continue
          fi
          if lock_directory_has_legacy_owner "$lock_dir" \
              || lock_directory_has_unknown_entries "$lock_dir"; then
            remove_incomplete_lock_directory "$lock_dir" "$generation_nonce" || true
            owned_lock_nonce=""
            owned_lock_directory=""
            sleep "$delay"
            continue
          fi
          if recover_owned_lock_generation "$lock_dir" "$generation_nonce"; then return 0; fi
          owned_lock_nonce=""
          owned_lock_directory=""
          sleep "$delay"
          continue
        fi
        if [[ "${CLAUDEX_TEST_MODE:-0}" == 1 && -n "${CLAUDEX_TEST_LOCK_SELF_RECOVERED_FILE:-}" ]]; then
          : > "$CLAUDEX_TEST_LOCK_SELF_RECOVERED_FILE"
        fi
        return 0
      fi
      rm -f "$generation_tmp" "$owner_tmp"
      if (( directory_replaced )) \
          || [[ "$(lock_directory_identity "$lock_dir" || true)" != "$directory_identity" ]]; then
        if (( generation_published || owner_published )); then
          remove_incomplete_lock_directory "$lock_dir" "$generation_nonce" 1 || true
        fi
      elif lock_directory_has_legacy_owner "$lock_dir" || lock_directory_has_unknown_entries "$lock_dir"; then
        remove_incomplete_lock_directory "$lock_dir" "$generation_nonce" || true
      elif (( owner_published )); then
        remove_owned_lock_generation "$lock_dir" "$generation_nonce" \
          || remove_incomplete_lock_directory "$lock_dir" "$generation_nonce" || true
      else
        remove_incomplete_lock_directory "$lock_dir" "$generation_nonce" || true
      fi
      sleep "$delay"
      continue
    fi
    rm -f "$generation_tmp" "$owner_tmp"

    age=$(lock_age_seconds "$lock_dir")
    observed_nonce=$(read_lock_field "$owner_file" nonce)
    legacy_pid=$(read_legacy_lock_pid "$lock_dir" || true)
    legacy_owner_present=0
    lock_directory_has_legacy_owner "$lock_dir" && legacy_owner_present=1
    if (( legacy_owner_present )) && [[ -n "$observed_nonce" ]]; then
      # A prior-format owner replaced the directory while a new creator was
      # publishing. Quarantine the mixed state, strip only the injected
      # structured generation, then apply the legacy owner's original age.
      quarantine="$lock_dir.quarantine.legacy.$$.$RANDOM"
      if mv "$lock_dir" "$quarantine" 2>/dev/null; then
        if lock_directory_has_legacy_owner "$quarantine"; then
          [[ "$(read_generation_nonce "$quarantine")" != "$observed_nonce" ]] \
            || rm -f "$quarantine/generation" 2>/dev/null || true
          [[ "$(read_lock_field "$quarantine/owner" nonce)" != "$observed_nonce" ]] \
            || rm -f "$quarantine/owner" 2>/dev/null || true
          legacy_pid=$(read_legacy_lock_pid "$quarantine" || true)
          if [[ -n "$legacy_pid" ]] && kill -0 "$legacy_pid" 2>/dev/null; then
            restore_lock_barrier "$lock_dir" "$quarantine" || true
          elif [[ -n "$legacy_pid" ]] && (( age >= legacy_ownerless_seconds )); then
            remove_legacy_lock_directory_files "$quarantine"
          else
            restore_lock_barrier "$lock_dir" "$quarantine" || true
          fi
        else
          restore_lock_barrier "$lock_dir" "$quarantine" || true
        fi
      fi
    elif [[ -n "$legacy_pid" ]] && kill -0 "$legacy_pid" 2>/dev/null; then
      : # A prior-format live owner is never reclaimed solely because it is old.
    elif (( legacy_owner_present )) && [[ -n "$legacy_pid" ]] && (( age >= legacy_ownerless_seconds )); then
      quarantine="$lock_dir.quarantine.legacy.$$.$RANDOM"
      if mv "$lock_dir" "$quarantine" 2>/dev/null; then
        legacy_pid=$(read_legacy_lock_pid "$quarantine" || true)
        if [[ -n "$legacy_pid" ]] && kill -0 "$legacy_pid" 2>/dev/null; then
          restore_lock_barrier "$lock_dir" "$quarantine" || true
        else
          remove_legacy_lock_directory_files "$quarantine"
        fi
      fi
    elif (( legacy_owner_present )); then
      : # Unknown or recent prior formats are preserved conservatively.
    elif [[ -n "$observed_nonce" ]]; then
      if ! lock_owner_is_current "$owner_file" && (( age >= 2 )); then
        remove_owned_lock_generation "$lock_dir" "$observed_nonce" || true
      fi
    elif [[ -n "$(read_generation_nonce "$lock_dir")" ]] && (( age >= 2 )); then
      observed_nonce=$(read_generation_nonce "$lock_dir")
      remove_owned_lock_generation "$lock_dir" "$observed_nonce" || true
    elif (( age >= legacy_ownerless_seconds )); then
      # A directory without a generation marker belongs to a pre-ownership
      # release. Preserve its historical stale threshold during upgrades.
      quarantine="$lock_dir.quarantine.legacy.$$.$RANDOM"
      if mv "$lock_dir" "$quarantine" 2>/dev/null; then
        legacy_pid=$(read_legacy_lock_pid "$quarantine" || true)
        if [[ -n "$(read_generation_nonce "$quarantine")" || -n "$(read_lock_field "$quarantine/owner" nonce)" ]] \
            || { [[ -n "$legacy_pid" ]] && kill -0 "$legacy_pid" 2>/dev/null; } \
            || lock_directory_has_unknown_entries "$quarantine"; then
          restore_lock_barrier "$lock_dir" "$quarantine" || true
        elif [[ -n "$legacy_pid" ]]; then
          remove_legacy_lock_directory_files "$quarantine"
        else
          remove_lock_directory_files "$quarantine"
        fi
      fi
    fi
    sleep "$delay"
  done
  return 1
}

release_owned_lock() {
  local lock_dir="$1" nonce="$2"
  [[ -n "$lock_dir" && -n "$nonce" ]] || return 0
  remove_owned_lock_generation "$lock_dir" "$nonce" || true
}

state_lock_nonce=""
acquire_state_lock() {
  state_lock_nonce=""
  acquire_owned_lock "$1" 100 0.02 || return 1
  state_lock_nonce="$owned_lock_nonce"
}

release_state_lock() {
  release_owned_lock "$1" "$state_lock_nonce"
  state_lock_nonce=""
}

# Claude Code's welcome banner does not use ANTHROPIC_CUSTOM_MODEL_OPTION_NAME.
# Seed its isolated model-option cache so custom GPT IDs have friendly names in
# both the banner and model picker. Preserve unrelated cached options.
ensure_model_display_names() {
  local state_file="$CLAUDE_CONFIG_DIR/.claude.json"
  local tmp_file lock_dir="$CLAUDE_CONFIG_DIR/run/model-display.lock"
  local managed_options='[
    {"value":"opusplan","label":"GPT-5.6 Solplan","description":"GPT-5.6 Sol in plan mode, GPT-5.6 Terra for implementation"},
    {"value":"gpt-5.6-sol","label":"GPT-5.6 Sol","description":"Frontier capability for planning and the hardest engineering work"},
    {"value":"gpt-5.6-terra","label":"GPT-5.6 Terra","description":"Balanced intelligence, speed, and cost for everyday coding"},
    {"value":"gpt-5.6-luna","label":"GPT-5.6 Luna","description":"Fast, efficient model for search, triage, and mechanical tasks"}
  ]'

  acquire_state_lock "$lock_dir" || return 0
  if [[ -s "$state_file" ]] && jq -e --argjson managed "$managed_options" '
    . as $root
    | all($managed[] as $expected;
        [$root.additionalModelOptionsCache[]? | select(.value == $expected.value)] as $matches
        | ($matches | length) == 1
        and $matches[0].label == $expected.label
        and $matches[0].description == $expected.description)
  ' "$state_file" >/dev/null 2>&1; then
    release_state_lock "$lock_dir"
    return 0
  fi

  mkdir -p "$CLAUDE_CONFIG_DIR"
  tmp_file=$(mktemp "$CLAUDE_CONFIG_DIR/.claude.json.tmp.XXXXXX")
  if [[ -s "$state_file" ]] && jq -e 'type == "object"' "$state_file" >/dev/null 2>&1; then
    if ! jq --argjson managed "$managed_options" '
      ($managed | map(.value)) as $managed_ids
      | .additionalModelOptionsCache = (
          ((.additionalModelOptionsCache // [])
            | map(.value as $value | select(($managed_ids | index($value)) == null)))
          + $managed
        )
    ' "$state_file" > "$tmp_file"; then
      rm -f "$tmp_file"
      release_state_lock "$lock_dir"
      return 0
    fi
  else
    if ! jq -n --argjson managed "$managed_options" \
      '{additionalModelOptionsCache: $managed}' > "$tmp_file"; then
      rm -f "$tmp_file"
      release_state_lock "$lock_dir"
      return 0
    fi
  fi
  mv -f "$tmp_file" "$state_file"
  release_state_lock "$lock_dir"
}

if (( ! early_runtime_bypass )) || { [[ -r "$settings_file" ]] && command -v jq >/dev/null 2>&1; }; then
  ensure_model_display_names
fi

fetch_models() {
  local timeout_seconds="${1:-1}" response_file status_file request_pid timer_pid request_status=0
  local http_status status_output
  local run_dir="$claudex_config_dir/run"
  mkdir -p "$run_dir"
  response_file=$(mktemp "$run_dir/.proxy-health.XXXXXX")
  status_file=$(mktemp "$run_dir/.proxy-health-status.XXXXXX")
  chmod 600 "$response_file" 2>/dev/null || true
  chmod 600 "$status_file" 2>/dev/null || true

  "$curl_bin" --silent --show-error \
    --connect-timeout 0.5 --max-time "$timeout_seconds" \
    --header @<(printf 'Authorization: Bearer %s\n' "$CLAUDEX_PROXY_TOKEN") \
    --output "$response_file" --write-out '%{http_code}' \
    "${CLAUDEX_PROXY_URL%/}/v1/models" > "$status_file" &
  request_pid=$!
  (
    sleep "$timeout_seconds"
    kill -TERM "$request_pid" 2>/dev/null || exit 0
    sleep 0.1
    kill -KILL "$request_pid" 2>/dev/null || true
  ) &
  timer_pid=$!
  wait "$request_pid" || request_status=$?
  kill "$timer_pid" 2>/dev/null || true
  wait "$timer_pid" 2>/dev/null || true

  if (( request_status != 0 )); then
    rm -f "$response_file" "$status_file"
    return "$request_status"
  fi
  status_output=$(<"$status_file")
  # Test doubles and curl-compatible wrappers may ignore --output/--write-out
  # and emit the body on stdout. Accept that shape without weakening real HTTP
  # status validation.
  if [[ ! -s "$response_file" && "$status_output" == \{* ]]; then
    printf '%s\n' "$status_output" > "$response_file"
    http_status=200
  else
    http_status="${status_output##*$'\n'}"
  fi
  rm -f "$status_file"
  case "$http_status" in
    2??) cat "$response_file"; rm -f "$response_file"; return 0 ;;
    401|403) rm -f "$response_file"; return 41 ;;
    *) rm -f "$response_file"; return 42 ;;
  esac
}

models_are_valid() {
  jq -e '[.data[]?.id | select(type == "string" and length > 0)] | length > 0' >/dev/null 2>&1
}

proxy_ready() {
  local models fetch_status=0
  models=$(fetch_models 1 2>/dev/null) || fetch_status=$?
  (( fetch_status == 0 )) || return "$fetch_status"
  printf '%s\n' "$models" | models_are_valid || return 43
}

model_is_advertised() {
  local selected_model="$1" models="$2" required_models
  case "$selected_model" in
    opusplan) required_models='["gpt-5.6-sol", "gpt-5.6-terra"]' ;;
    *) required_models=$(printf '["%s"]' "$selected_model") ;;
  esac
  printf '%s\n' "$models" | jq -e --argjson required "$required_models" '
    [.data[]?.id] as $ids
    | [$required[] as $model | select(($ids | index($model)) == null)]
    | length == 0
  ' >/dev/null 2>&1
}

normalize_managed_model() {
  case "$1" in
    gpt-5.6-sol|opus|fable) printf '%s\n' gpt-5.6-sol ;;
    gpt-5.6-terra|sonnet) printf '%s\n' gpt-5.6-terra ;;
    gpt-5.6-luna|haiku) printf '%s\n' gpt-5.6-luna ;;
    opusplan) printf '%s\n' opusplan ;;
    *) return 1 ;;
  esac
}

launch_model_is_available() {
  local selected_model="$1" fallback_models="${2:-}" models fetch_status=0 candidate normalized
  local fallback_candidates=()
  models=$(fetch_models 2) || fetch_status=$?
  (( fetch_status == 0 )) || return "$fetch_status"
  if model_is_advertised "$selected_model" "$models"; then return 0; fi
  IFS=',' read -r -a fallback_candidates <<< "$fallback_models"
  for candidate in ${fallback_candidates[@]+"${fallback_candidates[@]}"}; do
    candidate="${candidate#"${candidate%%[![:space:]]*}"}"
    candidate="${candidate%"${candidate##*[![:space:]]}"}"
    normalized=$(normalize_managed_model "$candidate" 2>/dev/null || true)
    [[ -n "$normalized" ]] || continue
    if model_is_advertised "$normalized" "$models"; then return 0; fi
  done
  return 44
}

proxy_reachable() {
  if [[ -n "${CLAUDEX_TEST_PROXY_REACHABLE_FILE:-}" ]]; then
    [[ -e "$CLAUDEX_TEST_PROXY_REACHABLE_FILE" ]]
    return
  fi
  proxy_ready
}

proxy_executable() {
  if [[ -n "${CLAUDEX_PROXY_BIN:-}" && -x "$CLAUDEX_PROXY_BIN" ]]; then
    printf '%s\n' "$CLAUDEX_PROXY_BIN"
  elif [[ -x "$CLAUDE_CONFIG_DIR/bin/cliproxyapi" ]]; then
    printf '%s\n' "$CLAUDE_CONFIG_DIR/bin/cliproxyapi"
  elif command -v cliproxyapi >/dev/null 2>&1; then
    command -v cliproxyapi
  elif command -v cli-proxy-api >/dev/null 2>&1; then
    command -v cli-proxy-api
  else
    return 1
  fi
}

start_auth_watcher() {

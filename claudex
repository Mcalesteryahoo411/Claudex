emit_skill_bridge_warnings() {
  local bridge_json="$1" warning_lines warning_count warning_digest
  local run_dir="$claudex_config_dir/run" state_file
  local now last_time=0 last_digest="" temporary=""
  state_file="$run_dir/skill-warning-state"
  warning_lines=$(printf '%s\n' "$bridge_json" | jq -r '
    [.warnings[]?
      | select(type == "string" and length > 0)
      | gsub("[[:cntrl:]]+"; " ")
      | gsub("[\u200B-\u200F\u202A-\u202E\u2060\u2066-\u2069\uFEFF]"; "")
      | gsub("  +"; " ")
      | gsub("^ +| +$"; "")
      | if length > 500 then .[0:500] + "..." else . end
      | select(length > 0)]
    | unique[]
  ')
  [[ -n "$warning_lines" ]] || return 0
  warning_count=$(printf '%s\n' "$warning_lines" | awk 'END { print NR }')
  warning_digest=$(printf '%s\n' "$warning_lines" | cksum | awk '{print $1 ":" $2}')
  now=$(date +%s)
  if [[ -r "$state_file" ]]; then
    read -r last_time last_digest < "$state_file" || { last_time=0; last_digest=""; }
  fi
  if [[ "$last_time" =~ ^[0-9]+$ ]] && (( last_time <= now && now - last_time < 300 )) \
      && [[ "$last_digest" == "$warning_digest" ]]; then
    return 0
  fi
  printf '%s\n' "$warning_lines" | sed -n '1,5{s/^/claudex: skill bridge warning: /;p;}' >&2
  if (( warning_count > 5 )); then
    printf 'claudex: skill bridge warning: %s additional unique warnings omitted.\n' "$(( warning_count - 5 ))" >&2
  fi
  if mkdir -p "$run_dir" 2>/dev/null; then
    temporary=$(mktemp "$run_dir/.skill-warning-state.XXXXXX" 2>/dev/null || true)
    if [[ -n "$temporary" ]]; then
      (umask 077; printf '%s %s\n' "$now" "$warning_digest" > "$temporary")
      chmod 600 "$temporary" 2>/dev/null || true
      mv -f "$temporary" "$state_file" 2>/dev/null || rm -f "$temporary"
    fi
  fi
}

skill_bridge_add_dirs=()
skill_bridge_plugin_dirs=()
if (( inject_skills )) && [[ "$CLAUDEX_SKILL_BRIDGE" == on ]]; then
  activate_managed_node
  node_supports_skill_bridge || { printf '%s\n' 'claudex: Node.js 18 or newer is required for Claude and Codex skill compatibility.' >&2; exit 1; }
  [[ -r "$skill_bridge_helper" ]] || { printf '%s\n' 'claudex: skill bridge helper is missing; reinstall Claudex.' >&2; exit 1; }
  skill_bridge_scope_args=()
  if (( parsed_worktree )); then skill_bridge_scope_args+=(--global-only); fi
  skill_bridge_json=$(node "$skill_bridge_helper" sync --project "$PWD" \
    ${skill_bridge_scope_args[@]+"${skill_bridge_scope_args[@]}"}) || {
    printf '%s\n' 'claudex: skill discovery failed; run `claudex skills` for details.' >&2
    exit 1
  }
  if ! printf '%s\n' "$skill_bridge_json" | jq -e '
      type == "object"
      and ((.addDirs // []) | type == "array")
      and ((.pluginDirs // []) | type == "array")
      and ((.instructions // []) | type == "array")
      and ((.warnings // []) | type == "array")
    ' >/dev/null 2>&1; then
    printf '%s\n' 'claudex: skill discovery returned an invalid response; run `claudex skills` for details.' >&2
    exit 1
  fi
  emit_skill_bridge_warnings "$skill_bridge_json"
  while IFS= read -r skill_directory; do
    [[ -z "$skill_directory" ]] || skill_bridge_add_dirs+=("$skill_directory")
  done < <(printf '%s\n' "$skill_bridge_json" | jq -r '.addDirs[]?')
  while IFS= read -r plugin_directory; do
    [[ -z "$plugin_directory" ]] || skill_bridge_plugin_dirs+=("$plugin_directory")
  done < <(printf '%s\n' "$skill_bridge_json" | jq -r '.pluginDirs[]?')
  if (( $(printf '%s\n' "$skill_bridge_json" | jq '(.instructions // []) | length') > 0 )); then
    # Claude Code normally ignores CLAUDE.md from --add-dir roots. The bridge's
    # generated overlay uses that file to carry snapshotted Codex instructions.
    export CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD=1
  fi
  if (( ${#skill_bridge_add_dirs[@]} > 0 )) && ! claude_supports '--add-dir'; then
    printf '%s\n' 'claudex: this Claude Code build lacks --add-dir, which is required for installed Codex skills; run `claude update`.' >&2
    exit 1
  fi
  if (( ${#skill_bridge_plugin_dirs[@]} > 0 )) && ! claude_supports '--plugin-dir'; then
    printf '%s\n' 'claudex: this Claude Code build lacks --plugin-dir, which is required for installed plugin skills; run `claude update`.' >&2
    exit 1
  fi
fi
if (( use_proxy )) || [[ "${forwarded_args[0]:-}" == auto-mode ]]; then ensure_auto_mode_rules; fi
case "${forwarded_args[0]:-}" in
  update|upgrade) ;;
  *) maybe_update_claude; maybe_self_update ;;
esac

if (( use_proxy )); then
  export CLAUDEX_MANAGED_SESSION=1
  ensure_proxy_for_launch "$start_model"
  selected_model_status=0
  launch_model_is_available "$start_model" "$forwarded_fallback_model" || selected_model_status=$?
  if (( selected_model_status != 0 && selected_model_status != 44 )); then
    # The bridge can exit after the initial semantic readiness check. Recover
    # transport failures once instead of misreporting them as a missing model.
    ensure_proxy_for_launch "$start_model"
    selected_model_status=0
    launch_model_is_available "$start_model" "$forwarded_fallback_model" || selected_model_status=$?
  fi
  if (( selected_model_status != 0 )); then
    if (( selected_model_status == 44 )); then
      printf '%s\n' "claudex: selected model '$start_model' and its managed fallbacks are not advertised by the authenticated Codex account." >&2
      printf '%s\n' 'claudex: choose an available managed model/fallback or run `claudex --doctor` for the full catalog check.' >&2
    else
      printf '%s\n' 'claudex: the local Codex bridge became unavailable while validating the selected model.' >&2
      printf '%s\n' 'claudex: run `claudex --doctor` and retry.' >&2
    fi
    exit 1
  fi
  auth_watcher_pid=""
  proxy_watcher_pid=""
  start_auth_watcher
  start_proxy_watcher

  prepare_chatgpt_plan_label

  export ANTHROPIC_BASE_URL="$CLAUDEX_PROXY_URL"
  export ANTHROPIC_AUTH_TOKEN="$CLAUDEX_PROXY_TOKEN"

# Map one Claude Code selector alias onto each GPT-5.6 model. Registering the
# same model through Fable, Opus, and the custom slot creates duplicate rows.
  export ANTHROPIC_DEFAULT_OPUS_MODEL="gpt-5.6-sol"
  export ANTHROPIC_DEFAULT_FABLE_MODEL="gpt-5.6-sol"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="gpt-5.6-terra"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="gpt-5.6-luna"
  export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="GPT-5.6 Sol"
  export ANTHROPIC_DEFAULT_FABLE_MODEL_NAME="GPT-5.6 Sol"
  export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="GPT-5.6 Terra"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="GPT-5.6 Luna"
  export ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION="Frontier capability for planning and the hardest engineering work"
  export ANTHROPIC_DEFAULT_FABLE_MODEL_DESCRIPTION="Frontier capability for planning and the hardest engineering work"
  export ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION="Balanced intelligence, speed, and cost for everyday coding"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL_DESCRIPTION="Fast, efficient model for search, triage, and mechanical tasks"

  readonly gpt56_capabilities="effort,xhigh_effort,max_effort,thinking,adaptive_thinking,interleaved_thinking"
  export ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"
  export ANTHROPIC_DEFAULT_FABLE_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"
  export ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES="$gpt56_capabilities"

# Claude Code otherwise chooses Sonnet 5 for an external-provider auto mode classifier,
# which Claudex maps to Terra. Pinning the classifier prevents misleading Terra outages.
  export CLAUDE_CODE_AUTO_MODE_MODEL="$CLAUDEX_AUTO_MODE_MODEL"
  export CLAUDE_CODE_BG_CLASSIFIER_MODEL="$CLAUDEX_BACKGROUND_MODEL"
  # Named managed agents carry their own model. Leave an explicit caller model
  # untouched so Claude Code's native routing remains available for every other
  # Agent invocation.
  export CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1
  export CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY="$CLAUDEX_MAX_TOOL_USE_CONCURRENCY"
  export CLAUDE_CODE_MAX_RETRIES="$CLAUDEX_MAX_RETRIES"

# Claude Code assumes unknown custom models have a 200k context window. Claudex's
# GPT-5.6 backend supports a larger window, so make the meter accurate and force
# client-side summarization before the session grows without bound.
  export CLAUDE_CODE_MAX_CONTEXT_TOKENS="$CLAUDEX_CONTEXT_WINDOW"
  export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$CLAUDEX_AUTO_COMPACT_WINDOW"
  # Claude Code's built-in 1M selector is an Anthropic model feature. Keeping
  # it visible on the Codex bridge can produce a misleading `/model opus 1m`
  # entry even though Claudex manages its own explicit context window.
  export CLAUDE_CODE_DISABLE_1M_CONTEXT=1
else
  unset ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN CLAUDEX_PROXY_TOKEN CLAUDE_CODE_DISABLE_1M_CONTEXT CLAUDEX_CHATGPT_PLAN_LABEL
fi

export CLAUDEX_USAGE_DISPLAY CLAUDEX_USAGE_REFRESH_SECONDS CLAUDEX_USAGE_TIMEOUT_SECONDS CLAUDEX_USAGE_MAX_STALE_SECONDS
export CLAUDEX_USAGE_SOURCE CLAUDEX_USAGE_ALERT_PERCENT
export CLAUDE_CODE_NO_FLICKER=1
export CLAUDE_CODE_ACCESSIBILITY=1

# One proxy credential backs all three aliases. Custom agents must not recursively
# spawn more agents, or a small parallel batch becomes a retry/429 storm.
readonly no_nested_agents="Do not spawn or delegate to additional agents, or send intermediate progress messages to the parent. Unless you are a teammate in a native Agent Team that the user explicitly requested, do not create, claim, or update entries in a shared task list; ordinary Agent task lifecycle belongs to the Sol leader. Complete the assigned task yourself and return one final result through the normal agent result channel. If the provider reports a 429 or model cooldown, do not launch a replacement agent or start a retry loop."
readonly claudex_agents="{\"Terra (high)\":{\"description\":\"Terra at high reasoning effort for delegated architecture, debugging, implementation, testing, security review, and other substantial engineering work.\",\"prompt\":\"You are GPT-5.6 Terra running at high reasoning effort. Investigate thoroughly, make robust focused progress, verify the result, and return concise findings backed by evidence. ${no_nested_agents}\",\"model\":\"gpt-5.6-terra\",\"effort\":\"high\"},\"Luna (medium)\":{\"description\":\"Luna at medium reasoning effort for delegated search, triage, inventory, and bounded mechanical tasks.\",\"prompt\":\"You are GPT-5.6 Luna running at medium reasoning effort. Complete the scoped task efficiently and report only relevant verified findings. ${no_nested_agents}\",\"model\":\"gpt-5.6-luna\",\"effort\":\"medium\"}}"
readonly claudex_capacity_guard="Claudex capacity rule: keep at most ${CLAUDEX_MAX_AGENT_CONCURRENCY} delegated workers active at once across Agent tasks and native Agent Teams. For ordinary delegation, launch no more than ${CLAUDEX_MAX_AGENT_CONCURRENCY} named agents in a wave and wait for one to finish before starting another. Create a native Agent Team only when the user explicitly requests one, and keep its active teammates within the same ${CLAUDEX_MAX_AGENT_CONCURRENCY}-worker limit. Sol capacity is reserved for the leader; use the named Terra (high) or Luna (medium) agents for delegated work. For every Agent call, make its description '- <concise task>' so the activity list renders labels such as 'Terra (high) - Audit JSON parser bugs'. If a model reports a 429 or cooldown, do not launch replacement agents or create a retry storm; continue useful local work and retry at most once after active agents settle."
readonly claudex_task_guard="Claudex task lifecycle rule: outside an explicitly requested native Agent Team, the Sol leader is the sole owner of the shared task list. Keep it compact and create only tasks that represent real remaining deliverables, not duplicate discovery lanes or speculative work. Mark a task in_progress only while the leader or a currently active agent is working on it; queued or blocked work stays pending. After every agent result, immediately reconcile its parent task and mark it completed once its outcome is integrated and verified. Before every final answer, call TaskList and reconcile every entry: completed work must be completed, inactive work must not remain in_progress, and genuinely unfinished pending work must be explicitly reported instead of being hidden behind a completion claim. Never leave stale in_progress tasks after their work is done."
readonly claudex_codex_guard="Claudex Codex model rule: operate as a Codex coding agent inside Claude Code's interface. Treat the available Claude Code tools and their schemas as the authoritative execution protocol. Prefer direct implementation and verification for concrete change requests. Ask as few questions as possible: inspect available context first, make safe reasonable assumptions, and continue without confirmation for routine, reversible work inside the requested scope. Never repeat a question the user already answered. Ask only when the missing answer cannot be discovered and would materially change the result, authorize a meaningful scope expansion, or precede an irreversible action. Treat the user's explicit approval as decisive for the specifically named action and target: after a soft auto mode denial, ask for precise consent only when it is missing, then retry once when the user grants it instead of claiming the denial is permanent. Hard deny security boundaries still apply. Do not invent unsupported provider behavior, do not expose raw internal tool protocol, and keep progress updates concise and based on evidence."
if [[ "$CLAUDEX_PLAN_MODE_POLICY" == conservative ]]; then
  readonly claudex_plan_guard="Claudex plan mode rule: remain in the current execution mode by default. Do not call EnterPlanMode or switch into plan permission mode merely because work is large, complex, unfamiliar, or benefits from private reasoning. Enter plan mode only when the user explicitly asks for a planning or design only response, when a required user decision would materially change the implementation, or when the requested action is irreversible and needs approval before execution. For ordinary bug fixes and implementation requests, inspect, implement, test, and report directly."
else
  readonly claudex_plan_guard=""
fi
readonly claudex_leader_guard="${claudex_capacity_guard}

${claudex_task_guard}

${claudex_codex_guard}

${claudex_plan_guard}"

claude_args=()
for skill_directory in ${skill_bridge_add_dirs[@]+"${skill_bridge_add_dirs[@]}"}; do
  claude_args+=(--add-dir "$skill_directory")
done
for plugin_directory in ${skill_bridge_plugin_dirs[@]+"${skill_bridge_plugin_dirs[@]}"}; do
  claude_args+=(--plugin-dir "$plugin_directory")
done
if (( inject_agents )) && claude_supports '--agents'; then
  claude_args+=(--agents "$claudex_agents")
fi
if (( inject_leader_guard )) && claude_supports '--append-system-prompt'; then
  claude_args+=(--append-system-prompt "$claudex_leader_guard")
fi
if (( inject_permission )) && claude_supports '--permission-mode'; then
  claude_args+=(--permission-mode "$permission_mode")
fi
if (( ! direct_chrome )) && [[ "$settings_file" != "$claudex_config_dir/settings.json" && "$effort_mode" != ultracode ]]; then
  claude_args+=(--settings "$settings_file")
fi
if (( use_proxy )) && [[ -n "$start_model" ]] && (( ! forwarded_model_specified )); then
  claude_args+=(--model "$start_model")
  if [[ "$start_model" == opusplan ]]; then export CLAUDEX_MODEL_MODE=solplan; fi
elif (( use_proxy && forwarded_model_specified )) && [[ "$start_model" == opusplan ]]; then
  export CLAUDEX_MODEL_MODE=solplan
fi
case "$effort_mode" in
  ultracode)
    claude_supports '--effort' || {
      printf '%s\n' 'claudex: this Claude Code build lacks --effort; run `claude update`.' >&2
      exit 1
    }
    if (( direct_chrome )); then
      ultracode_settings='{"ultracode":true,"workflows":true}'
    else
      ultracode_settings=$(jq -c '. + {ultracode: true, workflows: true}' "$settings_file")
    fi
    claude_args+=(--settings "$ultracode_settings" --effort xhigh)
    export CLAUDEX_SESSION_MODE=ultracode CLAUDE_CODE_EFFORT_LEVEL=xhigh
    ;;
  max)
    claude_supports '--effort' || {
      printf '%s\n' 'claudex: this Claude Code build lacks --effort; run `claude update`.' >&2
      exit 1
    }
    claude_args+=(--effort max)
    export CLAUDEX_SESSION_MODE=max CLAUDE_CODE_EFFORT_LEVEL=max
    ;;
esac

emit_mouse_pointer_shape() {
  local shape="$1"
  [[ "$CLAUDEX_MOUSE_POINTER_SHAPE" != "off" && -t 1 ]] || return 0

  # Ghostty implements OSC 22 application-controlled mouse pointer shapes.
  printf '\033]22;%s\033\\' "$shape"
}

resume_marker=""
claude_pid=""
claude_signal_exit=0
claude_signal_name=""
claude_escalation_pid=""
emit_mouse_pointer_shape "$CLAUDEX_MOUSE_POINTER_SHAPE"
cleanup_session() {
  emit_mouse_pointer_shape default
  [[ -z "${resume_marker:-}" ]] || rm -f "$resume_marker"
  if [[ -n "${claude_pid:-}" ]] && kill -0 "$claude_pid" 2>/dev/null; then
    kill -KILL "$claude_pid" 2>/dev/null || true
    wait "$claude_pid" 2>/dev/null || true
  fi
  if [[ -n "${claude_escalation_pid:-}" ]]; then
    kill "$claude_escalation_pid" 2>/dev/null || true
    wait "$claude_escalation_pid" 2>/dev/null || true
  fi
  if (( ! parsed_background )) && [[ -n "${auth_watcher_pid:-}" ]]; then
    kill "$auth_watcher_pid" 2>/dev/null || true
    wait "$auth_watcher_pid" 2>/dev/null || true
  fi
  if (( ! parsed_background )) && [[ -n "${proxy_watcher_pid:-}" ]]; then
    kill "$proxy_watcher_pid" 2>/dev/null || true
    wait "$proxy_watcher_pid" 2>/dev/null || true
  fi
}
trap cleanup_session EXIT

rewrite_resume_footer=0
if { [[ -t 0 && -t 1 ]] || [[ "${CLAUDEX_TEST_TTY_OUTPUT:-0}" == 1 ]]; }; then
  rewrite_resume_footer=1
  if (( parsed_background )); then rewrite_resume_footer=0; fi
  for argument in ${forwarded_args[@]+"${forwarded_args[@]}"}; do
    case "$argument" in
      --print|-p|--help|-h|--version|-v|doctor) rewrite_resume_footer=0 ;;
    esac
  done
fi
if (( rewrite_resume_footer )); then
  resume_marker=$(mktemp "$claudex_config_dir/.resume-start.XXXXXX")
fi

start_claude() {
  (
    # Bash gives asynchronous commands ignored INT/QUIT dispositions. Restore
    # defaults before exec while explicitly preserving stdin so Claude remains
    # the normal foreground TUI job rather than receiving /dev/null.
    trap - INT QUIT TERM HUP
    if (( ${#claude_args[@]} > 0 )); then
      if (( ${#forwarded_args[@]} > 0 )); then
        exec claude "${claude_args[@]}" "${forwarded_args[@]}"
      else
        exec claude "${claude_args[@]}"
      fi
    elif (( ${#forwarded_args[@]} > 0 )); then
      exec claude "${forwarded_args[@]}"
    else
      exec claude
    fi
  ) <&0 &
  claude_pid=$!
}

forward_claude_signal() {
  local signal="$1" signal_exit="$2"
  if (( claude_signal_exit == 0 )); then
    claude_signal_name="$signal"
    claude_signal_exit="$signal_exit"
  fi
  [[ -z "$claude_pid" ]] || kill -s "$signal" "$claude_pid" 2>/dev/null || true
  if [[ -n "$claude_pid" && -z "$claude_escalation_pid" ]]; then
    (
      trap - EXIT TERM INT HUP
      sleep 2
      kill -KILL "$claude_pid" 2>/dev/null || true
    ) &
    claude_escalation_pid=$!
  fi
}

trap 'forward_claude_signal TERM 143' TERM
trap 'forward_claude_signal INT 130' INT
trap 'forward_claude_signal HUP 129' HUP
set +e
start_claude
wait "$claude_pid"
claude_exit=$?
if (( claude_signal_exit != 0 )); then
  if kill -0 "$claude_pid" 2>/dev/null; then wait "$claude_pid" 2>/dev/null || true; fi
  if [[ -n "$claude_escalation_pid" ]]; then
    kill "$claude_escalation_pid" 2>/dev/null || true
    wait "$claude_escalation_pid" 2>/dev/null || true
    claude_escalation_pid=""
  fi
  claude_exit="$claude_signal_exit"
  rewrite_resume_footer=0
fi
set -e
trap - TERM INT HUP

if (( rewrite_resume_footer )); then
  project_key=$(printf '%s' "$PWD" | sed 's/[^A-Za-z0-9]/-/g')
  project_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects/$project_key"
  latest_session_file=""
  matching_session_count=0
  if [[ -d "$project_dir" ]]; then
    while IFS= read -r candidate; do
      candidate_session_id="${candidate##*/}"
      candidate_session_id="${candidate_session_id%.jsonl}"
      [[ "$candidate_session_id" =~ ^[0-9a-fA-F-]{36}$ ]] || continue
      # Agent and concurrent-session logs can change while the root session is
      # closing. Select only a root record for this working directory, then use
      # its actual session ID for the launcher-owned footer replacement.
      tail -n 200 "$candidate" 2>/dev/null | jq -s -e \
        --arg cwd "$PWD" --arg session_id "$candidate_session_id" '
          any(.[];
            (.sessionId // "") == $session_id
            and (.cwd // "") == $cwd
            and ((.isSidechain // false) == false))
        ' >/dev/null 2>&1 || continue
      matching_session_count=$(( matching_session_count + 1 ))
      if [[ -z "$latest_session_file" || "$candidate" -nt "$latest_session_file" ]]; then latest_session_file="$candidate"; fi
    done < <(find "$project_dir" -maxdepth 1 -type f -name '*.jsonl' -newer "$resume_marker" -print 2>/dev/null)
  fi
  if (( matching_session_count == 1 )) && [[ -n "$latest_session_file" ]]; then
    session_id="${latest_session_file##*/}"
    session_id="${session_id%.jsonl}"
    if [[ "$session_id" =~ ^[0-9a-fA-F-]{36}$ ]]; then
      # Claude Code prints its hardcoded binary name after the JavaScript
      # runtime has already shut down. Append the authenticated Claudex path;
      # cursor-up erasure can corrupt wrapped or resized terminal output.
      if (( direct_chrome )); then
        printf '\nResume this session with Claudex:\nclaudex --claude-chrome --resume %s\n' "$session_id"
      else
        printf '\nResume this session with Claudex:\nclaudex --resume %s\n' "$session_id"
      fi
    fi
  fi
fi
[[ -z "$resume_marker" ]] || rm -f "$resume_marker"
exit "$claude_exit"

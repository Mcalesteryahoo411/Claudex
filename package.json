{
  "name": "claudex-codex",
  "version": "1.5.0",
  "description": "Cross-platform compatibility layer for using Codex GPT models in Claude Code",
  "type": "module",
  "files": [
    "docs/",
    "skills/",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "GOVERNANCE.md",
    "LICENSE",
    "NOTICE.md",
    "README.md",
    "SECURITY.md",
    "SUPPORT.md",
    "bootstrap.ps1",
    "bootstrap.sh",
    "claudex",
    "claudex.cmd",
    "claudex.ps1",
    "codex-session",
    "codex-session.ps1",
    "env.example",
    "install.ps1",
    "install.sh",
    "install.zsh",
    "preload.cjs",
    "skill-bridge.cjs",
    "self-update",
    "self-update.ps1",
    "settings.json",
    "statusline",
    "statusline.ps1",
    "usage-limit",
    "usage-limit.ps1"
  ],
  "scripts": {
    "check:docs": "node scripts/check-docs.mjs",
    "check:preload": "node scripts/check-preload.mjs",
    "check:skills": "node tests/skill-bridge.test.cjs && node tests/skill-contract.test.cjs && node tests/skill-security.test.cjs",
    "test": "npm run check:docs && npm run check:preload && npm run check:skills",
    "test:all": "bash ./test.sh",
    "build:release": "bash ./scripts/build-release.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claudex",
    "claude-code",
    "codex",
    "openai",
    "anthropic",
    "cli",
    "developer-tools",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeamoINT/Claudex.git"
  },
  "bugs": {
    "url": "https://github.com/BeamoINT/Claudex/issues"
  },
  "homepage": "https://github.com/BeamoINT/Claudex#readme",
  "license": "MIT"
}
